# ══════════════════════════════════════════════════════════════
# TMUX CONFIGURATION TEMPLATE (Theme: {{THEME_NAME}})
# ══════════════════════════════════════════════════════════════
# this template is processed by dotfiles theme and written to:
#   ~/.config/tmux/tmux.conf (XDG standard location)
#
# a compatibility symlink exists at ~/.tmux.conf for backwards compatibility.
# change themes with: dotfiles theme switch <theme-name>
#
# quick reference:
#   Prefix: ` (backtick) or Ctrl+b (mobile-friendly)
#   Help:   ` h (popup with keybindings)
#   Save:   ` w (like vim :w)
#   List:   prefix + S (or `tls` in shell)

# ══════════════════════════════════════════════════════════════
# Core Settings
# ══════════════════════════════════════════════════════════════

# prefix key: ` (backtick, single key, double-tap for literal)
# secondary prefix: Ctrl+b (mobile-friendly, works alongside backtick)
set -g prefix `
set -g prefix2 C-b
bind ` send-prefix
bind C-b send-prefix -2

# terminal colours: enable 256-colour and true colour (RGB) support
# use terminal-features wildcard so RGB works regardless of outer TERM
# (xterm-ghostty under Ghostty, xterm-256color under other emulators, etc.)
set -g default-terminal "tmux-256color"
set -ag terminal-features "*:RGB"
# remap Home/End to CSI sequences so cmd+left/right work in all pane apps
set -ag terminal-overrides ",xterm-256color:khome=\E[H,kend=\E[F"
# Claude Code (>=2.1.77) clamps chalk to 256-colour whenever $TMUX is set,
# regardless of true terminal capability. opt out via this env var so the
# TUI emits real 24-bit RGB. see anthropics/claude-code#36785, #46146.
set-environment -g CLAUDE_CODE_TMUX_TRUECOLOR 1

# cursor: default to block (local.conf can override)
set -g cursor-style block

# mouse: enable for pane selection, scrolling, and resizing
set -g mouse on

# extended key and mouse support for apps like glow
set -ga terminal-features 'xterm*:extkeys:mouse'
set -g extended-keys always
set -s extended-keys-format csi-u    # emit kitty u-form (matches Ghostty + zsh bindkey)

# let TUIs (yazi, etc.) talk to the outer terminal directly. required by yazi;
# also stops its startup escape sequences leaking through tmux
set -g allow-passthrough on

# let inner apps set the terminal clipboard via OSC52. this is what allows
# nvim yanks to reach the OS clipboard across separate tmux panes/windows.
set -g set-clipboard on

# forward terminal focus events into panes (nvim :checktime autoreload,
# Claude Code focus tracking, TUIs that pause when unfocused)
set -g focus-events on

# import the launcher root vars from each attaching client into the session
# environment so the launcher picker popup (prefix + p) can see them. without
# this a popup only sees the server's start-time global env, so vars exported
# later in ~/.zshrc never reach it and the directory list comes up empty
set -ga update-environment "DEV_ROOT"
set -ga update-environment "PROJECTS_ROOT"
set -ga update-environment "PROJECT_DIRS"

# pass mouse wheel to apps using alternate screen (glow, k9s, etc.)
bind -n WheelUpPane if -F '#{alternate_on}' 'send-keys -M' 'if -F "#{mouse_any_flag}" "send -M" "copy-mode -e; send-keys -M"'
bind -n WheelDownPane if -F '#{alternate_on}' 'send-keys -M' 'send-keys -M'

# click session name in status bar to open session switcher
bind -n MouseDown1StatusLeft display-popup -w 95% -h 95% -E "\
  source {{DOTFILES_ROOT}}/scripts/fzf-theme.sh 2>/dev/null || true; \
  ~/.tmux/scripts/sessions/list.sh | \
  fzf --ansi --reverse --exact --disabled --cycle \
      --header-lines=7 \
      --color=label:{{TMUX_FG_PRIMARY}} \
      --prompt ': ' \
      --border=rounded \
      --border-label=' j/k ↓/↑ · g/G top/bottom · spc/⏎ sel · / srch · q/esc · n new · r rename · x kill · u undo ' \
      --border-label-pos=bottom \
      --preview '~/.tmux/scripts/utils/preview-pane.sh \$(echo {} | cut -d\" \" -f1)' \
      --preview-window='right,70%,<80(bottom,40%)' \
      --bind 'every(0.5):refresh-preview' \
      --bind 'j:down,k:up,g:first,G:last,q:abort,space:accept' \
      --bind 'enter:accept' \
      --bind 'change:transform:[[ \$FZF_PROMPT == \": \" ]] && echo \"clear-query\"' \
      --bind '/:enable-search+change-prompt(> )+unbind(j,k,g,G,q,space,n,r,x,u)' \
      --bind 'esc:transform:[[ \$FZF_PROMPT == \"> \" ]] && echo \"disable-search+clear-query+change-prompt(: )+rebind(j,k,g,G,q,space,n,r,x,u)\" || echo \"abort\"' \
      --bind 'ctrl-k:up,ctrl-l:clear-query' \
      --bind 'x:execute(~/.tmux/scripts/sessions/kill.sh \$(echo {} | cut -d\" \" -f1))+reload-sync(~/.tmux/scripts/sessions/list.sh)' \
      --bind 'u:execute(~/.tmux/scripts/sessions/undo.sh --quick)+reload-sync(~/.tmux/scripts/sessions/list.sh)' \
      --bind 'n:become(~/.tmux/scripts/sessions/new.sh)' \
      --bind 'r:execute(~/.tmux/scripts/sessions/rename.sh \$(echo {} | cut -d\" \" -f1) >/dev/null)+reload-sync(~/.tmux/scripts/sessions/list.sh)' | \
  cut -d' ' -f1 | xargs -r tmux switch-client -t"

# click alerts in status-right to jump to alert source (or pick if multiple)
bind -n MouseDown1StatusRight if-shell '[ #{client_width} -ge 80 ]' \
  'display-popup -w 50 -h 10 -E "source {{DOTFILES_ROOT}}/scripts/fzf-theme.sh 2>/dev/null || true; ~/.tmux/scripts/alerts/pick.sh"' \
  'display-popup -w 95% -h 14 -E "source {{DOTFILES_ROOT}}/scripts/fzf-theme.sh 2>/dev/null || true; ~/.tmux/scripts/alerts/pick.sh"'

# alert picker (prefix + A): keyboard shortcut for alerts
bind A if-shell '[ #{client_width} -ge 80 ]' \
  'display-popup -w 50 -h 10 -E "source {{DOTFILES_ROOT}}/scripts/fzf-theme.sh 2>/dev/null || true; ~/.tmux/scripts/alerts/pick.sh"' \
  'display-popup -w 95% -h 14 -E "source {{DOTFILES_ROOT}}/scripts/fzf-theme.sh 2>/dev/null || true; ~/.tmux/scripts/alerts/pick.sh"'

# indexing: start windows and panes at 1 (matches keyboard layout)
set -g base-index 1
setw -g pane-base-index 1

# auto-renumber windows when one is closed (no gaps in numbering)
set -g renumber-windows on

# command exit alert colours (theme-aware, set by dotfiles theme)
set -g @exit_pass_colour "{{TMUX_EXIT_PASS_COLOUR}}"
set -g @exit_fail_colour "{{TMUX_EXIT_FAIL_COLOUR}}"

# bell monitoring: highlight windows when Claude Code needs attention (via hooks)
setw -g monitor-activity off
setw -g monitor-bell on
set -g visual-bell off                # don't show message, just highlight

# window naming: directory name for shells, kebab-cased session title for
# claude code panes (OSC title, /rename-aware), otherwise the command.
# claude's process name is its version string (e.g. 2.1.202), hence the
# version-pattern match alongside claude*. title processing: strip the leading
# state glyph, map the startup "Claude Code" title to plain "claude",
# lowercase via 26 chained s/// (tmux formats have no case modifier), collapse
# spaces to hyphens, cap at 24 chars trimmed back to a hyphen boundary. the
# glyph strip uses + not * (an anchored empty match drops a char, regsub.c
# bug) and the boundary trim sits in a nested expansion because all s/// run
# before =|24| within one #{} regardless of written order
setw -g automatic-rename on
setw -g automatic-rename-format '#{?#{==:#{pane_current_command},zsh},#{b:pane_current_path},#{?#{||:#{m:claude*,#{pane_current_command}},#{m:[0-9]*.[0-9]*.[0-9]*,#{pane_current_command}}},#{?#{==:#{s/^[^a-zA-Z0-9]+//:pane_title},Claude Code},claude,#{s/-[^-]*…$/…/:#{s/^[^a-zA-Z0-9]+//;s/A/a/;s/B/b/;s/C/c/;s/D/d/;s/E/e/;s/F/f/;s/G/g/;s/H/h/;s/I/i/;s/J/j/;s/K/k/;s/L/l/;s/M/m/;s/N/n/;s/O/o/;s/P/p/;s/Q/q/;s/R/r/;s/S/s/;s/T/t/;s/U/u/;s/V/v/;s/W/w/;s/X/x/;s/Y/y/;s/Z/z/;s/ +/-/;=|24|…:pane_title}}},#{pane_current_command}}}'

# performance: eliminate delay after pressing Escape (important for vim)
set -s escape-time 0

# history: 50,000 lines of scrollback per pane
set -g history-limit 50000

# status bar refresh: every second (keeps right-side clock seconds in sync)
set -g status-interval 1

# ══════════════════════════════════════════════════════════════
# Keybindings
# ══════════════════════════════════════════════════════════════
# note: "M-" means Option/Alt key, "-n" means no prefix required

# unbind keys to pass through to shell/apps (Ctrl+z suspend, etc.)
unbind -n C-z
unbind -n C-o
unbind -n C-p
unbind -n C-x

# unbind default new-window (use Opt+t instead)
unbind c

# unbind default new-window (Shift variant, reused for Codex picker)
unbind C

# unbind default kill-pane (use Opt+s for kill-pane, Opt+x for kill-window)
unbind x

# unbind default clock (use prefix+t for theme picker instead)
unbind t

# unbind default last-window (prefix+l conflicts with pane navigation)
unbind l

# unbind default paste (use prefix+p for launcher picker instead)
unbind p

# unbind default next-layout (use prefix+Space for thumbs instead)
unbind Space

# unbind default zoom-pane (use Opt+z instead)
unbind z

# ─────────────────────────────────────────
# Window (tab) navigation
# ─────────────────────────────────────────
bind -n M-[ previous-window          # Opt+[
bind -n M-] next-window              # Opt+]

# pass Ctrl+Enter / Ctrl+Shift+Enter through to the inner program
# (extended-keys would otherwise consume them and leak the tail bytes)
bind -n C-Enter   send-keys C-Enter
bind -n C-S-Enter send-keys C-S-Enter

# previous/next window (prefix variants for mobile)
bind , next-window                    # prefix + ,
bind . previous-window                # prefix + .

# jump to window by number (requires prefix)
bind 1 select-window -t 1
bind 2 select-window -t 2
bind 3 select-window -t 3
bind 4 select-window -t 4
bind 5 select-window -t 5

# new window in current directory
bind -n M-t new-window -c "#{pane_current_path}"    # Opt+t

# window operations (right-click menu alternatives)
bind -n M-r if-shell '[ #{client_width} -ge 80 ]' \
  'display-popup -w 50 -h 7 -E "source {{DOTFILES_ROOT}}/scripts/fzf-theme.sh 2>/dev/null || true; ~/.tmux/scripts/windows/rename.sh"' \
  'display-popup -w 95% -h 7 -E "source {{DOTFILES_ROOT}}/scripts/fzf-theme.sh 2>/dev/null || true; ~/.tmux/scripts/windows/rename.sh"'
bind -n "M-{" swap-window -t -1 \; select-window -t -1                  # Opt+Shift+[ = swap left
bind -n "M-}" swap-window -t +1 \; select-window -t +1                  # Opt+Shift+] = swap right
bind -n M-x if-shell '[ #{client_width} -ge 80 ]' \
  'display-popup -E -w 50 -h 10 "TMUX_SESSION=#{session_name} TMUX_WINDOW=#{window_index} ~/.tmux/scripts/windows/kill.sh #{session_name}:#{window_index}"' \
  'display-popup -E -w 95% -h 10 "TMUX_SESSION=#{session_name} TMUX_WINDOW=#{window_index} ~/.tmux/scripts/windows/kill.sh #{session_name}:#{window_index}"'
bind -n M-q if-shell '[ #{client_width} -ge 80 ]' \
  'display-popup -E -w 50 -h 10 "~/.tmux/scripts/sessions/kill.sh"' \
  'display-popup -E -w 95% -h 10 "~/.tmux/scripts/sessions/kill.sh"'
bind -n M-u run-shell '~/.tmux/scripts/utils/undo-dispatch.sh'                  # Opt+u = undo last closed pane/window
bind -n M-D run-shell '~/.tmux/scripts/windows/duplicate.sh'               # Opt+Shift+d = duplicate window

# ─────────────────────────────────────────
# Claude instance switcher (prefix + c)
# Navigation: j/k (↓/↑), g/G (top/bottom)
# press / to start searching, Esc to return to navigation mode
# ─────────────────────────────────────────
bind c display-popup -w 95% -h 95% -E "\
  source {{DOTFILES_ROOT}}/scripts/fzf-theme.sh 2>/dev/null || true; \
  ~/.tmux/scripts/instances/claude.sh | \
  fzf --ansi --reverse --exact --disabled --cycle \
      --color=label:{{TMUX_FG_PRIMARY}} \
      --delimiter=\$'\\t' \
      --with-nth=1 \
      --header-lines=7 \
      --prompt ': ' \
      --border=rounded \
      --border-label=' j/k · g/G · spc/⏎ sel · / srch · n new · x kill · q/esc ' \
      --border-label-pos=bottom \
      --preview '~/.tmux/scripts/utils/preview-pane.sh {2}' \
      --preview-window='right,60%,<60(bottom,40%)' \
      --bind 'every(0.5):refresh-preview' \
      --bind 'every(2):reload-sync(~/.tmux/scripts/instances/claude.sh)' \
      --bind 'j:down,k:up,g:first,G:last,q:abort,space:accept' \
      --bind 'enter:accept' \
      --bind 'change:transform:[[ \$FZF_PROMPT == \": \" ]] && echo \"clear-query\"' \
      --bind '/:enable-search+change-prompt(> )+unbind(j,k,g,G,q,space,n,x)' \
      --bind 'esc:transform:[[ \$FZF_PROMPT == \"> \" ]] && echo \"disable-search+clear-query+change-prompt(: )+rebind(j,k,g,G,q,space,n,x)\" || echo \"abort\"' \
      --bind 'ctrl-k:up,ctrl-l:clear-query' \
      --bind 'n:execute-silent(~/.tmux/scripts/instances/new.sh claude)+abort' \
      --bind 'x:execute(~/.tmux/scripts/instances/kill.sh {2} claude)+reload-sync(~/.tmux/scripts/instances/claude.sh)' | \
  cut -f2 | xargs -r tmux switch-client -t"

