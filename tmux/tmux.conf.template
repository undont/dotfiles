# ══════════════════════════════════════════════════════════════
# TMUX CONFIGURATION TEMPLATE (Theme: {{THEME_NAME}})
# ══════════════════════════════════════════════════════════════
# This template is processed by theme-switch and written to:
#   ~/.config/tmux/tmux.conf (XDG standard location)
#
# A compatibility symlink exists at ~/.tmux.conf for backwards compatibility.
# Change themes with: theme-switch <theme-name>
#
# See ~/.tmux/README.md for full documentation and setup guide.
#
# Quick reference:
#   Prefix: ` (backtick)
#   Help:   ` h (popup with keybindings)
#   Save:   ` w (like vim :w)
#   List:   prefix + S (or `tls` in shell)

# ══════════════════════════════════════════════════════════════
# Core Settings
# ══════════════════════════════════════════════════════════════

# Prefix key: ` (backtick - single key, double-tap for literal)
unbind C-b
set -g prefix `
bind ` send-prefix

# Terminal colours: enable 256-colour and true colour (RGB) support
set -g default-terminal "tmux-256color"
set -ag terminal-overrides ",xterm-256color:RGB"

# Mouse: enable for pane selection, scrolling, and resizing
set -g mouse on

# Extended mouse support for apps like glow
set -ga terminal-features 'xterm*:extkeys:mouse'

# Pass mouse wheel to apps using alternate screen (glow, k9s, etc.)
bind -n WheelUpPane if -F '#{alternate_on}' 'send-keys -M' 'if -F "#{mouse_any_flag}" "send -M" "copy-mode -e; send-keys -M"'
bind -n WheelDownPane if -F '#{alternate_on}' 'send-keys -M' 'send-keys -M'

# Click session name in status bar to open session switcher
bind -n MouseDown1StatusLeft display-popup -w 95% -h 95% -E "\
  source \$HOME/dotfiles/scripts/fzf-theme.sh 2>/dev/null || true; \
  ~/.tmux/scripts/clear-agent-alerts.sh '#{session_name}' '#{window_name}' '#{window_id}'; \
  ~/.tmux/scripts/list-sessions.sh | \
  fzf --ansi --reverse --disabled --cycle \
      --header-lines=7 \
      --color=label:{{TMUX_FG_PRIMARY}} \
      --prompt ': ' \
      --border=rounded \
      --border-label=' j/k down/up · g/G first/last · spc/⏎ sel · / srch · q/esc · n new · r rename · x kill · u undo ' \
      --border-label-pos=bottom \
      --preview 'tmux capture-pane -ep -t \$(echo {} | cut -d\" \" -f1)' \
      --preview-window=right:70% \
      --bind 'j:down,k:up,g:first,G:last,q:abort,space:accept' \
      --bind 'enter:accept' \
      --bind 'change:transform:[[ \$FZF_PROMPT == \": \" ]] && echo \"clear-query\"' \
      --bind '/:enable-search+change-prompt(> )+unbind(j,k,g,G,q,space,n,r,x)' \
      --bind 'esc:transform:[[ \$FZF_PROMPT == \"> \" ]] && echo \"disable-search+clear-query+change-prompt(: )+rebind(j,k,g,G,q,space,n,r,x)\" || echo \"abort\"' \
      --bind 'ctrl-k:kill-line,ctrl-w:unix-line-discard' \
      --bind 'x:execute(~/.tmux/scripts/kill-session.sh \$(echo {} | cut -d\" \" -f1))+reload-sync(~/.tmux/scripts/list-sessions.sh)' \
      --bind 'u:execute(~/.tmux/scripts/undo-session.sh --quick)+reload-sync(~/.tmux/scripts/list-sessions.sh)' \
      --bind 'n:become(~/.tmux/scripts/new-session.sh)' \
      --bind 'r:become(~/.tmux/scripts/rename-session.sh \$(echo {} | cut -d\" \" -f1))' | \
  cut -d' ' -f1 | xargs -r tmux switch-client -t"

# Indexing: start windows and panes at 1 (matches keyboard layout)
set -g base-index 1
setw -g pane-base-index 1

# Auto-renumber windows when one is closed (no gaps in numbering)
set -g renumber-windows on

# Bell monitoring: highlight windows when Claude Code needs attention (via hooks)
setw -g monitor-activity off
setw -g monitor-bell on
set -g visual-bell off                # Don't show message, just highlight

# Window naming: show directory name if shell, otherwise show command
setw -g automatic-rename on
setw -g automatic-rename-format '#{?#{==:#{pane_current_command},zsh},#{b:pane_current_path},#{pane_current_command}}'

# Performance: eliminate delay after pressing Escape (important for vim)
set -s escape-time 0

# History: 50,000 lines of scrollback per pane
set -g history-limit 50000

# Status bar refresh: every 2 seconds (for responsive CPU/RAM display)
set -g status-interval 2

# ══════════════════════════════════════════════════════════════
# Keybindings
# ══════════════════════════════════════════════════════════════
# Note: "M-" means Option/Alt key, "-n" means no prefix required

# Unbind keys to pass through to shell/apps (Ctrl+z suspend, etc.)
unbind -n C-z
unbind -n C-o
unbind -n C-p
unbind -n C-x

# Unbind default new-window (use Opt+t instead)
unbind c

# Unbind default kill-pane (use Opt+s for kill-pane, Opt+x for kill-window)
unbind x

# Unbind default clock (use prefix+t for theme picker instead)
unbind t

# Unbind default paste (use prefix+p for launcher picker instead)
unbind p

# ─────────────────────────────────────────
# Window (tab) navigation
# ─────────────────────────────────────────
bind -n M-[ previous-window          # Opt+[
bind -n M-] next-window              # Opt+]
bind -n C-Enter next-window          # Ctrl+Enter
bind -n C-S-Enter previous-window    # Ctrl+Shift+Enter

# Jump to window by number (requires prefix)
bind 1 select-window -t 1
bind 2 select-window -t 2
bind 3 select-window -t 3
bind 4 select-window -t 4
bind 5 select-window -t 5

# New window in current directory
bind -n M-t new-window -c "#{pane_current_path}"    # Opt+t

# Window operations (right-click menu alternatives)
bind -n M-r display-popup -w 55 -h 7 -E "source \$HOME/dotfiles/scripts/fzf-theme.sh 2>/dev/null || true; ~/.tmux/scripts/rename-window.sh"    # Opt+r = rename window
bind -n "M-{" swap-window -t -1 \; select-window -t -1                  # Opt+Shift+[ = swap left
bind -n "M-}" swap-window -t +1 \; select-window -t +1                  # Opt+Shift+] = swap right
bind -n M-x display-popup -E -w 60 -h 10 "TMUX_SESSION=#{session_name} TMUX_WINDOW=#{window_index} ~/.tmux/scripts/kill-window.sh #{session_name}:#{window_index}"           # Opt+x = kill window (saves state for undo)
bind -n M-u run-shell '~/.tmux/scripts/undo-dispatch.sh'                  # Opt+u = undo last closed pane/window
bind -n M-D run-shell '~/.tmux/scripts/duplicate-window.sh'               # Opt+Shift+d = duplicate window

# ─────────────────────────────────────────
# Claude instance switcher (prefix + c)
# Navigation: j/k (up/down), g/G (first/last)
# Press / to start searching, Esc to return to navigation mode
# ─────────────────────────────────────────
bind c display-popup -w 95% -h 95% -E "\
  source \$HOME/dotfiles/scripts/fzf-theme.sh 2>/dev/null || true; \
  ~/.tmux/scripts/list-claude.sh | \
  fzf --ansi --reverse --disabled --cycle \
      --color=label:{{TMUX_FG_PRIMARY}} \
      --header-lines=5 \
      --prompt ': ' \
      --border=rounded \
      --border-label=' j/k · g/G · spc/⏎ sel · / srch · n new · x kill · q/esc ' \
      --border-label-pos=bottom \
      --preview 'tmux capture-pane -ep -t \$(echo {} | cut -d\" \" -f1)' \
      --preview-window=right:70% \
      --bind 'j:down,k:up,g:first,G:last,q:abort,space:accept' \
      --bind 'enter:accept' \
      --bind 'change:transform:[[ \$FZF_PROMPT == \": \" ]] && echo \"clear-query\"' \
      --bind '/:enable-search+change-prompt(> )+unbind(j,k,g,G,q,space,n,x)' \
      --bind 'esc:transform:[[ \$FZF_PROMPT == \"> \" ]] && echo \"disable-search+clear-query+change-prompt(: )+rebind(j,k,g,G,q,space,n,x)\" || echo \"abort\"' \
      --bind 'ctrl-k:kill-line,ctrl-w:unix-line-discard' \
      --bind 'n:become(~/.tmux/scripts/new-instance.sh claude)' \
      --bind 'x:execute(~/.tmux/scripts/kill-instance.sh \$(echo {} | cut -d\" \" -f1) claude)+reload-sync(~/.tmux/scripts/list-claude.sh)' | \
  cut -d' ' -f1 | \
  xargs -r sh -c 'SESSION=\$(echo \$1 | cut -d: -f1); WINDOW=\$(echo \$1 | cut -d: -f2 | cut -d. -f1); ~/.tmux/scripts/clear-agent-alerts.sh \"\$SESSION\" \"\$(tmux list-windows -t \$SESSION -F \"#{window_index} #{window_name}\" | grep \"^\$WINDOW \" | cut -d\" \" -f2-)\" \"\"; tmux switch-client -t \$1' _"

# ─────────────────────────────────────────
# OpenCode instance switcher (prefix + o)
# Navigation: j/k (up/down), g/G (first/last)
# Press / to start searching, Esc to return to navigation mode
# ─────────────────────────────────────────
bind o display-popup -w 95% -h 95% -E "\
  source \$HOME/dotfiles/scripts/fzf-theme.sh 2>/dev/null || true; \
  ~/.tmux/scripts/list-opencode.sh | \
  fzf --ansi --reverse --disabled --cycle \
      --color=label:{{TMUX_FG_PRIMARY}} \
      --header-lines=5 \
      --prompt ': ' \
      --border=rounded \
      --border-label=' j/k · g/G · spc/⏎ sel · / srch · n new · x kill · q/esc ' \
      --border-label-pos=bottom \
      --preview 'tmux capture-pane -ep -t \$(echo {} | cut -d\" \" -f1)' \
      --preview-window=right:70% \
      --bind 'j:down,k:up,g:first,G:last,q:abort,space:accept' \
      --bind 'enter:accept' \
      --bind 'change:transform:[[ \$FZF_PROMPT == \": \" ]] && echo \"clear-query\"' \
      --bind '/:enable-search+change-prompt(> )+unbind(j,k,g,G,q,space,n,x)' \
      --bind 'esc:transform:[[ \$FZF_PROMPT == \"> \" ]] && echo \"disable-search+clear-query+change-prompt(: )+rebind(j,k,g,G,q,space,n,x)\" || echo \"abort\"' \
      --bind 'ctrl-k:kill-line,ctrl-w:unix-line-discard' \
      --bind 'n:become(~/.tmux/scripts/new-instance.sh opencode)' \
      --bind 'x:execute(~/.tmux/scripts/kill-instance.sh \$(echo {} | cut -d\" \" -f1) opencode)+reload-sync(~/.tmux/scripts/list-opencode.sh)' | \
  cut -d' ' -f1 | \
  xargs -r sh -c 'SESSION=\$(echo \$1 | cut -d: -f1); WINDOW=\$(echo \$1 | cut -d: -f2 | cut -d. -f1); ~/.tmux/scripts/clear-agent-alerts.sh \"\$SESSION\" \"\$(tmux list-windows -t \$SESSION -F \"#{window_index} #{window_name}\" | grep \"^\$WINDOW \" | cut -d\" \" -f2-)\" \"\"; tmux switch-client -t \$1' _"

# ─────────────────────────────────────────
# Pane navigation and management
# ─────────────────────────────────────────
# Vim-style navigation (Opt+hjkl)
bind -n M-h select-pane -L           # Opt+h = left
bind -n M-j select-pane -D           # Opt+j = down
bind -n M-k select-pane -U           # Opt+k = up
bind -n M-l select-pane -R           # Opt+l = right

# Alternative navigation
bind -n C-, select-pane -L           # Ctrl+, = left
bind -n C-. select-pane -D           # Ctrl+. = down

# Split panes (new panes inherit current directory)
bind -n M-\\ split-window -h -c "#{pane_current_path}"    # Opt+\ = split right
bind -n "M-'" split-window -h -b -c "#{pane_current_path}"  # Opt+' = split left
bind -n M-- split-window -v -c "#{pane_current_path}"     # Opt+- = split down
bind -n M-= split-window -v -b -c "#{pane_current_path}"  # Opt+= = split up

# Pane operations
bind -n M-s display-popup -E -w 60 -h 10 "~/.tmux/scripts/kill-pane.sh #{session_name}:#{window_index}.#{pane_index}"    # Opt+s = close pane (saves state for undo)
bind -n M-z resize-pane -Z           # Opt+z = toggle zoom (fullscreen)
bind -n "M-)" select-layout -E       # Opt+Shift+0 = equalise pane sizes

# Swap panes (requires prefix)
bind H swap-pane -U
bind J swap-pane -D
bind K swap-pane -U
bind L swap-pane -D

# Resize panes (Opt+Shift+hjkl)
bind -n M-H resize-pane -L 5           # Opt+Shift+h = shrink left
bind -n M-J resize-pane -D 5           # Opt+Shift+j = shrink down
bind -n M-K resize-pane -U 5           # Opt+Shift+k = grow up
bind -n M-L resize-pane -R 5           # Opt+Shift+l = grow right

# ─────────────────────────────────────────
# URL picker
# ─────────────────────────────────────────
# Opt+y = find all URLs in scrollback and open selected one
bind -n M-y display-popup -w 80% -h 60% -E "source \$HOME/dotfiles/scripts/fzf-theme.sh 2>/dev/null || true; ~/.tmux/scripts/pick-url.sh #{pane_id}"

# ─────────────────────────────────────────
# Nvim instance switcher (prefix + n)
# Navigation: j/k (up/down), g/G (first/last)
# Press / to start searching, Esc to return to navigation mode
# Press c to connect nvim to current pane (for buffer sync)
# ─────────────────────────────────────────
unbind n
bind n display-popup -w 95% -h 95% -E "\
  source \$HOME/dotfiles/scripts/fzf-theme.sh 2>/dev/null || true; \
  ~/.tmux/scripts/list-nvim.sh | \
  fzf --ansi --reverse --disabled --cycle \
      --color=label:{{TMUX_FG_PRIMARY}} \
      --delimiter=\$'\\t' \
      --with-nth=1 \
      --header-lines=7 \
      --prompt ': ' \
      --border=rounded \
      --border-label=' j/k · g/G · spc/⏎ sel · c connect · n new · x kill · / srch · q/esc ' \
      --border-label-pos=bottom \
      --preview 'tmux capture-pane -ep -t \$(echo {} | cut -d\" \" -f1)' \
      --preview-window=right:70% \
      --bind 'j:down,k:up,g:first,G:last,q:abort,space:accept' \
      --bind 'enter:accept' \
      --bind 'c:execute(~/.tmux/scripts/connect-nvim.sh {})+abort' \
      --bind 'n:become(~/.tmux/scripts/new-instance.sh nvim)' \
      --bind 'x:execute(~/.tmux/scripts/kill-instance.sh \$(echo {} | cut -d\" \" -f1) nvim)+reload-sync(~/.tmux/scripts/list-nvim.sh)' \
      --bind 'change:transform:[[ \$FZF_PROMPT == \": \" ]] && echo \"clear-query\"' \
      --bind '/:enable-search+change-prompt(> )+unbind(j,k,g,G,q,space,c,n,x)' \
      --bind 'esc:transform:[[ \$FZF_PROMPT == \"> \" ]] && echo \"disable-search+clear-query+change-prompt(: )+rebind(j,k,g,G,q,space,c,n,x)\" || echo \"abort\"' \
      --bind 'ctrl-k:kill-line,ctrl-w:unix-line-discard' | \
  cut -d' ' -f1 | \
  xargs -r tmux switch-client -t"

# ─────────────────────────────────────────
# Scroll mode (copy-mode)
# ─────────────────────────────────────────
# Enter scroll mode
bind -n M-v copy-mode                    # Opt+v = enter scroll mode
bind v copy-mode                         # prefix + v = enter scroll mode

# Use vi-style keys in copy mode
setw -g mode-keys vi

# Navigation in copy mode (vim-style)
bind -T copy-mode-vi j send-keys -X cursor-down
bind -T copy-mode-vi k send-keys -X cursor-up
bind -T copy-mode-vi h send-keys -X cursor-left
bind -T copy-mode-vi l send-keys -X cursor-right

# Page navigation
bind -T copy-mode-vi C-f send-keys -X page-down       # Ctrl+f = page down
bind -T copy-mode-vi C-b send-keys -X page-up         # Ctrl+b = page up

# Half-page navigation
bind -T copy-mode-vi C-d send-keys -X halfpage-down   # Ctrl+d = half page down
bind -T copy-mode-vi C-u send-keys -X halfpage-up     # Ctrl+u = half page up
bind -T copy-mode-vi d send-keys -X halfpage-down \; send-keys -X bottom-line   # d = half page down + cursor to bottom
bind -T copy-mode-vi u send-keys -X halfpage-up \; send-keys -X top-line   # u = half page up + cursor to top

# Jump to top/bottom
bind -T copy-mode-vi g send-keys -X history-top       # g = top of history
bind -T copy-mode-vi G send-keys -X history-bottom    # G = bottom of history

# Search (find on page)
bind -T copy-mode-vi / command-prompt -i -p "(search down)" "send -X search-forward-incremental \"%%%\""
bind -T copy-mode-vi ? command-prompt -i -p "(search up)" "send -X search-backward-incremental \"%%%\""
bind -T copy-mode-vi n send-keys -X search-again      # n = next match
bind -T copy-mode-vi N send-keys -X search-reverse    # N = previous match

# Visual selection
bind -T copy-mode-vi v send-keys -X begin-selection   # v = start char selection
bind -T copy-mode-vi V send-keys -X select-line       # V = select entire line

# Yank (copy to clipboard)
bind -T copy-mode-vi y send-keys -X copy-pipe-and-cancel "pbcopy"   # y = yank selection
bind -T copy-mode-vi Y send-keys -X select-line \; send-keys -X copy-pipe-and-cancel "pbcopy"  # Y = yank line
# Yank to top/bottom: use v (visual) → g/G → y instead
# tmux doesn't support multi-key sequences like vim's ygg

# Exit scroll mode
bind -T copy-mode-vi q send-keys -X cancel            # q = quit scroll mode
bind -T copy-mode-vi Escape send-keys -X cancel       # Esc = quit scroll mode

# ─────────────────────────────────────────
# Help
# ─────────────────────────────────────────
# Display keybinding reference popup (press Esc to close)
bind h display-popup -w 74 -h 44 "cat ~/.tmux/tmux-help.txt; read -sk1"    # prefix + h

# ─────────────────────────────────────────
# Theme picker (prefix + t)
# Navigation: j/k (up/down), g/G (first/last)
# Press / to start searching, Esc to return to navigation mode
# ─────────────────────────────────────────
bind t display-popup -w 70 -h 24 -E "\
  source \$HOME/dotfiles/scripts/fzf-theme.sh 2>/dev/null || true; \
  THEME_POS=\$(~/.tmux/scripts/pick-theme.sh --pos); \
  ~/.tmux/scripts/pick-theme.sh | \
  fzf --ansi --reverse --disabled --cycle \
      --bind \"load:pos(\$THEME_POS)\" \
      --color=label:{{TMUX_FG_PRIMARY}} \
      --header-lines=5 \
      --padding=0,0,1,0 \
      --prompt ': ' \
      --border=rounded \
      --border-label=' j/k · g/G · spc/⏎ sel · / srch · q/esc ' \
      --border-label-pos=bottom \
      --bind 'j:down,k:up,g:first,G:last,q:abort,space:accept' \
      --bind 'enter:accept' \
      --bind 'change:transform:[[ \$FZF_PROMPT == \": \" ]] && echo \"clear-query\"' \
      --bind '/:enable-search+change-prompt(> )+unbind(j,k,g,G,q,space)' \
      --bind 'esc:transform:[[ \$FZF_PROMPT == \"> \" ]] && echo \"disable-search+clear-query+change-prompt(: )+rebind(j,k,g,G,q,space)\" || echo \"abort\"' \
      --bind 'ctrl-k:kill-line,ctrl-w:unix-line-discard' | \
  awk '{print \$1}' | \
  xargs -r -I {} sh -c '\$HOME/dotfiles/scripts/theme-switch {} --no-reload --quiet && tmux source-file \$HOME/.tmux.conf && ~/.tmux/scripts/reload-ghostty.sh && ~/.tmux/scripts/reload-fzf.sh && tmux display-message \"Theme: {}\"'"

# ─────────────────────────────────────────
# Launcher picker (prefix + p)
# Navigation: j/k (up/down), g/G (first/last)
# Press / to start searching, Esc to return to navigation mode
# Press n to create a new launcher
# ─────────────────────────────────────────
bind p display-popup -w 60% -h 60% -E "\
  source \$HOME/dotfiles/scripts/fzf-theme.sh 2>/dev/null || true; \
  ~/.tmux/scripts/list-launchers.sh | \
  fzf --ansi --reverse --disabled --cycle \
      --color=label:{{TMUX_FG_PRIMARY}} \
      --header-lines=7 \
      --padding=0,0,1,0 \
      --prompt ': ' \
      --border=rounded \
      --border-label=' j/k · g/G · spc/⏎ sel · / srch · n new · x del · q/esc ' \
      --border-label-pos=bottom \
      --bind 'j:down,k:up,g:first,G:last,q:abort' \
      --bind 'change:transform:[[ \$FZF_PROMPT == \": \" ]] && echo \"clear-query\"' \
      --bind '/:enable-search+change-prompt(> )+unbind(j,k,g,G,q,n,x)' \
      --bind 'esc:transform:[[ \$FZF_PROMPT == \"> \" ]] && echo \"disable-search+clear-query+change-prompt(: )+rebind(j,k,g,G,q,n,x)\" || echo \"abort\"' \
      --bind 'ctrl-k:kill-line,ctrl-w:unix-line-discard' \
      --bind 'n:become(~/.tmux/scripts/new-launcher-prompt.sh)' \
      --bind 'x:execute(~/.tmux/scripts/delete-launcher.sh {1})+reload-sync(~/.tmux/scripts/list-launchers.sh)' \
      --bind 'enter:become(~/.tmux/scripts/run-launcher.sh {1})' \
      --bind 'space:become(~/.tmux/scripts/run-launcher.sh {1})'"

# ─────────────────────────────────────────
# Window switcher with vim-style navigation (prefix + f)
# Navigation: j/k (up/down), g/G (first/last), f/b (page), d/u (half-page)
# Press / to start searching, Esc to return to navigation mode
# Press a to toggle between current session and all sessions
# ─────────────────────────────────────────
bind f display-popup -w 95% -h 95% -E "\
  source \$HOME/dotfiles/scripts/fzf-theme.sh 2>/dev/null || true; \
  ~/.tmux/scripts/clear-agent-alerts.sh '#{session_name}' '#{window_name}' '#{window_id}'; \
  ~/.tmux/scripts/list-windows.sh | \
  fzf --ansi --reverse --disabled --cycle \
      --header-lines=7 \
      --color=label:{{TMUX_FG_PRIMARY}} \
      --prompt ': ' \
      --border=rounded \
      --border-label=' j/k down/up · g/G first/last · spc/⏎ sel · / srch · a all · m move · q/esc · x kill · u undo ' \
      --border-label-pos=bottom \
      --preview 'tmux capture-pane -ep -t \$(echo {} | cut -d\" \" -f1)' \
      --preview-window=right:70% \
      --bind 'j:down,k:up,g:first,G:last,q:abort,space:accept' \
      --bind 'enter:accept' \
      --bind 'change:transform:[[ \$FZF_PROMPT == \": \" || \$FZF_PROMPT == \"* \" ]] && echo \"clear-query\"' \
      --bind '/:enable-search+change-prompt(> )+unbind(j,k,g,G,q,space,a,m,x)' \
      --bind 'esc:transform:[[ \$FZF_PROMPT == \"> \" ]] && echo \"disable-search+clear-query+change-prompt(: )+rebind(j,k,g,G,q,space,a,m,x)\" || echo \"abort\"' \
      --bind 'ctrl-k:kill-line,ctrl-w:unix-line-discard' \
      --bind 'a:transform:[[ \$FZF_PROMPT == \": \" ]] && echo \"change-prompt(* )+reload(~/.tmux/scripts/list-windows.sh --all)\" || echo \"change-prompt(: )+reload(~/.tmux/scripts/list-windows.sh)\"' \
      --bind 'm:execute(~/.tmux/scripts/move-window.sh \$(echo {} | cut -d\" \" -f1))+transform:[[ \$FZF_PROMPT == \"* \" ]] && echo \"reload(~/.tmux/scripts/list-windows.sh --all)\" || echo \"reload(~/.tmux/scripts/list-windows.sh)\"' \
      --bind 'x:execute(~/.tmux/scripts/kill-window.sh \$(echo {} | cut -d\" \" -f1))+transform:[[ \$FZF_PROMPT == \"* \" ]] && echo \"reload(~/.tmux/scripts/list-windows.sh --all)\" || echo \"reload(~/.tmux/scripts/list-windows.sh)\"' \
      --bind 'u:execute(~/.tmux/scripts/undo-window.sh)+transform:[[ \$FZF_PROMPT == \"* \" ]] && echo \"reload(~/.tmux/scripts/list-windows.sh --all)\" || echo \"reload(~/.tmux/scripts/list-windows.sh)\"' | \
  cut -d' ' -f1 | xargs -r tmux switch-client -t"

# ══════════════════════════════════════════════════════════════
# Status Bar (Themed)
# ══════════════════════════════════════════════════════════════

set -g status-position top
set -g status-style 'bg={{TMUX_STATUS_BG}} fg={{TMUX_STATUS_FG}}'
set -g status-left '#[fg={{TMUX_ACCENT_CYAN}}]#(~/.tmux/scripts/show-dotfiles-status.sh)#[fg={{TMUX_STATUS_BELL_FG}},bold]#S '
set -g status-right '#(~/.tmux/scripts/show-agent-alerts.sh)#{?window_zoomed_flag,#[fg={{TMUX_ACCENT_CYAN}}]Z ,}#{battery_color_charge_bg}#[fg={{TMUX_STATUS_FG}}] #{battery_icon_status} #{battery_percentage} #{cpu_bg_color}#[fg={{TMUX_STATUS_FG}}] ⚙ #{cpu_percentage} #{ram_bg_color}#[fg={{TMUX_STATUS_FG}}] ☰ #{ram_percentage} #[bg={{TMUX_FG_SECONDARY}},fg={{TMUX_STATUS_FG}}] %a %h-%d %H:%M '
set -g status-left-length 30
set -g status-right-length 150

# Window tabs: inactive=grey, active=purple highlight, bell/alert=pink
setw -g window-status-format '#[fg={{TMUX_STATUS_INACTIVE_FG}}]#{?window_bell_flag,#[fg={{TMUX_STATUS_BELL_FG}}],}#{?@claude_alert,#[fg={{TMUX_STATUS_BELL_FG}}],}#{?@gemini_alert,#[fg={{TMUX_STATUS_BELL_FG}}],}#{?@opencode_alert,#[fg={{TMUX_STATUS_BELL_FG}}],} #I:#W '
setw -g window-status-current-format '#[fg={{TMUX_STATUS_ACTIVE_FG}},bg={{TMUX_STATUS_ACTIVE_BG}},bold] #I:#W '

# Pane borders: inactive=dark grey, active=purple
set -g pane-border-style 'fg={{TMUX_PANE_BORDER_INACTIVE}}'
set -g pane-active-border-style 'fg={{TMUX_PANE_BORDER_ACTIVE}}'

# Command prompt / message bar: purple background with light text
set -g message-style 'bg={{TMUX_MESSAGE_BG}} fg={{TMUX_MESSAGE_FG}} bold'
set -g message-command-style 'bg={{TMUX_MESSAGE_COMMAND_BG}} fg={{TMUX_MESSAGE_COMMAND_FG}}'

# Copy mode (scroll mode) styling
set -g mode-style 'bg={{TMUX_ACCENT_CYAN}} fg={{TMUX_BG_PRIMARY}} bold'

# Search match highlighting in copy mode (tmux 3.2+)
# All matches highlighted in yellow, current match in bright cyan
set -g copy-mode-match-style 'bg={{TMUX_ACCENT_YELLOW}} fg={{TMUX_BG_PRIMARY}}'
set -g copy-mode-current-match-style 'bg={{TMUX_ACCENT_CYAN}} fg={{TMUX_BG_PRIMARY}} bold'

# Show search counter in mode indicator (e.g., "[3/12]" when searching)
set -g copy-mode-mark-style 'bg={{TMUX_ACCENT_PINK}} fg={{TMUX_BG_PRIMARY}} bold'

# Clock colour for copy mode
set -g clock-mode-colour "{{TMUX_ACCENT_CYAN}}"

# ══════════════════════════════════════════════════════════════
# Plugins (managed by TPM)
# ══════════════════════════════════════════════════════════════
# Install: prefix + I    Update: prefix + U    Clean: prefix + alt + u

set -g @plugin 'tmux-plugins/tpm'              # Plugin manager
set -g @plugin 'tmux-plugins/tmux-resurrect'   # Save/restore sessions
set -g @plugin 'tmux-plugins/tmux-continuum'   # Auto-save sessions
set -g @plugin 'tmux-plugins/tmux-cpu'         # CPU/RAM monitoring
set -g @plugin 'tmux-plugins/tmux-battery'    # Battery status
set -g @plugin 'tmux-plugins/tmux-open'        # Open highlighted selection
set -g @plugin 'tmux-plugins/tmux-yank'        # System clipboard integration

# ─────────────────────────────────────────
# Resurrect configuration
# ─────────────────────────────────────────
# Capture pane contents (terminal output) when saving
set -g @resurrect-capture-pane-contents 'on'

# Restore specific programs (space-separated list)
# Default: vi vim nvim emacs man less more tail top htop irssi weechat mutt ssh
# Add more as needed:
set -g @resurrect-processes 'ssh psql mysql sqlite3 claude opencode gemini "~rails server" "~npm start"'

# Alternative: Restore ALL running programs (use with caution)
# set -g @resurrect-processes ':all:'

# Note: Use tilde prefix (~) for fuzzy matching of commands with arguments
# Example: "~rails server" matches "/usr/bin/ruby /usr/local/bin/rails server"

# Auto-restore on tmux start
set -g @continuum-restore 'on'

# Save interval: every 1 minute (default is 15)
set -g @continuum-save-interval '1'

# ─────────────────────────────────────────
# tmux-cpu configuration
# ─────────────────────────────────────────
# Icons for different load levels
set -g @cpu_low_icon "="
set -g @cpu_medium_icon "≡"
set -g @cpu_high_icon "≣"

# CPU background colours (themed)
set -g @cpu_low_bg_color "#[bg={{TMUX_CPU_LOW_BG}}]"
set -g @cpu_medium_bg_color "#[bg={{TMUX_CPU_MEDIUM_BG}}]"
set -g @cpu_high_bg_color "#[bg={{TMUX_CPU_HIGH_BG}}]"

# Percentage format (no padding for consistent spacing)
set -g @cpu_percentage_format "%.0f%%"

# RAM icons for different load levels
set -g @ram_low_icon "="
set -g @ram_medium_icon "≡"
set -g @ram_high_icon "≣"

# RAM background colours (themed)
set -g @ram_low_bg_color "#[bg={{TMUX_RAM_LOW_BG}}]"
set -g @ram_medium_bg_color "#[bg={{TMUX_RAM_MEDIUM_BG}}]"
set -g @ram_high_bg_color "#[bg={{TMUX_RAM_HIGH_BG}}]"

# RAM percentage format (no padding for consistent spacing)
set -g @ram_percentage_format "%.0f%%"

# ─────────────────────────────────────────
# tmux-battery configuration
# ─────────────────────────────────────────
# Battery status icons (geometric, matches CPU/RAM style)
set -g @batt_icon_status_charged '■'
set -g @batt_icon_status_charging '▲'
set -g @batt_icon_status_discharging '▼'
set -g @batt_icon_status_attached '■'
set -g @batt_icon_status_unknown '?'

# Battery background colours (themed)
set -g @batt_color_charge_primary_tier8 '{{TMUX_BATTERY_NORMAL_BG}}'
set -g @batt_color_charge_primary_tier7 '{{TMUX_BATTERY_NORMAL_BG}}'
set -g @batt_color_charge_primary_tier6 '{{TMUX_BATTERY_NORMAL_BG}}'
set -g @batt_color_charge_primary_tier5 '{{TMUX_BATTERY_NORMAL_BG}}'
set -g @batt_color_charge_primary_tier4 '{{TMUX_BATTERY_NORMAL_BG}}'
set -g @batt_color_charge_primary_tier3 '{{TMUX_BATTERY_NORMAL_BG}}'
set -g @batt_color_charge_primary_tier2 '{{TMUX_BATTERY_LOW_BG}}'
set -g @batt_color_charge_primary_tier1 '{{TMUX_BATTERY_LOW_BG}}'

# Post-save hook: split combined save file into per-session files
# This enables restoring individual sessions independently
set -g @resurrect-hook-post-save-all '~/.tmux/scripts/split-resurrect.sh'

# ─────────────────────────────────────────
# Session management keybindings
# ─────────────────────────────────────────
# Built-in resurrect bindings:
#   prefix + Ctrl+s = save all sessions
#   prefix + Ctrl+r = restore all sessions

# Quick save (prefix + w, like vim :w)
bind w run-shell ~/.tmux/plugins/tmux-resurrect/scripts/save.sh

# Custom bindings for per-session management:
# Session switcher with vim-style navigation (prefix + s)
# Navigation: j/k (up/down), g/G (first/last), f/b (page), d/u (half-page)
# Press / to start searching, Esc to return to navigation mode
# Ctrl+x kills session, Ctrl+u undoes the last kill
bind s display-popup -w 95% -h 95% -E "\
  source \$HOME/dotfiles/scripts/fzf-theme.sh 2>/dev/null || true; \
  ~/.tmux/scripts/clear-agent-alerts.sh '#{session_name}' '#{window_name}' '#{window_id}'; \
  ~/.tmux/scripts/list-sessions.sh | \
  fzf --ansi --reverse --disabled --cycle \
      --header-lines=7 \
      --color=label:{{TMUX_FG_PRIMARY}} \
      --prompt ': ' \
      --border=rounded \
      --border-label=' j/k down/up · g/G first/last · spc/⏎ sel · / srch · q/esc · n new · r rename · x kill · u undo ' \
      --border-label-pos=bottom \
      --preview 'tmux capture-pane -ep -t \$(echo {} | cut -d\" \" -f1)' \
      --preview-window=right:70% \
      --bind 'j:down,k:up,g:first,G:last,q:abort,space:accept' \
      --bind 'enter:accept' \
      --bind 'change:transform:[[ \$FZF_PROMPT == \": \" ]] && echo \"clear-query\"' \
      --bind '/:enable-search+change-prompt(> )+unbind(j,k,g,G,q,space,n,r,x)' \
      --bind 'esc:transform:[[ \$FZF_PROMPT == \"> \" ]] && echo \"disable-search+clear-query+change-prompt(: )+rebind(j,k,g,G,q,space,n,r,x)\" || echo \"abort\"' \
      --bind 'ctrl-k:kill-line,ctrl-w:unix-line-discard' \
      --bind 'x:execute(~/.tmux/scripts/kill-session.sh \$(echo {} | cut -d\" \" -f1))+reload-sync(~/.tmux/scripts/list-sessions.sh)' \
      --bind 'u:execute(~/.tmux/scripts/undo-session.sh --quick)+reload-sync(~/.tmux/scripts/list-sessions.sh)' \
      --bind 'n:become(~/.tmux/scripts/new-session.sh)' \
      --bind 'r:become(~/.tmux/scripts/rename-session.sh \$(echo {} | cut -d\" \" -f1))' | \
  cut -d' ' -f1 | xargs -r tmux switch-client -t"
bind S display-popup -E -w 60 -h 20 "~/.tmux/scripts/restore-resurrect.sh --list; echo ''; read -n1 -p 'Press any key...'"
bind R command-prompt -p "Restore session:" "run-shell '~/.tmux/scripts/restore-resurrect.sh %%'"
# prefix + S = list saved session backups (popup)
# prefix + R = restore specific session (prompts for name)

# ─────────────────────────────────────────
# Auto-cleanup on session close
# ─────────────────────────────────────────
# When a session is killed, trigger a save to update backups
# This removes the killed session from tls listings
# Note: kill-session.sh already handles saves, but this catches edge cases
set-hook -g session-closed 'run-shell -b "~/.tmux/plugins/tmux-resurrect/scripts/save.sh >/dev/null 2>&1 && ~/.tmux/scripts/split-resurrect.sh >/dev/null 2>&1"'

# ─────────────────────────────────────────
# Window access tracking
# ─────────────────────────────────────────
# Update @last-viewed timestamp when switching windows for fuzzy finder sorting
# Also clear any claude alert on the window (backup to UserPromptSubmit hook)
set-hook -g after-select-window 'run-shell -b "~/.tmux/scripts/update-timestamp.sh #{window_id}; ~/.tmux/scripts/clear-agent-alerts.sh \"#{session_name}\" \"#{window_name}\" \"#{window_id}\""'

# Update alerts when window is renamed to prevent stale alerts
set-hook -g after-rename-window 'run-shell "~/.tmux/scripts/update-rename-alert.sh \"#{session_name}\" \"#{window_name_old}\" \"#{window_name}\""'
set-hook -g client-session-changed 'run-shell -b "~/.tmux/scripts/update-timestamp.sh #{window_id}"'

# ══════════════════════════════════════════════════════════════
# Plugin Manager Initialisation (must be at bottom)
# ══════════════════════════════════════════════════════════════
run '~/.tmux/plugins/tpm/tpm'

# Override tmux-yank's Y binding with our custom one (must be after plugin load)
bind -T copy-mode-vi Y send-keys -X select-line \; send-keys -X copy-pipe-and-cancel "pbcopy"
