# Ghostty Configuration File
# Theme: Nord

# Fonts
font-size = 13

# Window
window-padding-x = 0
window-padding-y = 0
window-width = 140
window-height = 38
window-position-x = 226
window-position-y = 115
background-opacity = 1
unfocused-split-opacity = 1
resize-overlay = never

# Cursor
cursor-style = block
cursor-style-blink = true

# Shell Integration
shell-integration = zsh
shell-integration-features = no-cursor,title

# Mouse
mouse-hide-while-typing = true

# Bell - allow terminal bells through for tmux monitor-bell
bell-features = title,attention

# Colors
background = #2e3440
foreground = #eceff4
cursor-color = #eceff4
cursor-text = #2e3440
selection-background = #434c5e
selection-foreground = #eceff4
palette = 0=#3b4252
palette = 1=#bf616a
palette = 2=#a3be8c
palette = 3=#ebcb8b
palette = 4=#81a1c1
palette = 5=#b48ead
palette = 6=#88c0d0
palette = 7=#e5e9f0
palette = 8=#4c566a
palette = 9=#bf616a
palette = 10=#a3be8c
palette = 11=#ebcb8b
palette = 12=#81a1c1
palette = 13=#b48ead
palette = 14=#8fbcbb
palette = 15=#eceff4

# Macos
macos-icon = glass
macos-icon-frame = chrome
macos-option-as-alt = left

keybind = shift+enter=text:\x1b\r
keybind = opt+c=text:\x1bc
keybind = opt+up=text:\x1b[A
keybind = opt+down=text:\x1b[B
keybind = opt+3=text:#
