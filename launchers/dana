#!/usr/bin/env bash
set -euo pipefail

# Dana project launcher - creates a multi-window tmux session

# Help flag handling
if [[ "${1:-}" == "--help" ]] || [[ "${1:-}" == "-h" ]]; then
    cat << 'EOF'
dana - Dana project tmux session launcher

USAGE:
    dana

DESCRIPTION:
    Creates or attaches to the 'dana' tmux session with a pre-configured
    multi-window layout for the Dana project located at ~/src/dana.

WINDOWS:
    1. backend           Backend development (~/src/dana/backend)
    2. web               Web frontend (~/src/dana/web)
    3. mobile            Mobile app (~/src/dana/mobile)
    4. tools             Split panes running development servers:
                         • Left pane: bun dev (web dev server)
                         • Right pane: npx expo (mobile dev server)
    5. commit-and-push   Git operations (~/src/dana)
    6. zsh               General shell (~)

OPTIONS:
    -h, --help   Show this help message

EXAMPLES:
    # Launch or attach to dana session
    dana

NOTES:
    • Requires ~/src/dana directory to exist
    • If session 'dana' exists, attaches instead of creating
    • Development servers auto-start in window 4 (tools)
    • Works both inside and outside of tmux

SEE ALSO:
    tnew           Generic development session launcher
    tattach        Smart attach to session (restores from backup if needed)
    trestore       Restore tmux sessions from backup
EOF
    exit 0
fi

SESSION="dana"
PROJECT_DIR="$HOME/src/dana"

# Validate project directory exists
if [[ ! -d "$PROJECT_DIR" ]]; then
    echo "Error: Project directory not found: $PROJECT_DIR" >&2
    exit 1
fi

# Check if session already exists
if tmux has-session -t "$SESSION" 2>/dev/null; then
    # Attach to existing session
    if [[ -n "${TMUX:-}" ]]; then
        tmux switch-client -t "$SESSION"
    else
        tmux attach-session -t "$SESSION"
    fi
    exit 0
fi

# Create new session with backend window
tmux new-session -d -s "$SESSION" -n backend -c "$PROJECT_DIR/backend"

# Window 2: web
tmux new-window -t "$SESSION" -n web -c "$PROJECT_DIR/web"

# Window 3: mobile
tmux new-window -t "$SESSION" -n mobile -c "$PROJECT_DIR/mobile"

# Window 4: tools (split panes)
tmux new-window -t "$SESSION" -n tools -c "$PROJECT_DIR/web"
tmux split-window -h -t "$SESSION:tools" -c "$PROJECT_DIR/mobile"

# Run dev servers in tools panes
tmux send-keys -t "$SESSION:tools.1" 'bun dev' C-m
tmux send-keys -t "$SESSION:tools.2" 'npx expo' C-m

# Window 5: commit-and-push
tmux new-window -t "$SESSION" -n commit-and-push -c "$PROJECT_DIR"

# Window 6: zsh
tmux new-window -t "$SESSION" -n zsh -c ~

# Select first window
tmux select-window -t "$SESSION:1"

# Attach to session
if [[ -n "${TMUX:-}" ]]; then
    tmux switch-client -t "$SESSION"
else
    tmux attach-session -t "$SESSION"
fi
