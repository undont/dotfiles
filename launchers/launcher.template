#!/usr/bin/env bash
set -euo pipefail

# =============================================================================
# PROJECT LAUNCHER TEMPLATE
# =============================================================================
# copy this file and customise for your project:
#   cp launcher.template myproject
#   chmod +x myproject
#
# add your project root to ~/.zshrc:
#   export MYPROJECT_ROOT="$HOME/src/myproject"
# =============================================================================

# =============================================================================
# CONFIGURATION - customise these for your project
# =============================================================================
# @description: My project - brief description of windows/layout
#
# the @description tag is required for the launcher picker (prefix + p).
# it appears as a one-line summary next to the launcher name in the picker.
# launchers without this tag are hidden from the picker.
#
# optional: @instance tag controls how new instances are created (press n):
#   # @instance: prompt    - asks for a name (e.g. ticket number → myproject-1234)
#   # @instance: auto      - auto-increments (myproject-2, myproject-3) [default]

SESSION="${SESSION_NAME:-myproject}"              # tmux session name (SESSION_NAME allows multi-instance)
PROJECT_DIR="${MYPROJECT_ROOT:-$HOME/src/myproject}"  # from local aliases or fallback

# help flag handling
if [[ "${1:-}" == "--help" ]] || [[ "${1:-}" == "-h" ]]; then
    cat << EOF
$SESSION - Project tmux session launcher

USAGE:
    $SESSION

DESCRIPTION:
    Creates or attaches to the '$SESSION' tmux session with a pre-configured
    multi-window layout.

WINDOWS:
    1. dev     Development (split: Claude left, terminal right)
    2. edit    Neovim editor
    3. shell   General terminal

OPTIONS:
    -h, --help   Show this help message

NOTES:
    • Reads ${SESSION^^}_ROOT from ~/.zshrc exports
    • Falls back to $PROJECT_DIR if not defined
    • If session exists, attaches instead of creating
EOF
    exit 0
fi

# =============================================================================
# VALIDATION
# =============================================================================

if [[ ! -d "$PROJECT_DIR" ]]; then
    echo "Error: Project directory not found: $PROJECT_DIR" >&2
    echo "Define ${SESSION^^}_ROOT in ~/.zshrc or create the directory." >&2
    exit 1
fi

# =============================================================================
# SESSION MANAGEMENT
# =============================================================================

# check if session already exists
if tmux has-session -t "$SESSION" 2>/dev/null; then
    if [[ -n "${TMUX:-}" ]]; then
        tmux switch-client -t "$SESSION"
    else
        tmux attach-session -t "$SESSION"
    fi
    exit 0
fi

# =============================================================================
# WINDOW LAYOUT - customise this section for your workflow
# =============================================================================

# window 1: dev (split panes - Claude left, terminal right)
tmux new-session -d -s "$SESSION" -n dev -c "$PROJECT_DIR"
tmux split-window -t "$SESSION:dev" -h -c "$PROJECT_DIR"
tmux send-keys -t "$SESSION:dev.1" 'claude' Enter

# window 2: edit (nvim)
tmux new-window -t "$SESSION" -n edit -c "$PROJECT_DIR"
tmux send-keys -t "$SESSION:edit" 'nvim' Enter

# window 3: shell (general terminal)
tmux new-window -t "$SESSION" -n shell -c "$PROJECT_DIR"

# =============================================================================
# EXAMPLES OF OTHER WINDOW CONFIGURATIONS
# =============================================================================
#
# # subdirectory window:
# tmux new-window -t "$SESSION" -n backend -c "$PROJECT_DIR/backend"
#
# # split pane running commands:
# tmux new-window -t "$SESSION" -n servers -c "$PROJECT_DIR"
# tmux split-window -h -t "$SESSION:servers" -c "$PROJECT_DIR"
# tmux send-keys -t "$SESSION:servers.1" 'npm run dev' Enter
# tmux send-keys -t "$SESSION:servers.2" 'npm run watch' Enter
#
# # window at home directory:
# tmux new-window -t "$SESSION" -n misc -c ~

# =============================================================================
# EXAMPLES OF INSTANCE CUSTOMISATION
# =============================================================================
#
# # git worktree matching (with @instance: prompt)
# # when the user types a ticket number (e.g. 1234), match it to a worktree
# # directory like ~/src/myproject-worktrees/PROJ-1234-Some-Description/
# #
# # WORKTREES_DIR="${MYPROJECT_WORKTREES:-$HOME/src/myproject-worktrees}"
# # if [[ "$SESSION" =~ ^myproject-(.+)$ ]]; then
# #     suffix="${BASH_REMATCH[1]}"
# #     worktree_match=$(find "$WORKTREES_DIR" -maxdepth 1 -type d -name "PROJ-${suffix}-*" 2>/dev/null | head -1)
# #     if [[ -n "$worktree_match" ]]; then
# #         PROJECT_DIR="$worktree_match"
# #     fi
# # fi
# #
# # place this between the SESSION/PROJECT_DIR lines and the validation block

# =============================================================================
# ATTACH TO SESSION
# =============================================================================

# select first window
tmux select-window -t "$SESSION:1"
tmux select-pane -t "$SESSION:1.1"

# attach to session
if [[ -n "${TMUX:-}" ]]; then
    tmux switch-client -t "$SESSION"
else
    tmux attach-session -t "$SESSION"
fi
