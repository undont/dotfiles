#!/usr/bin/env bash
set -euo pipefail

# @description: Dev session - Claude + Neovim
# Dev session launcher - creates a 3-window layout for development
# Invoked via the launcher picker (prefix + p) with a directory argument.

# Help flag handling
if [[ "${1:-}" == "--help" ]] || [[ "${1:-}" == "-h" ]]; then
    cat << 'EOF'
dev - tmux development session launcher

USAGE:
    dev <DIRECTORY>

DESCRIPTION:
    Creates or attaches to a tmux development session with a 3-window layout:
      • Window 1 (zsh): Terminal
      • Window 2 (nvim): Neovim editor
      • Window 3 (code): Claude Code

    The session name is derived from the directory basename.
    Use the launcher picker (prefix + p) to select a directory.

ARGUMENTS:
    DIRECTORY    Directory to create session in (required)

OPTIONS:
    -h, --help   Show this help message

NOTES:
    • If a session with the same name exists, attaches to it instead
    • Session names are sanitised (alphanumeric, underscore, dash only)
    • Works both inside and outside of tmux (uses switch-client vs attach-session)
    • Claude Code is launched via the 'claude' CLI command
EOF
    exit 0
fi

# Resolve script location (follow symlinks) to find shared libraries
_source="${BASH_SOURCE[0]}"
while [[ -L "$_source" ]]; do _source=$(readlink "$_source"); done
_script_dir="$(cd "$(dirname "$_source")" && pwd)"
# shellcheck source=tmux/scripts/_lib/common.sh
source "$_script_dir/../tmux/scripts/_lib/common.sh"
# shellcheck source=tmux/scripts/_lib/ui.sh
source "$_script_dir/../tmux/scripts/_lib/ui.sh"

dir="${1:-}"
if [[ -z "$dir" ]]; then
    echo "Usage: dev <DIRECTORY>" >&2
    echo "Use the launcher picker (prefix + p) to select a directory." >&2
    exit 1
fi

# Expand ~ to $HOME
dir="${dir/#\~/$HOME}"

# If directory doesn't exist, offer to create it
if [[ ! -d "$dir" ]]; then
    if ! show_visual_confirm "Create directory?" "$dir"; then
        exit 1
    fi
    mkdir -p "$dir"
fi

# Resolve to absolute path
dir=$(cd "$dir" && pwd)

# Use SESSION_NAME if provided (e.g. from collision handler), otherwise derive from directory basename
# Suffixed with -dev to avoid collisions with fixed-session launchers (e.g. jiru vs jiru-dev)
# Dots are replaced because tmux uses '.' as a separator in target syntax (session:window.pane)
session="${SESSION_NAME:-$(basename "$dir" | tr -c '[:alnum:]_\-\n' '-' | sed 's/-*$//')-dev}"

# Check if session already exists
if tmux has-session -t "$session" 2>/dev/null; then
    if [[ -n "${TMUX:-}" ]]; then
        tmux switch-client -t "$session"
    else
        tmux attach-session -t "$session"
    fi
    exit 0
fi

# Window 1: zsh
tmux new-session -d -s "$session" -n "zsh" -c "$dir"

# Window 2: nvim
tmux new-window -t "$session" -n "nvim" -c "$dir"
tmux send-keys -t "$session:nvim" 'nvim' Enter

# Window 3: code
tmux new-window -t "$session" -n "code" -c "$dir"
tmux send-keys -t "$session:code" 'claude' Enter

# Select first window
tmux select-window -t "$session:1"
tmux select-pane -t "$session:1.1"

# Attach to session
if [[ -n "${TMUX:-}" ]]; then
    tmux switch-client -t "$session"
else
    tmux attach-session -t "$session"
fi
