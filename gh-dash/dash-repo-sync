#!/usr/bin/env bash
# Discover local GitHub repos and sync repoPaths into gh-dash config.
# Scans DEV_ROOT and PROJECTS_ROOT for git repos with GitHub remotes.
#
# Usage: dash-repo-sync [--dry-run]

set -euo pipefail

# Resolve script location (follow symlinks) to find shared libraries
_source="${BASH_SOURCE[0]}"
while [[ -L "$_source" ]]; do _source=$(readlink "$_source"); done
_script_dir="$(cd "$(dirname "$_source")" && pwd)"
# shellcheck source=scripts/_lib/ghdash.sh
source "$_script_dir/../scripts/_lib/ghdash.sh"

if [[ ! -f "$GHDASH_LOCAL" ]]; then
    echo "gh-dash local.yml not found: $GHDASH_LOCAL" >&2
    echo "Run: dotfiles update (or install.sh) to create it from template" >&2
    exit 1
fi

if ! command -v yq >/dev/null 2>&1; then
    echo "yq is required (brew install yq)" >&2
    exit 1
fi

dry_run=false
[[ "${1:-}" == "--dry-run" ]] && dry_run=true

# Collect roots to scan
roots=()
[[ -n "${DEV_ROOT:-}" && -d "${DEV_ROOT:-}" ]] && roots+=("$DEV_ROOT")
[[ -n "${PROJECTS_ROOT:-}" && -d "${PROJECTS_ROOT:-}" ]] && roots+=("$PROJECTS_ROOT")

if (( ${#roots[@]} == 0 )); then
    echo "No project roots configured." >&2
    echo "Set DEV_ROOT and/or PROJECTS_ROOT:" >&2
    echo "  dotfiles set dev ~/src" >&2
    echo "  dotfiles set projects ~/playground" >&2
    exit 1
fi

# ─── Discover repos (first root wins on duplicates) ──────────────────────────
seen=""
count=0
yq_expr='.'

for root in "${roots[@]}"; do
    for dir in "$root"/*/; do
        [[ -d "$dir/.git" ]] || continue
        remote=$(git -C "$dir" remote get-url origin 2>/dev/null) || continue
        owner_repo=$(echo "$remote" | sed -E 's|.*github\.com[:/]||; s|\.git$||')
        [[ "$owner_repo" == */* ]] || continue

        # Deduplicate
        case "$seen" in
            *"|$owner_repo|"*) continue ;;
        esac
        seen="${seen}|${owner_repo}|"

        display="${dir%/}"
        display="${display#"$HOME"}"
        display="~${display}"
        yq_expr="${yq_expr} | .repoPaths.\"${owner_repo}\" = \"${display}\""
        count=$(( count + 1 ))
    done
done

# ─── Detect stale entries ────────────────────────────────────────────────────
# Entries not in the discovered set whose local path no longer exists on disk.
# Wildcard entries (org/*: ~/code/*) are always preserved — they're manual.
stale_del=""
stale_count=0
stale_names=""
while IFS=$'\t' read -r key value; do
    [[ -z "$key" ]] && continue
    # Skip if just discovered
    case "$seen" in *"|$key|"*) continue ;; esac
    # Skip wildcard/glob entries (manual)
    [[ "$value" == *'*'* ]] && continue
    # Keep if path still exists on disk (valid manual entry)
    expanded="${value/#\~/$HOME}"
    [[ -d "$expanded" ]] && continue
    # Stale — queue for removal
    stale_del="${stale_del} | del(.repoPaths.\"${key}\")"
    stale_count=$(( stale_count + 1 ))
    stale_names="${stale_names}  - ${key} (${value})\n"
done < <(yq -r '.repoPaths // {} | to_entries[] | [.key, .value] | @tsv' "$GHDASH_LOCAL" 2>/dev/null)

# ─── Nothing to do? ─────────────────────────────────────────────────────────
if (( count == 0 && stale_count == 0 )); then
    echo "No changes (0 discovered, 0 stale)"
    exit 0
fi

# ─── Dry-run report ─────────────────────────────────────────────────────────
if [[ "$dry_run" == "true" ]]; then
    echo "Would sync repo paths: $count discovered, $stale_count to remove"
    if (( stale_count > 0 )); then
        printf "Stale:\n%b" "$stale_names"
    fi
    if (( count > 0 )); then
        echo "Discovered:"
        yq eval "$yq_expr" /dev/null | sed '1d' | sed 's/^/  /'
    fi
    exit 0
fi

# ─── Apply changes ──────────────────────────────────────────────────────────
# Remove stale entries first
if (( stale_count > 0 )); then
    stale_del="${stale_del# | }"
    if ! yq eval -i "$stale_del" "$GHDASH_LOCAL" 2>/dev/null; then
        echo "Failed to remove stale entries" >&2
        exit 1
    fi
fi

# Add/update discovered repos
if (( count > 0 )); then
    if ! yq eval -i "$yq_expr" "$GHDASH_LOCAL" 2>/dev/null; then
        echo "yq update failed" >&2
        exit 1
    fi
fi

echo "Synced repo paths: $count discovered, $stale_count removed"

# Merge local overrides into the active config so gh-dash picks them up immediately
ghdash_merge_local
