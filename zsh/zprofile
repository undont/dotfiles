# =============================================================================
# ZSH PROFILE (Login Shell Configuration)
# =============================================================================
# This file is sourced for LOGIN shells only (e.g., when opening a new
# terminal window or SSH session). Use this for:
#   - PATH additions that installers add automatically
#   - Environment setup that only needs to run once per session
#
# For interactive shell config (aliases, functions, prompt), use ~/.zshrc
#
# Load order: .zshenv → .zprofile (login) → .zshrc (interactive) → .zlogin
#
# Conventions:
#   - This file is for PATH entries added by third-party installers (per machine).
#   - PATH entries the dotfiles framework owns live in zsh/dotfiles.zsh.
#   - Don't duplicate framework entries here; typeset -U below dedupes anyway.

# Keep $path (and therefore $PATH) deduplicated across all later additions,
# including any made by the framework in zsh/dotfiles.zsh.
typeset -U path PATH

# Homebrew environment (PATH, MANPATH, INFOPATH, FPATH for completions)
# Sets HOMEBREW_PREFIX and adds site-functions to fpath (needed by compinit).
if [[ -f /opt/homebrew/bin/brew ]]; then
  eval "$(/opt/homebrew/bin/brew shellenv)"
elif [[ -f /usr/local/bin/brew ]]; then
  eval "$(/usr/local/bin/brew shellenv)"
elif [[ -f /home/linuxbrew/.linuxbrew/bin/brew ]]; then
  eval "$(/home/linuxbrew/.linuxbrew/bin/brew shellenv)"
fi

# Bun global packages (bun install -g)
export PATH="$HOME/.bun/bin:$PATH"

# User-local binaries (~/.local/bin) — common install target for pipx,
# `cargo install`, Antigravity CLI, etc.
export PATH="$HOME/.local/bin:$PATH"

# over ssh, terminal emulators don't forward COLORTERM, so remote TUIs (claude
# code, etc.) see only TERM=*-256color and downsample 24-bit brand colours to
# the 256 palette. we always drive from a truecolor terminal (ghostty+tmux), so
# assert it when it's missing inside an ssh session.
if [[ -z "${COLORTERM:-}" && -n "${SSH_CONNECTION:-}" ]]; then
  export COLORTERM=truecolor
fi
