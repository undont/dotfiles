  dotfiles version [OPTIONS]
  dotfiles -v
  dotfiles --version

OPTIONS
  -h, --help     Show this help

EXAMPLES
  dotfiles version
EOF
}

_help_main() {
    print_logo
    cat << 'EOF'
dotfiles — manage your dotfiles installation

USAGE
  dotfiles <command> [options]    (shorthand: dot)
  dotfiles help <command>         Show detailed help for a command

COMMANDS
  update    -u    Pull latest and apply (incremental)
  status    -s    Version, sync status, local changes
  health          Run full health check
  set             Configure DEV_ROOT / PROJECTS_ROOT
  theme     -t    Manage colour themes
  links     -l    Show managed symlinks
  diff      -d    Show copy-on-install file diffs
  sync            Sync copy-on-install files from repo
  aliases   -a    Show shell aliases and shortcuts
  notes     -n    Browse changelog in pager
  version   -v    Show version, preset, theme
  edit      -e    Open dotfiles in $EDITOR
  cd              Print dotfiles path

For details on any command:
  dotfiles help <command>
  dotfiles <command> --help
EOF
}

# ─── Dispatcher ───────────────────────────────────────────────────────

main() {
    local cmd="${1:-help}"
    shift || true

    # Top-level shorthands
    case "$cmd" in
        --help|-h)    cmd=help ;;
        --version|-V) cmd=version ;;
    esac

    case "$cmd" in
        update|-u)              cmd_update    "$@" ;;
        status|-s)              cmd_status    "$@" ;;
        health)                 cmd_health    "$@" ;;
        set)                    cmd_set       "$@" ;;
        theme|-t)               cmd_theme     "$@" ;;
        links|-l)               cmd_links     "$@" ;;
        diff|-d)                cmd_diff      "$@" ;;
        sync)                   cmd_sync      "$@" ;;
        aliases|alias|cheat|-a) cmd_aliases   "$@" ;;
        notes|-n)               cmd_notes     "$@" ;;
        version|-v)             cmd_version   "$@" ;;
        edit|-e)                cmd_edit      "$@" ;;
        cd)                     cmd_cd        "$@" ;;
        help)                   cmd_help      "$@" ;;
        *)
            error "Unknown command: $cmd"
            echo ""
            _help_main
            exit 1
            ;;
    esac
}

main "$@"
