#!/usr/bin/env bash
# Dotfiles CLI - manage your dotfiles installation
# Usage: dotfiles <command> [options]
#
# Commands:
#   update  -u    Pull latest changes and apply (smart update)
#   status  -s    Show version, sync status, and local changes
#   health        Run full health check
#   set           Configure project directories (DEV_ROOT, PROJECTS_ROOT)
#   theme   -t    Manage colour themes
#   links   -l    Show all managed symlinks and their status
#   diff    -d    Show changes in copy-on-install files vs repo
#   sync          Copy repo versions of copy-on-install files to their destinations
#   aliases -a    Show all shell aliases, functions, and utilities
#   notes   -n    Browse the full changelog in a pager
#   version -v    Show current dotfiles version, preset, and theme
#   edit    -e    Open dotfiles directory in $EDITOR
#   cd            Print dotfiles path (use: cd "$(dotfiles cd)")
#   help          Show this help message

set -euo pipefail

# Detect script location to find DOTFILES_DIR
SCRIPT_PATH="${BASH_SOURCE[0]}"
# Resolve symlinks to find the real script location
while [[ -L "$SCRIPT_PATH" ]]; do
    SCRIPT_DIR="$(cd -P "$(dirname "$SCRIPT_PATH")" && pwd)"
    SCRIPT_PATH="$(readlink "$SCRIPT_PATH")"
    [[ "$SCRIPT_PATH" != /* ]] && SCRIPT_PATH="$SCRIPT_DIR/$SCRIPT_PATH"
done
SCRIPT_DIR="$(cd -P "$(dirname "$SCRIPT_PATH")" && pwd)"

# DOTFILES_DIR is parent of scripts/
DOTFILES_DIR="${DOTFILES_DIR:-$(dirname "$SCRIPT_DIR")}"
CONFIG_DIR="${XDG_CONFIG_HOME:-$HOME/.config}/dotfiles"
PRESET_FILE="$CONFIG_DIR/preset"

# Source common utilities
# shellcheck disable=SC1091
source "$DOTFILES_DIR/scripts/_lib/common.sh"

# Get the saved preset or default to full
get_preset() {
    if [[ -f "$PRESET_FILE" ]]; then
        cat "$PRESET_FILE"
    else
        echo "full"
    fi
}

# ─────────────────────────────────────────
# Changelog helpers
# ─────────────────────────────────────────

# Get the latest non-Unreleased version from the local changelog
_changelog_local_version() {
    sed -n 's/^## \[\([0-9][^]]*\)\].*/\1/p' "$DOTFILES_DIR/CHANGELOG.md" | head -1
}

# Get the latest non-Unreleased version from CHANGELOG.md at a given git ref
_changelog_version_at_ref() {
    local ref="$1"
    git show "$ref:CHANGELOG.md" 2>/dev/null | sed -n 's/^## \[\([0-9][^]]*\)\].*/\1/p' | head -1
}

# Show changelog entries from the remote that are newer than the local version
# Outputs nothing if no new entries exist
_changelog_incoming() {
    local remote_branch="$1"
    local local_version

    local_version=$(_changelog_local_version) || return 1
    [[ -z "$local_version" ]] && return 1

    local remote_changelog
    remote_changelog=$(git show "$remote_branch:CHANGELOG.md" 2>/dev/null) || return 1

    # Extract entries newer than local version (skip [Unreleased], stop at local version)
    printf '%s\n' "$remote_changelog" | awk -v ver="$local_version" '
        /^## \[Unreleased\]/ { next }
        /^## \[/ {
            if (index($0, "[" ver "]")) exit
            found = 1
        }
        found { print }
    '
}

# Colorise changelog markdown for terminal display
_changelog_colorise() {
    local cyan=$'\033[0;36m' green=$'\033[0;32m' magenta=$'\033[0;35m' bold_magenta=$'\033[1;35m'
    local yellow=$'\033[0;33m' red=$'\033[0;31m' grey=$'\033[0;90m' nc=$'\033[0m'
    sed \
        -e "s|^\(## \[.*\]\) ★ current\(.*\)|${magenta}\1 ${bold_magenta}★ current${magenta}\2${nc}|" \
        -e "s|^## \[.*|${cyan}&${nc}|" \
        -e "s|^### Added.*|${green}&${nc}|" \
        -e "s|^### Changed.*|${yellow}&${nc}|" \
        -e "s|^### Fixed.*|${yellow}&${nc}|" \
        -e "s|^### Removed.*|${red}&${nc}|" \
        -e "s|^- |  ${grey}•${nc} |"
}

# Get the default remote branch
get_remote_branch() {
    cd "$DOTFILES_DIR"
    local ref
    ref=$(git symbolic-ref refs/remotes/origin/HEAD 2>/dev/null) || {
        # Fallback: try common names
        if git rev-parse --verify origin/main &>/dev/null; then
            echo "origin/main"
        elif git rev-parse --verify origin/master &>/dev/null; then
            echo "origin/master"
        else
            echo "origin/main"  # Default guess
        fi
        return
    }
    echo "${ref#refs/remotes/}"
}

# ─────────────────────────────────────────
# Update helpers
# ─────────────────────────────────────────

# Compute which installer steps can be skipped based on changed files between two refs.
# Returns a comma-separated list of step names (homebrew,packages,symlinks,keyd).
_compute_skip_steps() {
    local ref_from="$1" ref_to="$2"
    local changed_files
    changed_files=$(git diff --name-only "$ref_from" "$ref_to" 2>/dev/null) || return 0

    local skippable=()

    # Brewfile not changed → skip homebrew + packages
    if ! printf '%s\n' "$changed_files" | grep -q '^Brewfile'; then
        skippable+=(homebrew packages)
    fi

    # No config/symlink-related files changed → skip symlinks
    local symlink_patterns='^scripts/install/create-symlinks\.sh|\.template$|^zsh/|^tmux/|^nvim/|^ghostty/|^hammerspoon/|^karabiner/|^launchers/|^lazygit/|^lazydocker/|^formatters/|^gh-dash/|^btop/|^themes/|^keyd/'
    if ! printf '%s\n' "$changed_files" | grep -qE "$symlink_patterns"; then
        skippable+=(symlinks)
    fi

    # keyd/ not changed → skip keyd (Linux only; macOS uses Karabiner)
    if is_linux && ! printf '%s\n' "$changed_files" | grep -q '^keyd/'; then
        skippable+=(keyd)
    fi

    local IFS=','
    printf '%s' "${skippable[*]}"
}

# Show changed files grouped by category for dry-run preview
_preview_changed_files() {
    local ref_from="$1" ref_to="$2"
    local changed_files
    changed_files=$(git diff --name-only "$ref_from" "$ref_to" 2>/dev/null) || return 0

    [[ -z "$changed_files" ]] && return 0

    local -A categories=(
        [Brewfile/packages]="^Brewfile"
        [Zsh config]="^zsh/"
        [Tmux config]="^tmux/"
        [Neovim config]="^nvim/"
        [Ghostty config]="^ghostty/"
        [Theme definitions]="^themes/"
        [Installer/scripts]="^scripts/|^install\.sh"
        [Launchers]="^launchers/"
        [Hammerspoon]="^hammerspoon/"
        [Karabiner]="^karabiner/"
        [Keyd]="^keyd/"
        [LazyGit]="^lazygit/"
        [Documentation]="^docs/|^README|^CLAUDE|^CHANGELOG"
    )

    # Ordered display
    local -a order=(
        "Brewfile/packages" "Zsh config" "Tmux config" "Neovim config"
        "Ghostty config" "Theme definitions" "Launchers" "Hammerspoon"
        "Karabiner" "Keyd" "LazyGit" "Installer/scripts" "Documentation"
    )

    local shown_files=""
    for cat_name in "${order[@]}"; do
        local pattern="${categories[$cat_name]}"
        local matches
        matches=$(printf '%s\n' "$changed_files" | grep -E "$pattern" || true)
        if [[ -n "$matches" ]]; then
            printf "  ${CYAN}%s:${NC}\n" "$cat_name"
            printf '%s\n' "$matches" | sed 's/^/    /'
            shown_files+="$matches"$'\n'
        fi
    done

    # Show any uncategorised files
    local other
    other=$(printf '%s\n' "$changed_files" | grep -vE "$(IFS='|'; printf '%s' "${categories[*]}")" || true)
    if [[ -n "$other" ]]; then
        printf "  ${CYAN}Other:${NC}\n"
        printf '%s\n' "$other" | sed 's/^/    /'
    fi
}

# Show which update steps would run vs be skipped
_show_step_plan() {
    local skipped="$1"
    # Only skippable steps are listed. Omitted steps always run:
    #   4 (backup) — controlled by --skip-backup, not --skip-steps
    #   9 (secrets), 11 (save preset), 12 (project dirs) — always run, non-skippable
    local -a all_steps=(
        "1:homebrew:Check Homebrew"
        "2:packages:Update packages"
        "3:prerequisites:Check prerequisites"
        "5:symlinks:Update symlinks"
        "6:plugins:Check plugin managers"
        "7:keyd:Update keyd config"
        "8:shell:Check default shell"
        "10:health:Run health check"
    )

    for step_info in "${all_steps[@]}"; do
        local num="${step_info%%:*}"
        local rest="${step_info#*:}"
        local name="${rest%%:*}"
        local label="${rest#*:}"

        if [[ ",$skipped," == *",$name,"* ]]; then
            printf "    ${GREY}%2s. %s (unchanged — skip)${NC}\n" "$num" "$label"
        else
            printf "    ${GREEN}%2s. %s${NC}\n" "$num" "$label"
        fi
    done
}

# ─────────────────────────────────────────
# Version comparison helpers (for migrations)
# ─────────────────────────────────────────

# Returns 0 if $1 > $2 (version comparison)
_version_gt() {
    [[ "$1" != "$2" ]] && [[ "$(printf '%s\n%s' "$1" "$2" | sort -V | head -1)" == "$2" ]]
}

# Run pending migration scripts between two versions
_run_pending_migrations() {
    local old_head="$1" new_head="$2"
    local migrations_dir="$DOTFILES_DIR/scripts/migrations"
    local state_dir="$CONFIG_DIR/.state"
    local applied_file="$state_dir/migrations"

    # Directory is guaranteed to exist post-pull by scripts/migrations/.gitkeep
    [[ -d "$migrations_dir" ]] || return 0

    # Get versions at old and new HEAD
    local old_version new_version
    old_version=$(_changelog_version_at_ref "$old_head") || {
        # Fresh clone or detached HEAD — no changelog at this ref is expected
        if git rev-parse --verify "$old_head" &>/dev/null; then
            warn "Could not extract version from CHANGELOG.md at $old_head — skipping migrations"
        fi
        return 0
    }
    new_version=$(_changelog_version_at_ref "$new_head") || {
        if git rev-parse --verify "$new_head" &>/dev/null; then
            warn "Could not extract version from CHANGELOG.md at $new_head — skipping migrations"
        fi
        return 0
    }

    [[ -z "$old_version" || -z "$new_version" ]] && return 0

    mkdir -p "$state_dir"
    touch "$applied_file"

    local found_any=false
    local migration
    for migration in "$migrations_dir"/*.sh; do
        [[ -f "$migration" ]] || continue
        local basename="${migration##*/}"
        local migration_version="${basename%%-*}"

        # Skip if already applied
        grep -qxF "$basename" "$applied_file" && continue

        # Skip if version is not in range (old_version, new_version]
        if ! _version_gt "$migration_version" "$old_version"; then
            continue
        fi
        if _version_gt "$migration_version" "$new_version"; then
            continue
        fi

        if [[ "$found_any" == false ]]; then
            printf "  ${CYAN}→${NC} Running migrations...\n"
            found_any=true
        fi

        printf "    ${CYAN}•${NC} %s\n" "$basename"
        if bash "$migration"; then
            echo "$basename" >> "$applied_file"
        else
            warn "Migration $basename failed (continuing)"
        fi
    done
}

# Show pending migrations for dry-run preview
_show_pending_migrations() {
    local ref_from="$1" ref_to="$2"
    local migrations_dir="$DOTFILES_DIR/scripts/migrations"
    local state_dir="$CONFIG_DIR/.state"
    local applied_file="$state_dir/migrations"

    [[ -d "$migrations_dir" ]] || return 0

    local old_version new_version
    old_version=$(_changelog_version_at_ref "$ref_from") || return 0
    new_version=$(_changelog_version_at_ref "$ref_to") || return 0

    [[ -z "$old_version" || -z "$new_version" ]] && return 0

    # Check remote for migration scripts (they may not exist locally yet)
    local remote_migrations
    remote_migrations=$(git ls-tree --name-only "$ref_to" scripts/migrations/ 2>/dev/null | grep '\.sh$' || true)

    [[ -z "$remote_migrations" ]] && return 0

    touch "$applied_file" 2>/dev/null || true

    local pending=()
    while IFS= read -r path; do
        [[ -z "$path" ]] && continue
        local basename="${path##*/}"
        local migration_version="${basename%%-*}"

        grep -qxF "$basename" "$applied_file" 2>/dev/null && continue

        if _version_gt "$migration_version" "$old_version" && ! _version_gt "$migration_version" "$new_version"; then
            pending+=("$basename")
        fi
    done <<< "$remote_migrations"

    if [[ ${#pending[@]} -gt 0 ]]; then
        echo ""
        printf "  ${CYAN}Pending migrations:${NC}\n"
        for m in "${pending[@]}"; do
            printf "    ${CYAN}•${NC} %s\n" "$m"
        done
    fi
}

# ─────────────────────────────────────────
# Update command
# ─────────────────────────────────────────

cmd_update() {
    local force=0 dry_run=0

    while [[ $# -gt 0 ]]; do
        case "$1" in
            --force|-f) force=1; shift ;;
            --preview|-p) dry_run=1; shift ;;
            *)
                error "Unknown option: $1"
                echo "Usage: dotfiles update [--force|-f] [--preview|-p]"
                return 1
                ;;
        esac
    done

    local preset remote_branch local_branch

    cd "$DOTFILES_DIR"

    preset=$(get_preset)
    remote_branch=$(get_remote_branch)
    local_branch=$(git rev-parse --abbrev-ref HEAD)

    print_logo
    print_header "Dotfiles Update"

    printf "${CYAN}Preset:${NC}  %s\n" "$preset"
    printf "${CYAN}Branch:${NC}  %s (tracking %s)\n" "$local_branch" "$remote_branch"
    echo ""

    # Fetch and check status
    printf "  ${CYAN}→${NC} Fetching from origin...\n"
    git fetch origin --quiet

    local behind ahead
    behind=$(git rev-list HEAD.."$remote_branch" --count 2>/dev/null) || behind=0
    ahead=$(git rev-list "$remote_branch"..HEAD --count 2>/dev/null) || ahead=0

    if [[ $behind -eq 0 && $ahead -eq 0 ]]; then
        printf "  ${GREEN}✓${NC} Already up-to-date!\n"
        echo ""
        return 0
    fi

    if [[ $ahead -gt 0 ]]; then
        printf "  ${YELLOW}!${NC} You have %d unpushed commit(s)\n" "$ahead"
    fi

    if [[ $behind -eq 0 ]]; then
        echo ""
        return 0
    fi

    printf "  ${CYAN}→${NC} %d new commit(s) available\n" "$behind"

    # Show incoming changelog entries
    local incoming
    incoming=$(_changelog_incoming "$remote_branch") || true
    if [[ -n "$incoming" ]]; then
        echo ""
        printf "  ${CYAN}What's new:${NC}\n"
        printf '%s\n' "$incoming" | _changelog_colorise | sed 's/^/  /'
    fi

    # ── Dry-run mode: show preview and exit ──
    if [[ $dry_run -eq 1 ]]; then
        echo ""
        printf "  ${CYAN}Changed files:${NC}\n"
        _preview_changed_files HEAD "$remote_branch"

        echo ""
        local would_skip=""
        if [[ $force -eq 0 ]]; then
            would_skip=$(_compute_skip_steps HEAD "$remote_branch")
        fi
        printf "  ${CYAN}Update steps:${NC}\n"
        _show_step_plan "$would_skip"

        _show_pending_migrations HEAD "$remote_branch"

        echo ""
        printf "  ${GREY}Run 'dotfiles update' to apply these changes.${NC}\n"
        echo ""
        return 0
    fi

    # ── Confirm before applying ──
    echo ""
    local response
    read -r -p "  Apply update? [Y/n] " response
    if [[ "$response" =~ ^[Nn]$ ]]; then
        printf "  ${GREY}Update cancelled.${NC}\n"
        return 0
    fi

    # ── Pull changes ──
    echo ""
    local old_head
    old_head=$(git rev-parse HEAD)

    printf "  ${CYAN}→${NC} Pulling changes...\n"
    git pull --ff-only --quiet origin "$local_branch" || {
        error "Pull failed. You may have local changes that conflict."
        echo "Try: cd $DOTFILES_DIR && git status"
        return 1
    }

    local new_head
    new_head=$(git rev-parse HEAD)

    # ── Run migrations ──
    _run_pending_migrations "$old_head" "$new_head"

    # ── Compute skip steps (unless --force) ──
    local skip_steps=""
    if [[ $force -eq 0 ]]; then
        skip_steps=$(_compute_skip_steps "$old_head" "$new_head")
    fi

    if [[ -n "$skip_steps" ]]; then
        printf "  ${GREY}Skipping unchanged: %s${NC}\n" "$skip_steps"
    fi

    echo ""

    # ── Run installer in update mode ──
    local install_args=("--$preset" --skip-backup --update --yes)
    [[ -n "$skip_steps" ]] && install_args+=(--skip-steps "$skip_steps")

    if ! "$DOTFILES_DIR/install.sh" "${install_args[@]}"; then
        error "Update failed — check output above"
        return 1
    fi
}

cmd_status() {
    cd "$DOTFILES_DIR"

    local preset remote_branch behind ahead version

    preset=$(get_preset)
    remote_branch=$(get_remote_branch)
    version=$(_changelog_local_version) || true

    print_logo
    print_header "Dotfiles Status"

    # Summary line: version, preset, theme, branch
    [[ -n "$version" ]] && printf "${CYAN}Version:${NC}   %s\n" "$version"
    printf "${CYAN}Preset:${NC}    %s\n" "$preset"
    local theme_file="${XDG_CONFIG_HOME:-$HOME/.config}/dotfiles/current-theme"
    [[ -f "$theme_file" ]] && printf "${CYAN}Theme:${NC}     %s\n" "$(<"$theme_file")"
    printf "${CYAN}Branch:${NC}    %s\n" "$(git rev-parse --abbrev-ref HEAD)"
    printf "${CYAN}Path:${NC}      %s\n" "$DOTFILES_DIR"
    echo ""

    # Fetch quietly
    git fetch origin --quiet 2>/dev/null || true

    behind=$(git rev-list HEAD.."$remote_branch" --count 2>/dev/null) || behind=0
    ahead=$(git rev-list "$remote_branch"..HEAD --count 2>/dev/null) || ahead=0

    if [[ $behind -eq 0 && $ahead -eq 0 ]]; then
        printf "  ${GREEN}✓${NC} Up-to-date with %s\n" "$remote_branch"
    else
        if [[ $behind -gt 0 ]]; then
            printf "  ${YELLOW}↓${NC} %d commit(s) behind %s\n" "$behind" "$remote_branch"
        fi
        if [[ $ahead -gt 0 ]]; then
            printf "  ${YELLOW}↑${NC} %d commit(s) ahead of %s\n" "$ahead" "$remote_branch"
        fi

        # Show incoming changelog entries
        if [[ $behind -gt 0 ]]; then
            local incoming
            incoming=$(_changelog_incoming "$remote_branch") || true
            if [[ -n "$incoming" ]]; then
                echo ""
                printf "  ${CYAN}Incoming changes:${NC}\n"
                printf '%s\n' "$incoming" | _changelog_colorise | sed 's/^/  /'
                echo ""
                printf "  ${GREY}Run 'dotfiles update' to apply.${NC}\n"
            fi
        fi
    fi

    # Local changes
    if [[ -n $(git status --porcelain 2>/dev/null) ]]; then
        echo ""
        printf "  ${YELLOW}!${NC} Uncommitted local changes:\n"
        git status --short | sed 's/^/    /'
    fi

    echo ""
}

cmd_health() {
    "$DOTFILES_DIR/scripts/install/health-check.sh"
}

cmd_edit() {
    cd "$DOTFILES_DIR"
    ${EDITOR:-vim} .
}

cmd_cd() {
    echo "$DOTFILES_DIR"
}

# ─────────────────────────────────────────
# Release notes
# ─────────────────────────────────────────
cmd_notes() {
    local changelog="$DOTFILES_DIR/CHANGELOG.md"

    if [[ ! -f "$changelog" ]]; then
        error "CHANGELOG.md not found"
        return 1
    fi

    local current_version
    current_version=$(_changelog_local_version) || true

    # Try to show the remote changelog so users can see unreceived changes
    local content=""
    cd "$DOTFILES_DIR"
    git fetch origin --quiet 2>/dev/null || true
    local remote_branch
    remote_branch=$(get_remote_branch)
    content=$(git show "$remote_branch:CHANGELOG.md" 2>/dev/null) || content=""

    # Fall back to local changelog if remote is unavailable
    if [[ -z "$content" ]]; then
        content=$(<"$changelog")
    fi

    # Pre-process: mark the current version line with ★
    if [[ -n "$current_version" ]]; then
        local escaped="${current_version//./\\.}"
        content=$(printf '%s\n' "$content" | sed "s/^## \[${escaped}\]/& ★ current/")
    fi

    # Always use custom coloriser so the ★ current marker gets accent colour
    printf '%s\n' "$content" | _changelog_colorise | less -R
}

cmd_version() {
    local version
    version=$(_changelog_local_version) || true

    if [[ -z "$version" ]]; then
        error "Could not determine version from CHANGELOG.md"
        return 1
    fi

    print_logo

    printf "${CYAN}Version:${NC}  %s\n" "$version"
    printf "${CYAN}Preset:${NC}   %s\n" "$(get_preset)"

    local theme_file="${XDG_CONFIG_HOME:-$HOME/.config}/dotfiles/current-theme"
    if [[ -f "$theme_file" ]]; then
        printf "${CYAN}Theme:${NC}    %s\n" "$(<"$theme_file")"
    fi

    cd "$DOTFILES_DIR"
    printf "${CYAN}Branch:${NC}   %s\n" "$(git rev-parse --abbrev-ref HEAD 2>/dev/null || echo "unknown")"
    printf "${CYAN}Path:${NC}     %s\n" "$DOTFILES_DIR"
    echo ""
}

# ─────────────────────────────────────────
# Theme management
# ─────────────────────────────────────────
cmd_theme() {
    local theme_cmd="${1:-list}"
    shift || true

    case "$theme_cmd" in
        list)
            "$DOTFILES_DIR/scripts/theme-switch" list
            ;;
        current)
            "$DOTFILES_DIR/scripts/theme-switch" current
            ;;
        generate)
            "$DOTFILES_DIR/scripts/generate-theme" "$@"
            ;;
        delete)
            "$DOTFILES_DIR/scripts/theme-delete" "$@"
            ;;
        *)
            "$DOTFILES_DIR/scripts/theme-switch" "$theme_cmd"
            ;;
    esac
}

# ─────────────────────────────────────────
# Set configuration
# ─────────────────────────────────────────
cmd_set() {
    local target="${1:-}"
    local dir="${2:-}"

    if [[ -z "$target" ]]; then
        error "Usage: dotfiles set <dev|projects> <directory>"
        echo ""
        echo "Examples:"
        echo "  dotfiles set dev ~/src"
        echo "  dotfiles set projects ~/playground"
        return 1
    fi

    local var_name
    case "$target" in
        dev)
            var_name="DEV_ROOT"
            ;;
        projects)
            var_name="PROJECTS_ROOT"
            ;;
        *)
            error "Unknown target: $target (use 'dev' or 'projects')"
            return 1
            ;;
    esac

    if [[ -z "$dir" ]]; then
        error "Directory argument required"
        echo "Usage: dotfiles set $target <directory>"
        return 1
    fi

    # Expand ~ and resolve to absolute path
    dir="${dir/#\~/$HOME}"
    if [[ -d "$dir" ]]; then
        dir=$(cd "$dir" && pwd)
    elif [[ -d "$(dirname "$dir")" ]]; then
        dir=$(cd "$(dirname "$dir")" && pwd)/$(basename "$dir")
    fi

    # Store with $HOME for portability
    local stored_value="\$HOME${dir#"$HOME"}"

    update_zshrc_export "$var_name" "$stored_value"

    success "$var_name set to $dir"
    printf "  ${GREY}Updated ~/.zshrc${NC}\n"
    echo ""
    info "Run 'source ~/.zshrc' or open a new shell to apply."
}

cmd_diff() {
    local found=0

    _copy_pairs

    for pair in "${COPY_PAIRS[@]}"; do
        local repo="${pair%%|*}" installed="${pair#*|}"
        [[ ! -f "$installed" ]] && continue
        local repo_path="$DOTFILES_DIR/$repo"
        [[ ! -f "$repo_path" ]] && continue
        if ! diff -q "$repo_path" "$installed" &>/dev/null; then
            found=1
            echo ""
            printf "${CYAN}%s${NC} vs ${YELLOW}%s${NC}\n" "$repo" "$installed"
            diff --color=auto -u "$repo_path" "$installed" || true
        fi
    done

    if [[ $found -eq 0 ]]; then
        success "All copy-on-install files match repo versions"
    fi
}

# Build the copy-on-install pairs array (shared by diff and sync)
_copy_pairs() {
    COPY_PAIRS=(
        "btop/btop.conf|$HOME/.config/btop/btop.conf"
        "karabiner/karabiner.json|$HOME/.config/karabiner/karabiner.json"
    )
    if is_macos; then
        COPY_PAIRS+=("lazydocker/config.yml|$HOME/Library/Application Support/lazydocker/config.yml")
    else
        COPY_PAIRS+=("lazydocker/config.yml|$HOME/.config/lazydocker/config.yml")
    fi
}

cmd_sync() {
    local force=0
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --force|-f) force=1; shift ;;
            *) error "Unknown option: $1"; return 1 ;;
        esac
    done

    _copy_pairs
    local synced=0 skipped=0 missing=0

    for pair in "${COPY_PAIRS[@]}"; do
        local repo="${pair%%|*}" installed="${pair#*|}"
        local repo_path="$DOTFILES_DIR/$repo"

        if [[ ! -f "$repo_path" ]]; then
            continue
        fi

        if [[ ! -f "$installed" ]]; then
            mkdir -p "$(dirname "$installed")"
            /bin/cp "$repo_path" "$installed"
            success "Created $installed"
            synced=$((synced + 1))
            continue
        fi

        if diff -q "$repo_path" "$installed" &>/dev/null; then
            skipped=$((skipped + 1))
            continue
        fi

        if [[ $force -eq 1 ]]; then
            /bin/cp "$repo_path" "$installed"
            success "Updated $installed"
            synced=$((synced + 1))
        else
            printf "  ${YELLOW}differs${NC}  %s\n" "$repo"
            missing=$((missing + 1))
        fi
    done

    echo ""
    if [[ $synced -gt 0 ]]; then
        success "$synced file(s) synced"
    fi
    if [[ $skipped -gt 0 ]]; then
        printf "  ${GREY}%d file(s) already up to date${NC}\n" "$skipped"
    fi
    if [[ $missing -gt 0 ]]; then
        echo ""
        info "$missing file(s) differ — run 'dotfiles sync --force' to overwrite"
        info "Use 'dotfiles diff' to inspect changes"
    fi
    if [[ $synced -eq 0 ]] && [[ $missing -eq 0 ]]; then
        success "All copy-on-install files are in sync"
    fi
}

cmd_help() {
    print_logo
    cat << 'EOF'
Dotfiles CLI - manage your dotfiles installation

Usage: dotfiles <command> [options]    (shorthand: dot <command>)

Commands:
  update  -u    Pull latest and apply updates (smart incremental)
                dotfiles update                - Incremental update (skip unchanged steps)
                dotfiles update --force, -f    - Re-run all steps regardless of changes
                dotfiles update --preview, -p  - Preview changes without applying
  status  -s    Show version, sync status, and local changes
  health        Run full health check (symlinks, plugins, secrets)
  set           Configure project directories
                dotfiles set dev <dir>       - Set DEV_ROOT in ~/.zshrc
                dotfiles set projects <dir>  - Set PROJECTS_ROOT in ~/.zshrc
  theme   -t    Manage colour themes
                dotfiles theme list          - List available themes
                dotfiles theme current       - Show current theme
                dotfiles theme <name>        - Switch to theme
                dotfiles theme generate <n>  - Generate from Ghostty theme
                dotfiles theme generate list - List Ghostty themes
                dotfiles theme delete <n>    - Delete a generated theme
  links   -l    Show all managed symlinks and their status
  diff    -d    Show changes in copy-on-install files vs repo
  sync          Sync copy-on-install files from repo to system
                dotfiles sync                - Show which files differ
                dotfiles sync --force, -f    - Overwrite with repo versions
  aliases -a    Show all shell aliases, functions, and utilities
  notes   -n    Browse the full changelog in a pager
  version -v    Show current dotfiles version, preset, and theme
  edit    -e    Open dotfiles directory in $EDITOR
  cd            Print dotfiles path (use: cd "$(dotfiles cd)")
  help          Show this help message

Examples:
  dotfiles status                    # Check if updates are available
  dotfiles update                    # Smart update
  dotfiles update --preview           # Preview what would change
  dotfiles update --force            # Force full re-run of all steps
  dotfiles notes                     # Browse full changelog
  dotfiles aliases                   # Browse available aliases and shortcuts
  dotfiles set dev ~/src             # Set DEV_ROOT for launcher picker
  dotfiles theme list                # Show available themes
  dotfiles theme dracula             # Switch to Dracula theme
  dotfiles theme generate zenburn    # Generate from Ghostty theme
  dotfiles theme delete zenburn      # Remove generated theme
  cd "$(dotfiles cd)"                # Navigate to dotfiles directory

Configuration:
  Preset is saved to ~/.config/dotfiles/preset during installation.
  The 'update' command re-uses your saved preset (minimal/core/full).
  Updates are incremental by default — only changed steps are re-run.
  Use --force to re-run all steps, or --preview to preview changes.
EOF
}

cmd_aliases() {
    local BOLD='\033[1m'

    # Print entries in two columns (pairs of name/description)
    # Names in yellow, descriptions in grey, columns separated by dim │
    _2col() {
        local -a items=("$@")
        local i=0 count=${#items[@]}
        while (( i < count )); do
            if (( i + 3 < count )); then
                printf "  ${YELLOW}%-12s${NC} ${GREY}%-22s${NC}  ${GREY}│${NC}  ${YELLOW}%-12s${NC} ${GREY}%s${NC}\n" \
                    "${items[$i]}" "${items[$((i+1))]}" \
                    "${items[$((i+2))]}" "${items[$((i+3))]}"
                (( i += 4 ))
            else
                printf "  ${YELLOW}%-12s${NC} ${GREY}%s${NC}\n" "${items[$i]}" "${items[$((i+1))]}"
                (( i += 2 ))
            fi
        done
    }

    printf "${BOLD}SHELL REFERENCE${NC}\n"
    printf '%0.s─' {1..80}; printf '\n'

    printf "\n${CYAN}NAVIGATION${NC}\n"
    _2col \
        "c"           "clear" \
        "cl"          "clear + scrollback" \
        ".."          "cd .." \
        "..."         "cd ../.." \
        "mkcd <dir>"  "mkdir + cd" \
        "cdb"         "cd back (browser)" \
        "cdf"         "cd forward (after cdb)" \
        "Opt+A"       "cd from history (fzf)"

    printf "\n${CYAN}FILES${NC}\n"
    _2col \
        "ls"  "ls (colour-aware)" \
        "ll"  "ls -alF" \
        "la"  "ls -A" \
        "l"   "ls -CF" \
        "cp"  "cp -i (safe overwrite)" \
        "mv"  "mv -i (safe overwrite)"

    printf "\n${CYAN}SEARCH & PROCESS${NC}\n"
    _2col \
        "grep"        "grep --color=auto" \
        "rg"          "ripgrep (fast search)" \
        "psg <name>"  "ps aux | grep" \
        "ports"       "lsof ports (local)"

    printf "\n${CYAN}GIT${NC}\n"
    _2col \
        "gs"   "git status -sb" \
        "gd"   "git diff" \
        "gdn"  "git diff (diffnav)" \
        "gds"  "git diff --stat" \
        "gl"   "git log (last 20)" \
        "glf"  "git log (full)" \
        "gco"  "git checkout" \
        "gsw"  "git switch" \
        "gb"   "git branch -vv" \
        "gp"   "git push" \
        "gpl"  "git pull" \
        "gst"  "git stash" \
        "gfp"  "git fetch --prune" \
        "gpr"  "prune local branches" \
        "grmc" "git rm --cached" \
        "gca"  "git commit --amend"

    printf "\n${CYAN}TMUX${NC}\n"
    _2col \
        "tls"          "list session backups" \
        "ta/tattach"   "attach/restore session" \
        "trestore"     "restore from backup" \
        "tkill"        "delete session backup" \
        "tcleanup"     "clean test resources" \
        "ac/alerts-clear" "clear all tmux alerts"

    printf "\n${CYAN}SYSTEM & NETWORK${NC}\n"
    _2col \
        "df"      "df -h" \
        "du"      "du -sh" \
        "myip"    "curl ifconfig.me" \
        "h"       "cd ~" \
        "j"       "jobs" \
        "v"       "clear + nvim" \
        "o"       "open file/dir" \
        "finder"  "open in Finder (macOS)" \
        "secrets" "edit secrets.zsh" \
        "config"  "edit ~/.config" \
        "zshrc"   "edit ~/.zshrc" \
        "font-preview" "font browser (fzf)"

    printf "\n${CYAN}DEVELOPMENT${NC}\n"
    _2col \
        "opencode"   "cl + opencode" \
        "oc"         "opencode (shorthand)" \
        "claude"     "cl + claude" \
        "gemini"     "cl + gemini" \
        "copilot"    "cl + copilot" \
        "ralph"      "cl + ralph" \
        "ralf"       "cl + ralf" \
        "drs"        "sync repo paths" \
        "ff"         "fastfetch system info" \
        "dash"       "cl + gh dash" \
        "gols"       "list Go binaries" \
        "nvim-clear" "clear nvim cache" \
        "nvim-sync"  "sync Lazy.nvim plugins" \
        "brewup"     "brew update + upgrade"

    printf "\n${CYAN}PROFILING${NC}\n"
    printf "  ${YELLOW}%-12s${NC} ${GREY}%-22s${NC}  ${GREY}│${NC}  ${YELLOW}%s${NC} ${GREY}%s${NC}\n" \
        "zsh-profile" "benchmark startup (5x)" \
        "zsh-profile-detailed" "detailed (ZPROF)"

    printf "\n${CYAN}DOTFILES CLI${NC}\n"
    _2col \
        "update  -u"  "smart update" \
        "status  -s"  "version + sync + changes" \
        "health"      "full health check" \
        "links   -l"  "managed symlinks" \
        "theme   -t"  "colour themes" \
        "set dev <d>" "set DEV_ROOT" \
        "diff    -d"  "copy-on-install diffs" \
        "sync"        "sync copy-on-install" \
        "notes   -n"  "browse changelog" \
        "version -v"  "version, preset, theme" \
        "edit    -e"  "open in \$EDITOR" \
        "aliases -a"  "show this reference" \
        "dot"         "shorthand for dotfiles" \
        "help"        "show help message"

    # Dotfiles-managed directories from ~/.zshrc
    local zshrc="$HOME/.zshrc"
    if [[ -f "$zshrc" ]]; then
        local dev_root projects_root
        dev_root=$(grep -E '^\s*export\s+DEV_ROOT=' "$zshrc" 2>/dev/null | head -1 | sed 's/.*=//; s/^"//; s/"$//' || true)
        projects_root=$(grep -E '^\s*export\s+PROJECTS_ROOT=' "$zshrc" 2>/dev/null | head -1 | sed 's/.*=//; s/^"//; s/"$//' || true)
        if [[ -n "$dev_root" || -n "$projects_root" ]]; then
            printf "\n${CYAN}DOTFILES DIRECTORIES${NC}  ${GREY}(set via dotfiles set)${NC}\n"
            [[ -n "$dev_root" ]] && printf "  ${YELLOW}%-14s${NC} ${GREY}%s${NC}\n" "DEV_ROOT" "$dev_root"
            [[ -n "$projects_root" ]] && printf "  ${YELLOW}%-14s${NC} ${GREY}%s${NC}\n" "PROJECTS_ROOT" "$projects_root"
        fi
    fi

    # User-defined aliases from ~/.zshrc
    if [[ -f "$zshrc" ]]; then
        local user_aliases
        user_aliases=$(grep -E '^\s*alias\s+' "$zshrc" 2>/dev/null | sed 's/^[[:space:]]*alias[[:space:]]*//' || true)
        if [[ -n "$user_aliases" ]]; then
            printf "\n${CYAN}USER ALIASES${NC}  ${GREY}(~/.zshrc)${NC}\n"
            while IFS= read -r line; do
                local name="${line%%=*}"
                local value="${line#*=}"
                # Strip inline comment (everything from whitespace+# onwards)
                value="${value%%[[:space:]]# *}"
                # Trim trailing whitespace left after comment stripping
                local trailing="${value##*[^[:space:]]}"
                value="${value%"$trailing"}"
                # Strip surrounding quotes
                value="${value#[\"\']}"
                value="${value%[\"\']}"
                printf "  ${YELLOW}%-14s${NC} ${GREY}%s${NC}\n" "$name" "$value"
            done <<< "$user_aliases"
        fi
    fi

    printf '\n'; printf '%0.s─' {1..80}; printf '\n'
    printf "${GREEN}Tip:${NC} run ${YELLOW}dotfiles help${NC} for CLI usage, ${YELLOW}dotfiles health${NC} to verify your install.\n\n"
}

# ─────────────────────────────────────────
# Managed symlinks
# ─────────────────────────────────────────
cmd_links() {
    local preset
    preset=$(get_preset)

    local ok=0 broken=0 absent=0 file_exists=0

    _check_link() {
        local dest="$1"
        # Display path with ~ for $HOME prefix
        local label="${dest/#"$HOME"/\~}"

        if [[ -L "$dest" ]]; then
            if [[ -e "$dest" ]]; then
                printf "  ${GREEN}OK${NC}      %s  ${GREY}→ %s${NC}\n" "$label" "$(readlink "$dest")"
                ok=$(( ok + 1 ))
            else
                printf "  ${RED}BROKEN${NC}  %s  ${GREY}→ %s${NC}\n" "$label" "$(readlink "$dest")"
                broken=$(( broken + 1 ))
            fi
        elif [[ -e "$dest" ]]; then
            printf "  ${YELLOW}FILE${NC}    %s  ${GREY}(exists but not a symlink)${NC}\n" "$label"
            file_exists=$(( file_exists + 1 ))
        else
            printf "  ${YELLOW}ABSENT${NC}  %s\n" "$label"
            absent=$(( absent + 1 ))
        fi
    }

    print_logo
    print_header "Managed Symlinks"
    printf "${CYAN}Preset:${NC} %s\n\n" "$preset"

    # Zsh (minimal)
    printf "${CYAN}Zsh${NC}\n"
    _check_link "$HOME/.zprofile"
    _check_link "$HOME/.p10k.zsh"

    # Tmux (minimal)
    printf "\n${CYAN}Tmux${NC}\n"
    _check_link "$HOME/.tmux"
    _check_link "$HOME/.tmux.conf"

    # CLI (minimal)
    printf "\n${CYAN}CLI${NC}\n"
    _check_link "$HOME/.local/bin/dotfiles"

    # Formatters
    printf "\n${CYAN}Formatters${NC}\n"
    _check_link "$HOME/.prettierrc"
    _check_link "$HOME/.editorconfig"

    # Neovim (core)
    if should_install "core"; then
        printf "\n${CYAN}Neovim${NC}\n"
        _check_link "$HOME/.config/nvim"
    fi

    # Ghostty (core) — config is generated, not symlinked

    # gh-dash (core) — config is generated, not symlinked
    if should_install "core"; then
        printf "\n${CYAN}gh-dash${NC}\n"
        _check_link "$HOME/.local/bin/dash-repo-sync"
    fi

    # Launchers (core)
    if should_install "core"; then
        printf "\n${CYAN}Launchers${NC}\n"
        _check_link "$HOME/.local/launchers/dev"
    fi

    # LazyGit (core)
    if should_install "core"; then
        printf "\n${CYAN}LazyGit${NC}\n"
        _check_link "$HOME/.config/lazygit/config.yml"
    fi



    # Hammerspoon (full)
    if should_install "full"; then
        printf "\n${CYAN}Hammerspoon${NC}\n"
        _check_link "$HOME/.hammerspoon/init.lua"
    fi

    # Summary
    local total=$(( ok + broken + absent + file_exists ))
    echo ""
    printf "${GREEN}%d OK${NC}  ${RED}%d broken${NC}  ${YELLOW}%d absent${NC}  ${YELLOW}%d file${NC}  (%d total)\n" \
        "$ok" "$broken" "$absent" "$file_exists" "$total"
    echo ""
}

# Main dispatch
main() {
    local cmd="${1:-help}"

    case "$cmd" in
        update|-u)
            shift
            cmd_update "$@"
            ;;
        status|-s)
            cmd_status
            ;;
        health)
            cmd_health
            ;;
        set)
            shift
            cmd_set "$@"
            ;;
        theme|-t)
            shift
            cmd_theme "$@"
            ;;
        links|-l)
            cmd_links
            ;;
        aliases|alias|cheat|-a)
            cmd_aliases
            ;;
        edit|-e)
            cmd_edit
            ;;
        cd)
            cmd_cd
            ;;
        diff|-d)
            cmd_diff
            ;;
        sync)
            shift
            cmd_sync "$@"
            ;;
        notes|-n)
            cmd_notes
            ;;
        version|-v|--version)
            cmd_version
            ;;
        help|--help|-h)
            cmd_help
            ;;
        *)
            error "Unknown command: $cmd"
            echo ""
            cmd_help
            exit 1
            ;;
    esac
}

main "$@"
