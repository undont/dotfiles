#!/usr/bin/env bash
# dotfiles — manage your dots
# For per-command details: dotfiles help <command>  (or: dotfiles <command> --help)

set -euo pipefail

# ─── Bootstrap ─────────────────────────────────────────────────────────

# Detect script location to find DOTFILES_DIR (resolve symlinks).
SCRIPT_PATH="${BASH_SOURCE[0]}"
while [[ -L "$SCRIPT_PATH" ]]; do
    SCRIPT_DIR="$(cd -P "$(dirname "$SCRIPT_PATH")" && pwd)"
    SCRIPT_PATH="$(readlink "$SCRIPT_PATH")"
    [[ "$SCRIPT_PATH" != /* ]] && SCRIPT_PATH="$SCRIPT_DIR/$SCRIPT_PATH"
done
SCRIPT_DIR="$(cd -P "$(dirname "$SCRIPT_PATH")" && pwd)"

# DOTFILES_DIR is the parent of scripts/.
DOTFILES_DIR="${DOTFILES_DIR:-$(dirname "$SCRIPT_DIR")}"

# common.sh must be sourced before cli.sh (cli.sh checks for the load guard).
# shellcheck disable=SC1091
source "$DOTFILES_DIR/scripts/_lib/common.sh"
# shellcheck disable=SC1091
source "$DOTFILES_DIR/scripts/_lib/cli.sh"
# shellcheck disable=SC1091
source "$DOTFILES_DIR/scripts/_lib/local-layer.sh"

# ─── Flag-parsing helpers (dispatcher-internal) ────────────────────────

# Print "unknown flag" error and a hint to the per-command help.
unknown_flag() {
    local cmd="$1" flag="$2"
    error "Unknown option for '$cmd': $flag"
    printf "  Run: ${CYAN}dotfiles help %s${NC}\n" "$cmd" >&2
    return 2
}

# Print "missing argument" error and a hint to the per-command help.
missing_arg() {
    local cmd="$1" flag="$2"
    error "'$flag' requires an argument"
    printf "  Run: ${CYAN}dotfiles help %s${NC}\n" "$cmd" >&2
    return 2
}

# ─── Internal helpers (single-use, kept inline for locality) ───────────

# Compute which installer steps can be skipped based on changed files between
# two refs. Returns a comma-separated list (homebrew,packages,symlinks,keyd).
_compute_skip_steps() {
    local ref_from="$1" ref_to="$2"
    local changed_files
    changed_files=$(git -C "$DOTFILES_DIR" diff --name-only "$ref_from" "$ref_to" 2>/dev/null) || return 0

    local skippable=()

    # Homebrew + packages always run so upstream upgrades flow in.
    # install-packages.sh has its own `brew bundle check` fast path that skips
    # the actual install when nothing in the Brewfile is missing or outdated.

    # No config/symlink-related files changed → skip symlinks
    local symlink_patterns='^scripts/install/create-symlinks\.sh|\.template$|^zsh/|^tmux/|^nvim/|^ghostty/|^hammerspoon/|^karabiner/|^launchers/|^lazygit/|^lazydocker/|^formatters/|^gh-dash/|^btop/|^themes/|^keyd/'
    if ! printf '%s\n' "$changed_files" | grep -qE "$symlink_patterns"; then
        skippable+=(symlinks)
    fi

    # keyd/ not changed → skip keyd (Linux only; macOS uses Karabiner)
    if is_linux && ! printf '%s\n' "$changed_files" | grep -q '^keyd/'; then
        skippable+=(keyd)
    fi

    local IFS=','
    printf '%s' "${skippable[*]}"
}

# Show changed files grouped by category for dry-run preview
_preview_changed_files() {
    local ref_from="$1" ref_to="$2"
    local changed_files
    changed_files=$(git -C "$DOTFILES_DIR" diff --name-only "$ref_from" "$ref_to" 2>/dev/null) || return 0

    [[ -z "$changed_files" ]] && return 0

    local -A categories=(
        [Brewfile/packages]="^Brewfile"
        [Zsh config]="^zsh/"
        [Tmux config]="^tmux/"
        [Neovim config]="^nvim/"
        [Ghostty config]="^ghostty/"
        [Theme definitions]="^themes/"
        [Installer/scripts]="^scripts/|^install\.sh"
        [Launchers]="^launchers/"
        [Hammerspoon]="^hammerspoon/"
        [Karabiner]="^karabiner/"
        [Keyd]="^keyd/"
        [LazyGit]="^lazygit/"
        [Documentation]="^docs/|^README|^CLAUDE|^CHANGELOG"
    )

    local -a order=(
        "Brewfile/packages" "Zsh config" "Tmux config" "Neovim config"
        "Ghostty config" "Theme definitions" "Launchers" "Hammerspoon"
        "Karabiner" "Keyd" "LazyGit" "Installer/scripts" "Documentation"
    )

    local shown_files=""
    for cat_name in "${order[@]}"; do
        local pattern="${categories[$cat_name]}"
        local matches
        matches=$(printf '%s\n' "$changed_files" | grep -E "$pattern" || true)
        if [[ -n "$matches" ]]; then
            printf "  ${CYAN}%s:${NC}\n" "$cat_name"
            printf '%s\n' "$matches" | sed 's/^/    /'
            shown_files+="$matches"$'\n'
        fi
    done

    # Show any uncategorised files
    local other
    other=$(printf '%s\n' "$changed_files" | grep -vE "$(IFS='|'; printf '%s' "${categories[*]}")" || true)
    if [[ -n "$other" ]]; then
        printf "  ${CYAN}Other:${NC}\n"
        printf '%s\n' "$other" | sed 's/^/    /'
    fi
}

# Show which update steps would run vs be skipped
_show_step_plan() {
    local skipped="$1"
    # Only skippable steps are listed. Omitted steps always run:
    #   4 (backup) — controlled by --skip-backup, not --skip-steps
    #   9 (secrets), 11 (save preset), 12 (project dirs) — always run, non-skippable
    local -a all_steps=(
        "1:homebrew:Check Homebrew"
        "2:packages:Update packages"
        "3:prerequisites:Check prerequisites"
        "5:symlinks:Update symlinks"
        "6:plugins:Check plugin managers"
        "7:keyd:Update keyd config"
        "8:shell:Check default shell"
        "10:health:Run health check"
    )

    for step_info in "${all_steps[@]}"; do
        local num="${step_info%%:*}"
        local rest="${step_info#*:}"
        local name="${rest%%:*}"
        local label="${rest#*:}"

        if [[ ",$skipped," == *",$name,"* ]]; then
            printf "    ${GREY}%2s. %s (unchanged — skip)${NC}\n" "$num" "$label"
        else
            printf "    ${GREEN}%2s. %s${NC}\n" "$num" "$label"
        fi
    done
}

# Print and clear any post-update notices left by migrations. Migrations
# append blocks to $STATE_DIR/update-notices.txt when they do something
# the user should see after the rest of `dotfiles update` has scrolled
# past (e.g. apps removed, files relocated). Cleared after printing so a
# subsequent update doesn't replay stale notices.
_print_update_notices() {
    local notice_file="$STATE_DIR/update-notices.txt"
    [[ -s "$notice_file" ]] || return 0

    echo ""
    printf "  ${YELLOW}Notices from this update:${NC}\n"
    sed 's/^/  /' "$notice_file"
    rm -f "$notice_file"
}

# Run pending migration scripts between two versions
_run_pending_migrations() {
    local old_head="$1" new_head="$2"
    local migrations_dir="$DOTFILES_DIR/scripts/migrations"
    local applied_file="$STATE_DIR/migrations"

    [[ -d "$migrations_dir" ]] || return 0

    local old_version new_version
    old_version=$(_changelog_version_at_ref "$old_head") || {
        if git -C "$DOTFILES_DIR" rev-parse --verify "$old_head" &>/dev/null; then
            warn "Could not extract version from CHANGELOG.md at $old_head — skipping migrations"
        fi
        return 0
    }
    new_version=$(_changelog_version_at_ref "$new_head") || {
        if git -C "$DOTFILES_DIR" rev-parse --verify "$new_head" &>/dev/null; then
            warn "Could not extract version from CHANGELOG.md at $new_head — skipping migrations"
        fi
        return 0
    }

    [[ -z "$old_version" || -z "$new_version" ]] && return 0

    mkdir -p "$STATE_DIR"
    touch "$applied_file"

    local found_any=false
    local migration
    for migration in "$migrations_dir"/*.sh; do
        [[ -f "$migration" ]] || continue
        local basename="${migration##*/}"
        local migration_version="${basename%%-*}"

        grep -qxF "$basename" "$applied_file" && continue

        if ! _version_gt "$migration_version" "$old_version"; then
            continue
        fi
        if _version_gt "$migration_version" "$new_version"; then
            continue
        fi

        if [[ "$found_any" == false ]]; then
            printf "  ${CYAN}→${NC} Running migrations...\n"
            found_any=true
        fi

        printf "    ${CYAN}•${NC} %s\n" "$basename"
        if bash "$migration"; then
            echo "$basename" >> "$applied_file"
        else
            warn "Migration $basename failed (continuing)"
        fi
    done
}

# Show pending migrations for dry-run preview
_show_pending_migrations() {
    local ref_from="$1" ref_to="$2"
    local migrations_dir="$DOTFILES_DIR/scripts/migrations"
    local applied_file="$STATE_DIR/migrations"

    [[ -d "$migrations_dir" ]] || return 0

    local old_version new_version
    old_version=$(_changelog_version_at_ref "$ref_from") || return 0
    new_version=$(_changelog_version_at_ref "$ref_to") || return 0

    [[ -z "$old_version" || -z "$new_version" ]] && return 0

    local remote_migrations
    remote_migrations=$(git -C "$DOTFILES_DIR" ls-tree --name-only "$ref_to" scripts/migrations/ 2>/dev/null | grep '\.sh$' || true)

    [[ -z "$remote_migrations" ]] && return 0

    touch "$applied_file" 2>/dev/null || true

    local pending=()
    while IFS= read -r path; do
        [[ -z "$path" ]] && continue
        local basename="${path##*/}"
        local migration_version="${basename%%-*}"

        grep -qxF "$basename" "$applied_file" 2>/dev/null && continue

        if _version_gt "$migration_version" "$old_version" && ! _version_gt "$migration_version" "$new_version"; then
            pending+=("$basename")
        fi
    done <<< "$remote_migrations"

    if [[ ${#pending[@]} -gt 0 ]]; then
        echo ""
        printf "  ${CYAN}Pending migrations:${NC}\n"
        for m in "${pending[@]}"; do
            printf "    ${CYAN}•${NC} %s\n" "$m"
        done
    fi
}

# Build the copy-on-install pairs array (shared by diff and sync)
_copy_pairs() {
    COPY_PAIRS=(
        "btop/btop.conf|$HOME/.config/btop/btop.conf"
        "karabiner/karabiner.json|$HOME/.config/karabiner/karabiner.json"
        "zed/settings.json|$HOME/.config/zed/settings.json"
    )
    if is_macos; then
        COPY_PAIRS+=("lazydocker/config.yml|$HOME/Library/Application Support/lazydocker/config.yml")
    else
        COPY_PAIRS+=("lazydocker/config.yml|$HOME/.config/lazydocker/config.yml")
    fi
}

# Render a single managed-symlink row for cmd_links, mutating the outer
# ok / broken / absent / file_exists counters.
_check_link() {
    local dest="$1"
    local label="${dest/#"$HOME"/\~}"

    if [[ -L "$dest" ]]; then
        if [[ -e "$dest" ]]; then
            printf "  ${GREEN}OK${NC}      %s  ${GREY}→ %s${NC}\n" "$label" "$(readlink "$dest")"
            ok=$(( ok + 1 ))
        else
            printf "  ${RED}BROKEN${NC}  %s  ${GREY}→ %s${NC}\n" "$label" "$(readlink "$dest")"
            broken=$(( broken + 1 ))
        fi
    elif [[ -e "$dest" ]]; then
        printf "  ${YELLOW}FILE${NC}    %s  ${GREY}(exists but not a symlink)${NC}\n" "$label"
        file_exists=$(( file_exists + 1 ))
    else
        printf "  ${YELLOW}ABSENT${NC}  %s\n" "$label"
        absent=$(( absent + 1 ))
    fi
}

# ─── Commands (cmd_*) ─────────────────────────────────────────────────

# Cheatsheet renderer. The static section/entry data is parsed from
# zsh/dotfiles.zsh — see _aliases_parse for the source conventions.
cmd_aliases() {
    while [[ $# -gt 0 ]]; do
        case "$1" in
            -h|--help) _help_aliases; return 0 ;;
            --)        shift; break ;;
            -*)        unknown_flag aliases "$1"; return $? ;;
            *)         unknown_flag aliases "$1"; return $? ;;
        esac
        shift
    done

    local source_file="$DOTFILES_DIR/zsh/dotfiles.zsh"
    if [[ ! -f "$source_file" ]]; then
        error "Shell source not found: $source_file"
        return 1
    fi

    local BOLD='\033[1m'

    printf "${BOLD}SHELL REFERENCE${NC}\n"
    printf '%0.s─' {1..80}; printf '\n'

    # Parser emits tab-separated records:
    #   SECTION<tab><name>            — start a new section (flush pending pair first)
    #   ENTRY<tab><name><tab><desc>   — emit a row in the current section
    while IFS=$'\t' read -r kind a b; do
        case "$kind" in
            SECTION)
                _aliases_flush_pending
                printf "\n${CYAN}%s${NC}\n" "$a"
                ;;
            ENTRY)
                _aliases_emit "$a" "$b"
                ;;
        esac
    done < <(_aliases_parse "$source_file")
    _aliases_flush_pending

    _aliases_render_zshrc

    printf '\n'
    printf '%0.s─' {1..80}; printf '\n'
    printf "${GREEN}Tip:${NC} run ${YELLOW}dotfiles help${NC} for CLI usage, ${YELLOW}dotfiles health${NC} to verify your install.\n\n"
}

# Parse the shell source and emit SECTION/ENTRY records.
# Conventions (in zsh/dotfiles.zsh):
#   "# @section: <Name>"                       → SECTION (display name, uppercased)
#   "alias <name>=\"...\"  # <description>"    → ENTRY (alias name + trailing description)
#   "# @cheat: <name> | <description>"         → ENTRY (free-form name + description)
#   "# @cheat: <description>" then "name() {"  → ENTRY (function name + directive description)
# Aliases without a trailing description comment are skipped — the cheatsheet is curated.
_aliases_parse() {
    local file="$1"
    awk '
        # Section header: "# @section: <Name>"
        /^# @section: / {
            name = substr($0, 13)
            sub(/^[[:space:]]+/, "", name)
            sub(/[[:space:]]+$/, "", name)
            print "SECTION\t" toupper(name)
            pending_cheat = ""
            next
        }

        # Free-form cheat row: "# @cheat: <name> | <description>"
        # Splits on the FIRST "|" only (descriptions may contain "|").
        /^# @cheat:.*\|/ {
            line = substr($0, 10)
            sub(/^[[:space:]]+/, "", line)
            if (match(line, /[[:space:]]*\|[[:space:]]*/)) {
                name = substr(line, 1, RSTART - 1)
                desc = substr(line, RSTART + RLENGTH)
                sub(/[[:space:]]+$/, "", name)
                sub(/[[:space:]]+$/, "", desc)
                print "ENTRY\t" name "\t" desc
            }
            pending_cheat = ""
            next
        }

        # Function-attached cheat directive: "# @cheat: <description>"
        /^# @cheat: / {
            pending_cheat = substr($0, 10)
            sub(/^[[:space:]]+/, "", pending_cheat)
            next
        }

        # Function definition (with or without "function" keyword).
        # Pairs with the preceding pending_cheat.
        /^(function )?[a-zA-Z_][a-zA-Z0-9_-]*\(\)[[:space:]]*\{/ {
            if (pending_cheat != "") {
                fname = $0
                sub(/^function /, "", fname)
                sub(/\(\).*/, "", fname)
                print "ENTRY\t" fname "\t" pending_cheat
            }
            pending_cheat = ""
            next
        }

        # Alias definition with trailing description comment.
        # Match a closing quote followed by whitespace then "# <desc>".
        # Leading whitespace allowed (handles aliases inside if/else blocks).
        /^[[:space:]]*alias [a-zA-Z_][a-zA-Z0-9_-]*=/ {
            name = $0
            sub(/^[[:space:]]*alias /, "", name)
            sub(/=.*/, "", name)

            desc = $0
            if (match(desc, /"[[:space:]]+#[[:space:]]*/)) {
                desc = substr(desc, RSTART + RLENGTH)
            } else if (match(desc, /'\''[[:space:]]+#[[:space:]]*/)) {
                desc = substr(desc, RSTART + RLENGTH)
            } else {
                pending_cheat = ""
                next
            }
            sub(/[[:space:]]+$/, "", desc)
            print "ENTRY\t" name "\t" desc
            pending_cheat = ""
            next
        }

        # Any other non-comment, non-blank line clears pending_cheat so the
        # directive only attaches to the immediately following function.
        /^[^#[:space:]]/ { pending_cheat = "" }
    ' "$file"
}

# Two-column emit: buffers one pair, flushes when paired.
_ALIASES_PENDING_NAME=""
_ALIASES_PENDING_DESC=""

_aliases_emit() {
    local name="$1" desc="$2"
    if [[ -z "$_ALIASES_PENDING_NAME" ]]; then
        _ALIASES_PENDING_NAME="$name"
        _ALIASES_PENDING_DESC="$desc"
        return
    fi
    printf "  ${YELLOW}%-12s${NC} ${GREY}%-22s${NC}  ${GREY}│${NC}  ${YELLOW}%-12s${NC} ${GREY}%s${NC}\n" \
        "$_ALIASES_PENDING_NAME" "$_ALIASES_PENDING_DESC" "$name" "$desc"
    _ALIASES_PENDING_NAME=""
    _ALIASES_PENDING_DESC=""
}

_aliases_flush_pending() {
    if [[ -n "$_ALIASES_PENDING_NAME" ]]; then
        printf "  ${YELLOW}%-12s${NC} ${GREY}%s${NC}\n" \
            "$_ALIASES_PENDING_NAME" "$_ALIASES_PENDING_DESC"
        _ALIASES_PENDING_NAME=""
        _ALIASES_PENDING_DESC=""
    fi
}

# Render dynamic sections (project dirs + user aliases from ~/.zshrc).
_aliases_render_zshrc() {
    local zshrc="$HOME/.zshrc"
    [[ -f "$zshrc" ]] || return 0

    local dev_root projects_root
    dev_root=$(grep -E '^\s*export\s+DEV_ROOT=' "$zshrc" 2>/dev/null \
        | head -1 | sed 's/.*=//; s/^"//; s/"$//' || true)
    projects_root=$(grep -E '^\s*export\s+PROJECTS_ROOT=' "$zshrc" 2>/dev/null \
        | head -1 | sed 's/.*=//; s/^"//; s/"$//' || true)
    if [[ -n "$dev_root" || -n "$projects_root" ]]; then
        printf "\n${CYAN}DOTFILES DIRECTORIES${NC}  ${GREY}(set via dotfiles set)${NC}\n"
        [[ -n "$dev_root" ]]      && printf "  ${YELLOW}%-14s${NC} ${GREY}%s${NC}\n" "DEV_ROOT" "$dev_root"
        [[ -n "$projects_root" ]] && printf "  ${YELLOW}%-14s${NC} ${GREY}%s${NC}\n" "PROJECTS_ROOT" "$projects_root"
    fi

    local user_aliases
    user_aliases=$(grep -E '^\s*alias\s+' "$zshrc" 2>/dev/null \
        | sed 's/^[[:space:]]*alias[[:space:]]*//' || true)
    if [[ -n "$user_aliases" ]]; then
        printf "\n${CYAN}USER ALIASES${NC}  ${GREY}(~/.zshrc)${NC}\n"
        while IFS= read -r line; do
            local name="${line%%=*}"
            local value="${line#*=}"
            value="${value%%[[:space:]]# *}"
            local trailing="${value##*[^[:space:]]}"
            value="${value%"$trailing"}"
            value="${value#[\"\']}"
            value="${value%[\"\']}"
            printf "  ${YELLOW}%-14s${NC} ${GREY}%s${NC}\n" "$name" "$value"
        done <<< "$user_aliases"
    fi
}

cmd_cd() {
    while [[ $# -gt 0 ]]; do
        case "$1" in
            -h|--help) _help_cd; return 0 ;;
            --)        shift; break ;;
            -*)        unknown_flag cd "$1"; return $? ;;
            *)         unknown_flag cd "$1"; return $? ;;
        esac
        shift
    done
    echo "$DOTFILES_DIR"
}

cmd_diff() {
    while [[ $# -gt 0 ]]; do
        case "$1" in
            -h|--help) _help_diff; return 0 ;;
            --)        shift; break ;;
            -*)        unknown_flag diff "$1"; return $? ;;
            *)         unknown_flag diff "$1"; return $? ;;
        esac
        shift
    done

    local found=0
    _copy_pairs

    for pair in "${COPY_PAIRS[@]}"; do
        local repo="${pair%%|*}" installed="${pair#*|}"
        [[ ! -f "$installed" ]] && continue
        local repo_path="$DOTFILES_DIR/$repo"
        [[ ! -f "$repo_path" ]] && continue
        if ! diff -q "$repo_path" "$installed" &>/dev/null; then
            found=1
            echo ""
            printf "${CYAN}%s${NC} vs ${YELLOW}%s${NC}\n" "$repo" "$installed"
            diff --color=auto -u "$repo_path" "$installed" || true
        fi
    done

    if [[ $found -eq 0 ]]; then
        success "All copy-on-install files match repo versions"
    fi
}

cmd_edit() {
    while [[ $# -gt 0 ]]; do
        case "$1" in
            -h|--help) _help_edit; return 0 ;;
            --)        shift; break ;;
            -*)        unknown_flag edit "$1"; return $? ;;
            *)         unknown_flag edit "$1"; return $? ;;
        esac
        shift
    done
    cd "$DOTFILES_DIR"
    ${EDITOR:-vim} .
}

cmd_export() {
    local push=0
    local -a selectors=()
    while [[ $# -gt 0 ]]; do
        case "$1" in
            -h|--help)  _help_export; return 0 ;;
            -p|--push)  push=1 ;;
            --)         shift; break ;;
            -*)         unknown_flag export "$1"; return $? ;;
            *)          selectors+=("$1") ;;
        esac
        shift
    done
    selectors+=("$@")

    local dir
    dir=$(_local_dir_required) || return $?
    _local_pairs
    if [[ ${#selectors[@]} -gt 0 ]]; then
        _local_select "${selectors[@]}" || return 1
    fi

    local pair repo sys
    local -a added=()
    for pair in ${LOCAL_PAIRS[@]+"${LOCAL_PAIRS[@]}"}; do
        repo="${pair%%|*}" sys="${pair#*|}"
        added+=("$repo")
        [[ -f "$sys" ]] || continue
        mkdir -p "$(dirname "$dir/$repo")"
        if [[ ! -f "$dir/$repo" ]] || ! diff -q "$sys" "$dir/$repo" &>/dev/null; then
            /bin/cp "$sys" "$dir/$repo"
        fi
    done

    # directories: replace the repo copy wholesale so deletions propagate;
    # strip .DS_Store and never export symlinks
    if [[ ${#LOCAL_DIR_PAIRS[@]} -gt 0 ]]; then
        for pair in "${LOCAL_DIR_PAIRS[@]}"; do
            repo="${pair%%|*}" sys="${pair#*|}"
            added+=("$repo")
            [[ -d "$sys" ]] || continue
            rm -rf "${dir:?}/${repo:?}"
            mkdir -p "$dir/$repo"
            /bin/cp -R "$sys/." "$dir/$repo/"
            find "$dir/$repo" -name .DS_Store -delete
            find "$dir/$repo" -type l -delete
        done
    fi

    # scope the stage to the exported entries when targeted, so a partial
    # export never sweeps in unrelated drift sitting in the repo
    if [[ ${#selectors[@]} -gt 0 ]]; then
        git -C "$dir" add -A -- ${added[@]+"${added[@]}"}
    else
        git -C "$dir" add -A
    fi
    local changed
    changed=$(git -C "$dir" status --porcelain | wc -l | tr -d ' ')
    if [[ "$changed" -gt 0 ]]; then
        _local_commit "$dir" "export from $(hostname -s) $(date '+%Y-%m-%d %H:%M')"
        success "Exported $changed change(s), committed to $dir"
    else
        success "Nothing to export, local repo is up to date"
    fi

    if [[ $push -eq 1 ]]; then
        if git -C "$dir" remote get-url origin &>/dev/null; then
            if git -C "$dir" push -q -u origin HEAD 2>/dev/null; then
                success "Pushed to origin"
            else
                error "Push failed, check the remote"
                return 1
            fi
        else
            warn "No remote configured"
            printf "  Add one: ${CYAN}git -C %s remote add origin <url>${NC}\n" "$dir"
        fi
    fi
}

cmd_health() {
    while [[ $# -gt 0 ]]; do
        case "$1" in
            -h|--help) _help_health; return 0 ;;
            --)        shift; break ;;
            -*)        unknown_flag health "$1"; return $? ;;
            *)         unknown_flag health "$1"; return $? ;;
        esac
        shift
    done
    "$DOTFILES_DIR/scripts/install/health-check.sh"
}

cmd_help() {
    local topic="${1:-}"
    if [[ -z "$topic" ]]; then
        _help_main
        return 0
    fi
    # Resolve aliases / short flags to canonical names
    case "$topic" in
        -u) topic="update" ;;
        -s) topic="status" ;;
        -t) topic="theme" ;;
        -l) topic="links" ;;
        -d) topic="diff" ;;
        -a) topic="aliases" ;;
        -n) topic="notes" ;;
        -v) topic="version" ;;
        -e) topic="edit" ;;
    esac
    local fn="_help_${topic//-/_}"
    if declare -F "$fn" >/dev/null; then
        "$fn"
    else
        error "No help available for: $topic"
        echo ""
        _help_main
        return 1
    fi
}

# import a single file, mutating the outer synced / skipped / differs /
# symlinks counters; respects the outer force flag
_import_one() {
    local repo_file="$1" sys_file="$2" label="$3"
    [[ -f "$repo_file" ]] || return 0

    if [[ -L "$sys_file" ]]; then
        printf "  ${YELLOW}symlink${NC}  %s  ${GREY}(resolve manually)${NC}\n" "$label"
        symlinks=$((symlinks + 1))
        return 0
    fi
    if [[ ! -f "$sys_file" ]]; then
        mkdir -p "$(dirname "$sys_file")"
        /bin/cp "$repo_file" "$sys_file"
        [[ "$sys_file" == */aerc/accounts.conf ]] && chmod 600 "$sys_file"
        success "Created $sys_file"
        synced=$((synced + 1))
        return 0
    fi
    if diff -q "$repo_file" "$sys_file" &>/dev/null; then
        skipped=$((skipped + 1))
        return 0
    fi
    if [[ $force -eq 1 ]]; then
        /bin/cp "$repo_file" "$sys_file"
        [[ "$sys_file" == */aerc/accounts.conf ]] && chmod 600 "$sys_file"
        success "Updated $sys_file"
        synced=$((synced + 1))
    else
        printf "  ${YELLOW}differs${NC}  %s\n" "$label"
        differs=$((differs + 1))
    fi
}

# prune a system file inside a directory pair that has no repo counterpart:
# export mirrors the dir wholesale, so a missing repo file means it was
# removed upstream, or created locally on this machine. the two are
# indistinguishable, so deletion is gated behind an explicit --prune (never
# --force) to protect machine-local launchers
_prune_one() {
    local sys_file="$1" label="$2"
    if [[ $prune -eq 1 ]]; then
        rm -f "$sys_file"
        success "Removed $sys_file"
        removed=$((removed + 1))
    else
        printf "  ${YELLOW}orphan${NC}   %s  ${GREY}(not in repo; --prune to delete)${NC}\n" "$label"
        orphaned=$((orphaned + 1))
    fi
}

cmd_import() {
    local force=0 prune=0
    local -a selectors=()
    while [[ $# -gt 0 ]]; do
        case "$1" in
            -h|--help)  _help_import; return 0 ;;
            -f|--force) force=1 ;;
            -p|--prune) prune=1 ;;
            --)         shift; break ;;
            -*)         unknown_flag import "$1"; return $? ;;
            *)          selectors+=("$1") ;;
        esac
        shift
    done
    selectors+=("$@")

    local dir
    dir=$(_local_dir_required) || return $?

    if git -C "$dir" remote get-url origin &>/dev/null; then
        git -C "$dir" pull --ff-only -q 2>/dev/null \
            || warn "Pull failed (offline or diverged), importing from local copy"
    fi

    _local_pairs
    if [[ ${#selectors[@]} -gt 0 ]]; then
        _local_select "${selectors[@]}" || return 1
    fi

    local synced=0 skipped=0 differs=0 symlinks=0 removed=0 orphaned=0
    local pair repo sys rel f
    for pair in ${LOCAL_PAIRS[@]+"${LOCAL_PAIRS[@]}"}; do
        repo="${pair%%|*}" sys="${pair#*|}"
        _import_one "$dir/$repo" "$sys" "$repo"
    done
    if [[ ${#LOCAL_DIR_PAIRS[@]} -gt 0 ]]; then
        for pair in "${LOCAL_DIR_PAIRS[@]}"; do
            repo="${pair%%|*}" sys="${pair#*|}"
            [[ -d "$dir/$repo" ]] || continue
            while IFS= read -r f; do
                rel="${f#"$dir/$repo/"}"
                _import_one "$f" "$sys/$rel" "$repo/$rel"
            done < <(find "$dir/$repo" -type f ! -name .DS_Store)
            # prune system files the repo no longer tracks. -type f skips
            # symlinks, which export never captures, so repo-managed launcher
            # links are left in place
            [[ -d "$sys" ]] || continue
            while IFS= read -r f; do
                rel="${f#"$sys/"}"
                [[ -f "$dir/$repo/$rel" ]] && continue
                _prune_one "$f" "$repo/$rel"
            done < <(find "$sys" -type f ! -name .DS_Store)
        done
    fi

    echo ""
    if [[ $synced -gt 0 ]]; then
        success "$synced file(s) imported"
    fi
    if [[ $removed -gt 0 ]]; then
        success "$removed file(s) removed"
    fi
    if [[ $skipped -gt 0 ]]; then
        printf "  ${GREY}%d file(s) already up to date${NC}\n" "$skipped"
    fi
    if [[ $differs -gt 0 ]]; then
        echo ""
        info "$differs file(s) differ; run 'dotfiles import --force' to overwrite"
        info "Use 'dotfiles local diff' to inspect changes"
    fi
    if [[ $orphaned -gt 0 ]]; then
        info "$orphaned file(s) not in repo; run 'dotfiles import --prune' to delete"
    fi
    if [[ $symlinks -gt 0 ]]; then
        info "$symlinks destination(s) are symlinks and were left untouched"
    fi
    if [[ $synced -eq 0 && $removed -eq 0 && $differs -eq 0 && $orphaned -eq 0 && $symlinks -eq 0 ]]; then
        success "Local layer already in sync"
    fi
}

cmd_links() {
    while [[ $# -gt 0 ]]; do
        case "$1" in
            -h|--help) _help_links; return 0 ;;
            --)        shift; break ;;
            -*)        unknown_flag links "$1"; return $? ;;
            *)         unknown_flag links "$1"; return $? ;;
        esac
        shift
    done

    local preset
    preset=$(get_preset)

    local ok=0 broken=0 absent=0 file_exists=0

    print_logo
    print_header "Managed Symlinks"
    printf "${CYAN}Preset:${NC} %s\n\n" "$preset"

    # Zsh (minimal)
    printf "${CYAN}Zsh${NC}\n"
    _check_link "$HOME/.zprofile"

    # Tmux (minimal)
    printf "\n${CYAN}Tmux${NC}\n"
    _check_link "$HOME/.tmux"
    _check_link "$HOME/.tmux.conf"

    # CLI (minimal)
    printf "\n${CYAN}CLI${NC}\n"
    _check_link "$HOME/.local/bin/dotfiles"

    # Formatters
    printf "\n${CYAN}Formatters${NC}\n"
    _check_link "$HOME/.prettierrc"
    _check_link "$HOME/.editorconfig"

    # Neovim (core)
    if should_install "core"; then
        printf "\n${CYAN}Neovim${NC}\n"
        _check_link "$HOME/.config/nvim"
    fi

    # gh-dash (core) — config is generated, not symlinked
    if should_install "core"; then
        printf "\n${CYAN}gh-dash${NC}\n"
        _check_link "$HOME/.local/bin/dash-repo-sync"
    fi

    # Launchers (core)
    if should_install "core"; then
        printf "\n${CYAN}Launchers${NC}\n"
        _check_link "$HOME/.local/launchers/dev"
    fi

    # LazyGit (core)
    if should_install "core"; then
        printf "\n${CYAN}LazyGit${NC}\n"
        _check_link "$HOME/.config/lazygit/config.yml"
    fi

    # Hammerspoon (full)
    if should_install "full"; then
        printf "\n${CYAN}Hammerspoon${NC}\n"
        _check_link "$HOME/.hammerspoon/init.lua"
    fi

    # Summary
    local total=$(( ok + broken + absent + file_exists ))
    echo ""
    printf "${GREEN}%d OK${NC}  ${RED}%d broken${NC}  ${YELLOW}%d absent${NC}  ${YELLOW}%d file${NC}  (%d total)\n" \
        "$ok" "$broken" "$absent" "$file_exists" "$total"
    echo ""
}

cmd_local() {
    if [[ "${1:-}" == "-h" || "${1:-}" == "--help" ]]; then
        _help_local
        return 0
    fi

    local sub="${1:-status}"
    shift || true

    case "$sub" in
        init)   cmd_local_init   "$@" ;;
        clone)  cmd_local_clone  "$@" ;;
        status) cmd_local_status "$@" ;;
        diff)   cmd_local_diff   "$@" ;;
        edit)   cmd_local_edit   "$@" ;;
        *)
            error "Unknown local subcommand: $sub"
            printf "  Run: ${CYAN}dotfiles help local${NC}\n" >&2
            return 2
            ;;
    esac
}

cmd_local_init() {
    local url="" dir_flag=""
    while [[ $# -gt 0 ]]; do
        case "$1" in
            -h|--help) _help_local; return 0 ;;
            --dir)
                if [[ -z "${2:-}" ]]; then
                    missing_arg local --dir
                    return $?
                fi
                dir_flag="$2"
                shift
                ;;
            --) shift; break ;;
            -*) unknown_flag local "$1"; return $? ;;
            *)  url="$1" ;;
        esac
        shift
    done

    local dir
    dir="${dir_flag:-$(get_local_dir)}"
    dir="${dir:-$HOME/.dotfiles-local}"
    dir="${dir/#\~/$HOME}"

    local already=0
    if git -C "$dir" rev-parse --git-dir &>/dev/null \
        && [[ -f "$LOCAL_REPO_FILE" || -n "${DOTFILES_LOCAL_DIR:-}" ]]; then
        already=1
    fi

    mkdir -p "$dir"
    if ! git -C "$dir" rev-parse --git-dir &>/dev/null; then
        git -C "$dir" init -q -b main 2>/dev/null || git -C "$dir" init -q
    fi
    _local_seed_gitignore "$dir"
    if [[ -n "$url" ]]; then
        url=$(_local_expand_url "$url")
        git -C "$dir" remote add origin "$url" 2>/dev/null \
            || git -C "$dir" remote set-url origin "$url"
    fi
    _local_write_pointer "$dir"

    if [[ $already -eq 1 ]]; then
        info "Already configured: $dir"
    else
        success "Local layer repo ready: $dir"
    fi
    printf "  ${GREY}Next: 'dotfiles export' to capture your local layer.${NC}\n"
}

cmd_local_clone() {
    local url="" dir_flag=""
    while [[ $# -gt 0 ]]; do
        case "$1" in
            -h|--help) _help_local; return 0 ;;
            --dir)
                if [[ -z "${2:-}" ]]; then
                    missing_arg local --dir
                    return $?
                fi
                dir_flag="$2"
                shift
                ;;
            --) shift; break ;;
            -*) unknown_flag local "$1"; return $? ;;
            *)  url="$1" ;;
        esac
        shift
    done

    if [[ -z "$url" ]]; then
        error "'clone' requires a repository url"
        printf "  Run: ${CYAN}dotfiles help local${NC}\n" >&2
        return 2
    fi
    url=$(_local_expand_url "$url")

    local dir
    dir="${dir_flag:-$HOME/.dotfiles-local}"
    dir="${dir/#\~/$HOME}"

    if [[ -d "$dir" && -n "$(ls -A "$dir" 2>/dev/null)" ]]; then
        error "Directory exists and is not empty: $dir"
        printf "  Use ${CYAN}--dir <path>${NC} or remove it first.\n" >&2
        return 1
    fi

    if ! git clone -q "$url" "$dir"; then
        error "Clone failed"
        return 1
    fi
    _local_seed_gitignore "$dir"
    _local_write_pointer "$dir"

    success "Cloned local layer repo to $dir"

    # cloning is a statement of intent to use it here; apply immediately
    # (skips files that differ, so this never clobbers)
    echo ""
    cmd_import
}

cmd_local_status() {
    while [[ $# -gt 0 ]]; do
        case "$1" in
            -h|--help) _help_local; return 0 ;;
            --)        shift; break ;;
            *)         unknown_flag local "$1"; return $? ;;
        esac
        shift
    done

    local dir
    dir=$(get_local_dir)
    if [[ -z "$dir" ]]; then
        info "No local repo configured (optional)"
        printf "  ${GREY}Set up with: dotfiles local init | dotfiles local clone <url>${NC}\n"
        return 0
    fi

    printf "${CYAN}Path:${NC}    %s" "$dir"
    [[ -n "${DOTFILES_LOCAL_DIR:-}" ]] && printf "  ${GREY}(from DOTFILES_LOCAL_DIR)${NC}"
    printf "\n"

    if [[ ! -d "$dir" ]] || ! git -C "$dir" rev-parse --git-dir &>/dev/null; then
        error "Path missing or not a git repository"
        printf "  Fix the pointer (%s) or run: ${CYAN}dotfiles local init${NC}\n" "$LOCAL_REPO_FILE" >&2
        return 1
    fi

    local remote
    remote=$(git -C "$dir" remote get-url origin 2>/dev/null) || remote="none"
    printf "${CYAN}Remote:${NC}  %s\n" "$remote"

    if [[ "$remote" != "none" ]]; then
        git -C "$dir" fetch origin --quiet 2>/dev/null || true
        local behind ahead
        behind=$(git -C "$dir" rev-list HEAD..@'{upstream}' --count 2>/dev/null) || behind=0
        ahead=$(git -C "$dir" rev-list @'{upstream}'..HEAD --count 2>/dev/null) || ahead=0
        if [[ $behind -eq 0 && $ahead -eq 0 ]]; then
            printf "  ${GREEN}✓${NC} Up-to-date with origin\n"
        else
            [[ $behind -gt 0 ]] && printf "  ${YELLOW}↓${NC} %d commit(s) behind origin\n" "$behind"
            [[ $ahead -gt 0 ]]  && printf "  ${YELLOW}↑${NC} %d commit(s) ahead of origin\n" "$ahead"
        fi
    fi

    if [[ -n $(git -C "$dir" status --porcelain 2>/dev/null) ]]; then
        printf "  ${YELLOW}!${NC} Uncommitted changes in the local repo\n"
    fi

    # manifest drift: file pairs individually, each directory pair as one unit
    _local_pairs
    local insync=0 differ=0 only_sys=0 only_repo=0
    local pair repo sys
    for pair in "${LOCAL_PAIRS[@]}"; do
        repo="$dir/${pair%%|*}" sys="${pair#*|}"
        if [[ -f "$repo" && -f "$sys" ]]; then
            if diff -q "$repo" "$sys" &>/dev/null; then
                insync=$((insync + 1))
            else
                differ=$((differ + 1))
            fi
        elif [[ -f "$sys" ]]; then
            only_sys=$((only_sys + 1))
        elif [[ -f "$repo" ]]; then
            only_repo=$((only_repo + 1))
        fi
    done
    if [[ ${#LOCAL_DIR_PAIRS[@]} -gt 0 ]]; then
        for pair in "${LOCAL_DIR_PAIRS[@]}"; do
            repo="$dir/${pair%%|*}" sys="${pair#*|}"
            if [[ -d "$repo" && -d "$sys" ]]; then
                if diff -r -q -x .DS_Store "$repo" "$sys" &>/dev/null; then
                    insync=$((insync + 1))
                else
                    differ=$((differ + 1))
                fi
            elif [[ -d "$sys" ]]; then
                only_sys=$((only_sys + 1))
            elif [[ -d "$repo" ]]; then
                only_repo=$((only_repo + 1))
            fi
        done
    fi

    echo ""
    printf "${GREEN}%d in sync${NC}  ${YELLOW}%d differ${NC}  ${YELLOW}%d not yet exported${NC}  ${YELLOW}%d not yet imported${NC}\n" \
        "$insync" "$differ" "$only_sys" "$only_repo"
}

cmd_local_diff() {
    while [[ $# -gt 0 ]]; do
        case "$1" in
            -h|--help) _help_local; return 0 ;;
            --)        shift; break ;;
            *)         unknown_flag local "$1"; return $? ;;
        esac
        shift
    done

    local dir
    dir=$(_local_dir_required) || return $?
    _local_pairs

    # repo side first so + lines show what export would capture
    local found=0
    local pair repo sys label
    for pair in "${LOCAL_PAIRS[@]}"; do
        label="${pair%%|*}" sys="${pair#*|}"
        repo="$dir/$label"
        if [[ -f "$repo" && -f "$sys" ]]; then
            if ! diff -q "$repo" "$sys" &>/dev/null; then
                found=1
                echo ""
                printf "${CYAN}%s${NC} vs ${YELLOW}%s${NC}\n" "$label" "$sys"
                diff --color=auto -u "$repo" "$sys" || true
            fi
        elif [[ -f "$sys" ]]; then
            found=1
            printf "  ${YELLOW}only on system${NC}  %s\n" "$label"
        elif [[ -f "$repo" ]]; then
            found=1
            printf "  ${YELLOW}only in repo${NC}    %s\n" "$label"
        fi
    done
    if [[ ${#LOCAL_DIR_PAIRS[@]} -gt 0 ]]; then
        for pair in "${LOCAL_DIR_PAIRS[@]}"; do
            label="${pair%%|*}" sys="${pair#*|}"
            repo="$dir/$label"
            if [[ -d "$repo" && -d "$sys" ]]; then
                if ! diff -r -q -x .DS_Store "$repo" "$sys" &>/dev/null; then
                    found=1
                    echo ""
                    printf "${CYAN}%s/${NC} vs ${YELLOW}%s/${NC}\n" "$label" "$sys"
                    diff -r -x .DS_Store --color=auto -u "$repo" "$sys" || true
                fi
            elif [[ -d "$sys" ]]; then
                found=1
                printf "  ${YELLOW}only on system${NC}  %s/\n" "$label"
            elif [[ -d "$repo" ]]; then
                found=1
                printf "  ${YELLOW}only in repo${NC}    %s/\n" "$label"
            fi
        done
    fi

    # git-level state in the local repo, scoped to the managed pairs. export
    # auto-commits, so uncommitted changes here mean a repo file was edited by
    # hand: the repo↔system comparison above can report a clean match while such
    # an edit sits unsaved (and a later export, treating the system file as the
    # source of truth, would overwrite it), so surface it or it stays invisible
    local -a relpaths=()
    for pair in "${LOCAL_PAIRS[@]}"; do relpaths+=("${pair%%|*}"); done
    for pair in ${LOCAL_DIR_PAIRS[@]+"${LOCAL_DIR_PAIRS[@]}"}; do relpaths+=("${pair%%|*}"); done
    local git_dirty=""
    if git -C "$dir" rev-parse --git-dir &>/dev/null && [[ ${#relpaths[@]} -gt 0 ]]; then
        git_dirty=$(git -C "$dir" status --porcelain -- "${relpaths[@]}" 2>/dev/null)
    fi
    if [[ -n "$git_dirty" ]]; then
        echo ""
        printf "${YELLOW}uncommitted in the local repo${NC} (edited by hand, not via export; a later export may overwrite it):\n"
        if git -C "$dir" rev-parse --verify -q HEAD >/dev/null 2>&1; then
            git -C "$dir" -c color.ui=always diff HEAD -- "${relpaths[@]}" 2>/dev/null || true
        else
            printf "%s\n" "$git_dirty"
        fi
        printf "  ${GREY}save with: git -C %s commit -a   ·   discard with: git -C %s checkout -- .${NC}\n" "$dir" "$dir"
    fi

    if [[ $found -eq 0 && -z "$git_dirty" ]]; then
        success "Local layer matches the repo"
        return 0
    fi
    if [[ $found -eq 0 ]]; then
        info "System and repo copies match; commit the changes above to save them"
    fi
    return 1
}

cmd_local_edit() {
    while [[ $# -gt 0 ]]; do
        case "$1" in
            -h|--help) _help_local; return 0 ;;
            --)        shift; break ;;
            -*)        unknown_flag local "$1"; return $? ;;
            *)         unknown_flag local "$1"; return $? ;;
        esac
        shift
    done

    local dir
    dir=$(_local_dir_required) || return $?
    cd "$dir"
    ${EDITOR:-vim} .
}

cmd_notes() {
    while [[ $# -gt 0 ]]; do
        case "$1" in
            -h|--help) _help_notes; return 0 ;;
            --)        shift; break ;;
            -*)        unknown_flag notes "$1"; return $? ;;
            *)         unknown_flag notes "$1"; return $? ;;
        esac
        shift
    done

    local changelog="$DOTFILES_DIR/CHANGELOG.md"
    if [[ ! -f "$changelog" ]]; then
        error "CHANGELOG.md not found"
        return 1
    fi

    local current_version
    current_version=$(_changelog_local_version) || true

    # Try to show the remote changelog so users can see unreceived changes
    local content=""
    git -C "$DOTFILES_DIR" fetch origin --quiet 2>/dev/null || true
    local remote_branch
    remote_branch=$(get_remote_branch)
    content=$(git -C "$DOTFILES_DIR" show "$remote_branch:CHANGELOG.md" 2>/dev/null) || content=""

    # Fall back to local changelog if remote is unavailable
    if [[ -z "$content" ]]; then
        content=$(<"$changelog")
    fi

    # Pre-process: mark the current version line with ★
    if [[ -n "$current_version" ]]; then
        local escaped="${current_version//./\\.}"
        content=$(printf '%s\n' "$content" | sed "s/^## \[${escaped}\]/& ★ current/")
    fi

    printf '%s\n' "$content" | _changelog_colorise | less -R
}

cmd_set() {
    while [[ $# -gt 0 ]]; do
        case "$1" in
            -h|--help) _help_set; return 0 ;;
            --)        shift; break ;;
            -*)        unknown_flag set "$1"; return $? ;;
            *)         break ;;
        esac
    done

    local target="${1:-}"
    local dir="${2:-}"

    if [[ -z "$target" ]]; then
        error "Missing argument: dev|projects"
        printf "  Run: ${CYAN}dotfiles help set${NC}\n" >&2
        return 2
    fi

    local var_name
    case "$target" in
        dev)      var_name="DEV_ROOT" ;;
        projects) var_name="PROJECTS_ROOT" ;;
        *)
            error "Unknown target: $target (use 'dev' or 'projects')"
            printf "  Run: ${CYAN}dotfiles help set${NC}\n" >&2
            return 2
            ;;
    esac

    if [[ -z "$dir" ]]; then
        error "Directory argument required"
        printf "  Run: ${CYAN}dotfiles help set${NC}\n" >&2
        return 2
    fi

    # Expand ~ and resolve to absolute path
    dir="${dir/#\~/$HOME}"
    if [[ -d "$dir" ]]; then
        dir=$(cd "$dir" && pwd)
    elif [[ -d "$(dirname "$dir")" ]]; then
        dir=$(cd "$(dirname "$dir")" && pwd)/$(basename "$dir")
    fi

    # Store with $HOME for portability
    local stored_value="\$HOME${dir#"$HOME"}"

    update_zshrc_export "$var_name" "$stored_value"

    success "$var_name set to $dir"
    printf "  ${GREY}Updated ~/.zshrc${NC}\n"
    echo ""
    info "Run 'source ~/.zshrc' or open a new shell to apply."
}

cmd_status() {
    while [[ $# -gt 0 ]]; do
        case "$1" in
            -h|--help) _help_status; return 0 ;;
            --)        shift; break ;;
            -*)        unknown_flag status "$1"; return $? ;;
            *)         unknown_flag status "$1"; return $? ;;
        esac
        shift
    done

    local preset remote_branch behind ahead version

    preset=$(get_preset)
    remote_branch=$(get_remote_branch)
    version=$(_changelog_local_version) || true

    print_logo
    print_header "Dotfiles Status"

    [[ -n "$version" ]] && printf "${CYAN}Version:${NC}   %s\n" "$(_format_version "$version")"

    local released updated
    released=$(_release_datetime "$version") || true
    updated=$(_last_update_datetime) || true
    [[ -n "$released" ]] && printf "${CYAN}Released:${NC}  %s\n" "$released"
    [[ -n "$updated" ]]  && printf "${CYAN}Updated:${NC}   %s\n" "$updated"

    printf "${CYAN}Preset:${NC}    %s\n" "$preset"
    local theme_file="${XDG_CONFIG_HOME:-$HOME/.config}/dotfiles/current-theme"
    [[ -f "$theme_file" ]] && printf "${CYAN}Theme:${NC}     %s\n" "$(<"$theme_file")"
    printf "${CYAN}Branch:${NC}    %s\n" "$(git -C "$DOTFILES_DIR" rev-parse --abbrev-ref HEAD)"
    printf "${CYAN}Path:${NC}      %s\n" "$DOTFILES_DIR"
    echo ""

    git -C "$DOTFILES_DIR" fetch origin --quiet 2>/dev/null || true

    behind=$(git -C "$DOTFILES_DIR" rev-list HEAD.."$remote_branch" --count 2>/dev/null) || behind=0
    ahead=$(git -C "$DOTFILES_DIR" rev-list "$remote_branch"..HEAD --count 2>/dev/null) || ahead=0

    if [[ $behind -eq 0 && $ahead -eq 0 ]]; then
        printf "  ${GREEN}✓${NC} Up-to-date with %s\n" "$remote_branch"
    else
        if [[ $behind -gt 0 ]]; then
            printf "  ${YELLOW}↓${NC} %d commit(s) behind %s\n" "$behind" "$remote_branch"
        fi
        if [[ $ahead -gt 0 ]]; then
            printf "  ${YELLOW}↑${NC} %d commit(s) ahead of %s\n" "$ahead" "$remote_branch"
        fi

        if [[ $behind -gt 0 ]]; then
            local incoming
            incoming=$(_changelog_incoming "$remote_branch") || true
            if [[ -n "$incoming" ]]; then
                echo ""
                printf "  ${CYAN}Incoming changes:${NC}\n"
                printf '%s\n' "$incoming" | _changelog_colorise | sed 's/^/  /'
                echo ""
                printf "  ${GREY}Run 'dotfiles update' to apply.${NC}\n"
            fi
        fi
    fi

    if [[ -n $(git -C "$DOTFILES_DIR" status --porcelain 2>/dev/null) ]]; then
        echo ""
        printf "  ${YELLOW}!${NC} Uncommitted local changes:\n"
        git -C "$DOTFILES_DIR" status --short | sed 's/^/    /'
    fi

    echo ""
}

cmd_sync() {
    local force=0
    while [[ $# -gt 0 ]]; do
        case "$1" in
            -h|--help)    _help_sync; return 0 ;;
            -f|--force)   force=1 ;;
            --)           shift; break ;;
            -*)           unknown_flag sync "$1"; return $? ;;
            *)            unknown_flag sync "$1"; return $? ;;
        esac
        shift
    done

    _copy_pairs
    local synced=0 skipped=0 missing=0

    for pair in "${COPY_PAIRS[@]}"; do
        local repo="${pair%%|*}" installed="${pair#*|}"
        local repo_path="$DOTFILES_DIR/$repo"

        [[ ! -f "$repo_path" ]] && continue

        if [[ ! -f "$installed" ]]; then
            mkdir -p "$(dirname "$installed")"
            /bin/cp "$repo_path" "$installed"
            success "Created $installed"
            synced=$((synced + 1))
            continue
        fi

        if diff -q "$repo_path" "$installed" &>/dev/null; then
            skipped=$((skipped + 1))
            continue
        fi

        if [[ $force -eq 1 ]]; then
            /bin/cp "$repo_path" "$installed"
            success "Updated $installed"
            synced=$((synced + 1))
        else
            printf "  ${YELLOW}differs${NC}  %s\n" "$repo"
            missing=$((missing + 1))
        fi
    done

    echo ""
    if [[ $synced -gt 0 ]]; then
        success "$synced file(s) synced"
    fi
    if [[ $skipped -gt 0 ]]; then
        printf "  ${GREY}%d file(s) already up to date${NC}\n" "$skipped"
    fi
    if [[ $missing -gt 0 ]]; then
        echo ""
        info "$missing file(s) differ — run 'dotfiles sync --force' to overwrite"
        info "Use 'dotfiles diff' to inspect changes"
    fi
    if [[ $synced -eq 0 ]] && [[ $missing -eq 0 ]]; then
        success "All copy-on-install files are in sync"
    fi
}

cmd_theme() {
    # Top-level --help is handled here. Subcommands (list, current, switch,
    # generate, delete) are delegated to scripts/theme-* — pass
    # DOTFILES_INVOKED_AS so child scripts render the user-facing parent name
    # in their help text.
    if [[ "${1:-}" == "-h" || "${1:-}" == "--help" ]]; then
        _help_theme
        return 0
    fi

    local theme_cmd="${1:-list}"
    shift || true

    case "$theme_cmd" in
        help)
            # `dotfiles theme help` (no further args) shows theme help.
            # `theme <sub> help` is intentionally NOT intercepted here so it
            # reaches the child script (theme-delete, theme-generate, etc.).
            if [[ $# -eq 0 ]]; then
                _help_theme
                return 0
            fi
            error "Unknown theme subcommand: help"
            printf "  Run: ${CYAN}dotfiles help theme${NC}\n" >&2
            return 2
            ;;
        list)
            "$DOTFILES_DIR/scripts/theme-switch" list
            ;;
        current)
            "$DOTFILES_DIR/scripts/theme-switch" current
            ;;
        switch)
            if [[ $# -eq 0 ]]; then
                error "'switch' requires a theme name"
                printf "  Run: ${CYAN}dotfiles help theme${NC}\n" >&2
                return 2
            fi
            DOTFILES_INVOKED_AS="dotfiles theme switch" \
                "$DOTFILES_DIR/scripts/theme-switch" "$@"
            ;;
        generate)
            DOTFILES_INVOKED_AS="dotfiles theme generate" \
                "$DOTFILES_DIR/scripts/generate-theme" "$@"
            ;;
        delete)
            DOTFILES_INVOKED_AS="dotfiles theme delete" \
                "$DOTFILES_DIR/scripts/theme-delete" "$@"
            ;;
        *)
            error "Unknown theme subcommand: $theme_cmd"
            printf "  Run: ${CYAN}dotfiles help theme${NC}\n" >&2
            return 2
            ;;
    esac
}

cmd_update() {
    local force=0 dry_run=0
    while [[ $# -gt 0 ]]; do
        case "$1" in
            -h|--help)    _help_update; return 0 ;;
            -f|--force)   force=1 ;;
            -p|--preview) dry_run=1 ;;
            --)           shift; break ;;
            -*)           unknown_flag update "$1"; return $? ;;
            *)            unknown_flag update "$1"; return $? ;;
        esac
        shift
    done

    local preset remote_branch local_branch

    cd "$DOTFILES_DIR"

    preset=$(get_preset)
    remote_branch=$(get_remote_branch)
    local_branch=$(git rev-parse --abbrev-ref HEAD)

    print_logo
    print_header "Dotfiles Update"

    printf "${CYAN}Preset:${NC}  %s\n" "$preset"
    printf "${CYAN}Branch:${NC}  %s (tracking %s)\n" "$local_branch" "$remote_branch"
    echo ""

    printf "  ${CYAN}→${NC} Fetching from origin...\n"
    git fetch origin --quiet

    local behind ahead
    behind=$(git rev-list HEAD.."$remote_branch" --count 2>/dev/null) || behind=0
    ahead=$(git rev-list "$remote_branch"..HEAD --count 2>/dev/null) || ahead=0

    if [[ $behind -eq 0 && $ahead -eq 0 ]]; then
        printf "  ${GREEN}✓${NC} Already up-to-date!\n"
        echo ""
        return 0
    fi

    if [[ $ahead -gt 0 ]]; then
        printf "  ${YELLOW}!${NC} You have %d unpushed commit(s)\n" "$ahead"
    fi

    if [[ $behind -eq 0 ]]; then
        echo ""
        return 0
    fi

    printf "  ${CYAN}→${NC} %d new commit(s) available\n" "$behind"

    local incoming
    incoming=$(_changelog_incoming "$remote_branch") || true
    if [[ -n "$incoming" ]]; then
        echo ""
        printf "  ${CYAN}What's new:${NC}\n"
        printf '%s\n' "$incoming" | _changelog_colorise | sed 's/^/  /'
    fi

    # ── Dry-run mode: show preview and exit ──
    if [[ $dry_run -eq 1 ]]; then
        echo ""
        printf "  ${CYAN}Changed files:${NC}\n"
        _preview_changed_files HEAD "$remote_branch"

        echo ""
        local would_skip=""
        if [[ $force -eq 0 ]]; then
            would_skip=$(_compute_skip_steps HEAD "$remote_branch")
        fi
        printf "  ${CYAN}Update steps:${NC}\n"
        _show_step_plan "$would_skip"

        _show_pending_migrations HEAD "$remote_branch"

        echo ""
        printf "  ${GREY}Run 'dotfiles update' to apply these changes.${NC}\n"
        echo ""
        return 0
    fi

    # ── Confirm before applying ──
    echo ""
    local response
    read -r -p "  Apply update? [Y/n] " response
    if [[ "$response" =~ ^[Nn]$ ]]; then
        printf "  ${GREY}Update cancelled.${NC}\n"
        return 0
    fi

    # ── Pull changes ──
    echo ""
    local old_head
    old_head=$(git rev-parse HEAD)

    printf "  ${CYAN}→${NC} Pulling changes...\n"
    git pull --ff-only --quiet origin "$local_branch" || {
        error "Pull failed. You may have local changes that conflict."
        echo "Try: cd $DOTFILES_DIR && git status"
        return 1
    }

    local new_head
    new_head=$(git rev-parse HEAD)

    # ── Run migrations ──
    _run_pending_migrations "$old_head" "$new_head"

    # ── Compute skip steps (unless --force) ──
    local skip_steps=""
    if [[ $force -eq 0 ]]; then
        skip_steps=$(_compute_skip_steps "$old_head" "$new_head")
    fi

    if [[ -n "$skip_steps" ]]; then
        printf "  ${GREY}Skipping unchanged: %s${NC}\n" "$skip_steps"
    fi

    echo ""

    local install_args=("--$preset" --skip-backup --update --yes)
    [[ -n "$skip_steps" ]] && install_args+=(--skip-steps "$skip_steps")

    if ! "$DOTFILES_DIR/install.sh" "${install_args[@]}"; then
        _print_update_notices
        error "Update failed — check output above"
        return 1
    fi

    _print_update_notices
}

cmd_version() {
    while [[ $# -gt 0 ]]; do
        case "$1" in
            -h|--help) _help_version; return 0 ;;
            --)        shift; break ;;
            -*)        unknown_flag version "$1"; return $? ;;
            *)         unknown_flag version "$1"; return $? ;;
        esac
        shift
    done

    local version
    version=$(_changelog_local_version) || true

    if [[ -z "$version" ]]; then
        error "Could not determine version from CHANGELOG.md"
        return 1
    fi

    print_logo

    printf "${CYAN}Version:${NC}  %s\n" "$(_format_version "$version")"

    local released updated
    released=$(_release_datetime "$version") || true
    updated=$(_last_update_datetime) || true
    [[ -n "$released" ]] && printf "${CYAN}Released:${NC} %s\n" "$released"
    [[ -n "$updated" ]]  && printf "${CYAN}Updated:${NC}  %s\n" "$updated"

    printf "${CYAN}Preset:${NC}   %s\n" "$(get_preset)"

    local theme_file="${XDG_CONFIG_HOME:-$HOME/.config}/dotfiles/current-theme"
    if [[ -f "$theme_file" ]]; then
        printf "${CYAN}Theme:${NC}    %s\n" "$(<"$theme_file")"
    fi

    printf "${CYAN}Branch:${NC}   %s\n" "$(git -C "$DOTFILES_DIR" rev-parse --abbrev-ref HEAD 2>/dev/null || echo "unknown")"
    printf "${CYAN}Path:${NC}     %s\n" "$DOTFILES_DIR"
    echo ""
}

