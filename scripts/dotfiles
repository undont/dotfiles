_help_main() {
    print_logo
    cat << 'EOF'
dotfiles — manage your dots

USAGE
  dotfiles <command> [options]    (shorthand: dot)
  dotfiles help <command>         Show detailed help for a command

COMMANDS
  update    -u    Pull latest and apply (incremental)
  status    -s    Version, sync status, local changes
  health          Run full health check
  set             Configure DEV_ROOT / PROJECTS_ROOT
  theme     -t    Manage colour themes
  links     -l    Show managed symlinks
  diff      -d    Show copy-on-install file diffs
  sync            Sync copy-on-install files from repo
  export          Export local layer to the private repo
  import          Import local layer from the private repo
  local           Manage the private local-layer repo
  aliases   -a    Show shell aliases and shortcuts
  notes     -n    Browse changelog in pager
  version   -v    Show version, dates, preset, theme
  edit      -e    Open dotfiles in $EDITOR
  cd              Print dotfiles path

For details on any command:
  dotfiles help <command>
  dotfiles <command> --help
EOF
}

# ─── Dispatcher ───────────────────────────────────────────────────────

main() {
    local cmd="${1:-help}"
    shift || true

    # Top-level shorthands
    case "$cmd" in
        --help|-h)    cmd=help ;;
        --version|-V) cmd=version ;;
    esac

    # Treat `dotfiles <cmd> help` as an alias for `dotfiles <cmd> --help`,
    # mirroring the existing `dotfiles help <cmd>` path. Skipped for the
    # `help` command itself (which already takes a topic) and for `theme`,
    # whose subcommand dispatcher delegates `help` to child scripts.
    if [[ "$cmd" != "help" && "$cmd" != "theme" && "$cmd" != "-t" && "${1:-}" == "help" ]]; then
        set -- "--help" "${@:2}"
    fi

    case "$cmd" in
        update|-u)              cmd_update    "$@" ;;
        status|-s)              cmd_status    "$@" ;;
        health)                 cmd_health    "$@" ;;
        set)                    cmd_set       "$@" ;;
        theme|-t)               cmd_theme     "$@" ;;
        links|-l)               cmd_links     "$@" ;;
        diff|-d)                cmd_diff      "$@" ;;
        sync)                   cmd_sync      "$@" ;;
        export)                 cmd_export    "$@" ;;
        import)                 cmd_import    "$@" ;;
        local)                  cmd_local     "$@" ;;
        aliases|alias|cheat|-a) cmd_aliases   "$@" ;;
        notes|-n)               cmd_notes     "$@" ;;
        version|-v)             cmd_version   "$@" ;;
        edit|-e)                cmd_edit      "$@" ;;
        cd)                     cmd_cd        "$@" ;;
        help)                   cmd_help      "$@" ;;
        *)
            error "Unknown command: $cmd"
            echo ""
            _help_main
            exit 1
            ;;
    esac
}

main "$@"
