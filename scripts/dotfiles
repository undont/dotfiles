_help_update() {
    cat << 'EOF'
dotfiles update — pull latest changes and apply incrementally

USAGE
  dotfiles update [OPTIONS]
  dotfiles -u

OPTIONS
  -f, --force    Re-run all installer steps regardless of changes
  -p, --preview  Show what would change without applying
  -h, --help     Show this help

EXAMPLES
  dotfiles update              # Smart incremental update
  dotfiles update --preview    # Preview without applying
  dotfiles update --force      # Force full re-run
