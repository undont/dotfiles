#!/usr/bin/env bash
# dotfiles — manage your dotfiles installation.
# For per-command details: dotfiles help <command>  (or: dotfiles <command> --help)

set -euo pipefail

# ─── Bootstrap ─────────────────────────────────────────────────────────

# Detect script location to find DOTFILES_DIR (resolve symlinks).
SCRIPT_PATH="${BASH_SOURCE[0]}"
while [[ -L "$SCRIPT_PATH" ]]; do
    SCRIPT_DIR="$(cd -P "$(dirname "$SCRIPT_PATH")" && pwd)"
    SCRIPT_PATH="$(readlink "$SCRIPT_PATH")"
    [[ "$SCRIPT_PATH" != /* ]] && SCRIPT_PATH="$SCRIPT_DIR/$SCRIPT_PATH"
done
SCRIPT_DIR="$(cd -P "$(dirname "$SCRIPT_PATH")" && pwd)"

# DOTFILES_DIR is the parent of scripts/.
DOTFILES_DIR="${DOTFILES_DIR:-$(dirname "$SCRIPT_DIR")}"

# common.sh must be sourced before cli.sh (cli.sh checks for the load guard).
# shellcheck disable=SC1091
source "$DOTFILES_DIR/scripts/_lib/common.sh"
# shellcheck disable=SC1091
source "$DOTFILES_DIR/scripts/_lib/cli.sh"

# ─── Flag-parsing helpers (dispatcher-internal) ────────────────────────

# Print "unknown flag" error and a hint to the per-command help.
unknown_flag() {
    local cmd="$1" flag="$2"
    error "Unknown option for '$cmd': $flag"
    printf "  Run: ${CYAN}dotfiles help %s${NC}\n" "$cmd" >&2
    return 2
}

# Print "missing argument" error and a hint to the per-command help.
missing_arg() {
    local cmd="$1" flag="$2"
    error "'$flag' requires an argument"
    printf "  Run: ${CYAN}dotfiles help %s${NC}\n" "$cmd" >&2
    return 2
}

# ─── Internal helpers (single-use, kept inline for locality) ───────────

# Compute which installer steps can be skipped based on changed files between
# two refs. Returns a comma-separated list (homebrew,packages,symlinks,keyd).
_compute_skip_steps() {
    local ref_from="$1" ref_to="$2"
    local changed_files
    changed_files=$(git -C "$DOTFILES_DIR" diff --name-only "$ref_from" "$ref_to" 2>/dev/null) || return 0

    local skippable=()

    # Brewfile not changed → skip homebrew + packages
    if ! printf '%s\n' "$changed_files" | grep -q '^Brewfile'; then
        skippable+=(homebrew packages)
    fi

    # No config/symlink-related files changed → skip symlinks
    local symlink_patterns='^scripts/install/create-symlinks\.sh|\.template$|^zsh/|^tmux/|^nvim/|^ghostty/|^hammerspoon/|^karabiner/|^launchers/|^lazygit/|^lazydocker/|^formatters/|^gh-dash/|^btop/|^themes/|^keyd/'
    if ! printf '%s\n' "$changed_files" | grep -qE "$symlink_patterns"; then
        skippable+=(symlinks)
    fi

    # keyd/ not changed → skip keyd (Linux only; macOS uses Karabiner)
    if is_linux && ! printf '%s\n' "$changed_files" | grep -q '^keyd/'; then
        skippable+=(keyd)
    fi

    local IFS=','
    printf '%s' "${skippable[*]}"
}

# Show changed files grouped by category for dry-run preview
_preview_changed_files() {
    local ref_from="$1" ref_to="$2"
    local changed_files
    changed_files=$(git -C "$DOTFILES_DIR" diff --name-only "$ref_from" "$ref_to" 2>/dev/null) || return 0

    [[ -z "$changed_files" ]] && return 0

    local -A categories=(
        [Brewfile/packages]="^Brewfile"
        [Zsh config]="^zsh/"
        [Tmux config]="^tmux/"
        [Neovim config]="^nvim/"
        [Ghostty config]="^ghostty/"
        [Theme definitions]="^themes/"
        [Installer/scripts]="^scripts/|^install\.sh"
        [Launchers]="^launchers/"
        [Hammerspoon]="^hammerspoon/"
        [Karabiner]="^karabiner/"
        [Keyd]="^keyd/"
        [LazyGit]="^lazygit/"
        [Documentation]="^docs/|^README|^CLAUDE|^CHANGELOG"
    )

    local -a order=(
        "Brewfile/packages" "Zsh config" "Tmux config" "Neovim config"
        "Ghostty config" "Theme definitions" "Launchers" "Hammerspoon"
        "Karabiner" "Keyd" "LazyGit" "Installer/scripts" "Documentation"
    )

    local shown_files=""
    for cat_name in "${order[@]}"; do
        local pattern="${categories[$cat_name]}"
        local matches
        matches=$(printf '%s\n' "$changed_files" | grep -E "$pattern" || true)
        if [[ -n "$matches" ]]; then
            printf "  ${CYAN}%s:${NC}\n" "$cat_name"
            printf '%s\n' "$matches" | sed 's/^/    /'
            shown_files+="$matches"$'\n'
        fi
    done

    # Show any uncategorised files
    local other
    other=$(printf '%s\n' "$changed_files" | grep -vE "$(IFS='|'; printf '%s' "${categories[*]}")" || true)
    if [[ -n "$other" ]]; then
        printf "  ${CYAN}Other:${NC}\n"
        printf '%s\n' "$other" | sed 's/^/    /'
    fi
}

# Show which update steps would run vs be skipped
_show_step_plan() {
    local skipped="$1"
    # Only skippable steps are listed. Omitted steps always run:
    #   4 (backup) — controlled by --skip-backup, not --skip-steps
    #   9 (secrets), 11 (save preset), 12 (project dirs) — always run, non-skippable
    local -a all_steps=(
        "1:homebrew:Check Homebrew"
        "2:packages:Update packages"
        "3:prerequisites:Check prerequisites"
        "5:symlinks:Update symlinks"
        "6:plugins:Check plugin managers"
        "7:keyd:Update keyd config"
        "8:shell:Check default shell"
        "10:health:Run health check"
    )

    for step_info in "${all_steps[@]}"; do
        local num="${step_info%%:*}"
        local rest="${step_info#*:}"
        local name="${rest%%:*}"
        local label="${rest#*:}"

        if [[ ",$skipped," == *",$name,"* ]]; then
            printf "    ${GREY}%2s. %s (unchanged — skip)${NC}\n" "$num" "$label"
        else
            printf "    ${GREEN}%2s. %s${NC}\n" "$num" "$label"
        fi
    done
}

# Run pending migration scripts between two versions
_run_pending_migrations() {
    local old_head="$1" new_head="$2"
    local migrations_dir="$DOTFILES_DIR/scripts/migrations"
    local applied_file="$STATE_DIR/migrations"

    [[ -d "$migrations_dir" ]] || return 0

    local old_version new_version
    old_version=$(_changelog_version_at_ref "$old_head") || {
        if git -C "$DOTFILES_DIR" rev-parse --verify "$old_head" &>/dev/null; then
            warn "Could not extract version from CHANGELOG.md at $old_head — skipping migrations"
        fi
        return 0
    }
    new_version=$(_changelog_version_at_ref "$new_head") || {
        if git -C "$DOTFILES_DIR" rev-parse --verify "$new_head" &>/dev/null; then
            warn "Could not extract version from CHANGELOG.md at $new_head — skipping migrations"
        fi
        return 0
    }

    [[ -z "$old_version" || -z "$new_version" ]] && return 0

    mkdir -p "$STATE_DIR"
    touch "$applied_file"

    local found_any=false
    local migration
    for migration in "$migrations_dir"/*.sh; do
        [[ -f "$migration" ]] || continue
        local basename="${migration##*/}"
        local migration_version="${basename%%-*}"

        grep -qxF "$basename" "$applied_file" && continue

        if ! _version_gt "$migration_version" "$old_version"; then
            continue
        fi
        if _version_gt "$migration_version" "$new_version"; then
            continue
        fi

        if [[ "$found_any" == false ]]; then
            printf "  ${CYAN}→${NC} Running migrations...\n"
            found_any=true
        fi

        printf "    ${CYAN}•${NC} %s\n" "$basename"
        if bash "$migration"; then
            echo "$basename" >> "$applied_file"
        else
            warn "Migration $basename failed (continuing)"
        fi
    done
}

# Show pending migrations for dry-run preview
_show_pending_migrations() {
    local ref_from="$1" ref_to="$2"
    local migrations_dir="$DOTFILES_DIR/scripts/migrations"
    local applied_file="$STATE_DIR/migrations"

    [[ -d "$migrations_dir" ]] || return 0

    local old_version new_version
    old_version=$(_changelog_version_at_ref "$ref_from") || return 0
    new_version=$(_changelog_version_at_ref "$ref_to") || return 0

    [[ -z "$old_version" || -z "$new_version" ]] && return 0

    local remote_migrations
    remote_migrations=$(git -C "$DOTFILES_DIR" ls-tree --name-only "$ref_to" scripts/migrations/ 2>/dev/null | grep '\.sh$' || true)

    [[ -z "$remote_migrations" ]] && return 0

    touch "$applied_file" 2>/dev/null || true

    local pending=()
    while IFS= read -r path; do
        [[ -z "$path" ]] && continue
        local basename="${path##*/}"
        local migration_version="${basename%%-*}"

        grep -qxF "$basename" "$applied_file" 2>/dev/null && continue

        if _version_gt "$migration_version" "$old_version" && ! _version_gt "$migration_version" "$new_version"; then
            pending+=("$basename")
        fi
    done <<< "$remote_migrations"

    if [[ ${#pending[@]} -gt 0 ]]; then
        echo ""
        printf "  ${CYAN}Pending migrations:${NC}\n"
        for m in "${pending[@]}"; do
            printf "    ${CYAN}•${NC} %s\n" "$m"
        done
    fi
}

# Build the copy-on-install pairs array (shared by diff and sync)
_copy_pairs() {
    COPY_PAIRS=(
        "btop/btop.conf|$HOME/.config/btop/btop.conf"
        "karabiner/karabiner.json|$HOME/.config/karabiner/karabiner.json"
    )
    if is_macos; then
        COPY_PAIRS+=("lazydocker/config.yml|$HOME/Library/Application Support/lazydocker/config.yml")
    else
        COPY_PAIRS+=("lazydocker/config.yml|$HOME/.config/lazydocker/config.yml")
    fi
}

# Render a single managed-symlink row for cmd_links, mutating the outer
# ok / broken / absent / file_exists counters.
_check_link() {
    local dest="$1"
    local label="${dest/#"$HOME"/\~}"

    if [[ -L "$dest" ]]; then
        if [[ -e "$dest" ]]; then
            printf "  ${GREEN}OK${NC}      %s  ${GREY}→ %s${NC}\n" "$label" "$(readlink "$dest")"
            ok=$(( ok + 1 ))
        else
            printf "  ${RED}BROKEN${NC}  %s  ${GREY}→ %s${NC}\n" "$label" "$(readlink "$dest")"
            broken=$(( broken + 1 ))
        fi
    elif [[ -e "$dest" ]]; then
        printf "  ${YELLOW}FILE${NC}    %s  ${GREY}(exists but not a symlink)${NC}\n" "$label"
        file_exists=$(( file_exists + 1 ))
    else
        printf "  ${YELLOW}ABSENT${NC}  %s\n" "$label"
        absent=$(( absent + 1 ))
    fi
}

# ─── Commands (cmd_*) ─────────────────────────────────────────────────

# Cheatsheet renderer. The static section/entry data is parsed from
# zsh/dotfiles.zsh — see _aliases_parse for the source conventions.
cmd_aliases() {
    while [[ $# -gt 0 ]]; do
        case "$1" in
            -h|--help) _help_aliases; return 0 ;;
            --)        shift; break ;;
            -*)        unknown_flag aliases "$1"; return $? ;;
            *)         unknown_flag aliases "$1"; return $? ;;
        esac
        shift
    done

    local source_file="$DOTFILES_DIR/zsh/dotfiles.zsh"
    if [[ ! -f "$source_file" ]]; then
        error "Shell source not found: $source_file"
        return 1
    fi

    local BOLD='\033[1m'

    printf "${BOLD}SHELL REFERENCE${NC}\n"
    printf '%0.s─' {1..80}; printf '\n'

    # Parser emits tab-separated records:
    #   SECTION<tab><name>            — start a new section (flush pending pair first)
    #   ENTRY<tab><name><tab><desc>   — emit a row in the current section
    while IFS=$'\t' read -r kind a b; do
        case "$kind" in
            SECTION)
                _aliases_flush_pending
                printf "\n${CYAN}%s${NC}\n" "$a"
                ;;
            ENTRY)
                _aliases_emit "$a" "$b"
                ;;
        esac
    done < <(_aliases_parse "$source_file")
    _aliases_flush_pending

    _aliases_render_zshrc

    printf '\n'
    printf '%0.s─' {1..80}; printf '\n'
    printf "${GREEN}Tip:${NC} run ${YELLOW}dotfiles help${NC} for CLI usage, ${YELLOW}dotfiles health${NC} to verify your install.\n\n"
}

# Parse the shell source and emit SECTION/ENTRY records.
# Conventions (in zsh/dotfiles.zsh):
#   "# @section: <Name>"                       → SECTION (display name, uppercased)
#   "alias <name>=\"...\"  # <description>"    → ENTRY (alias name + trailing description)
#   "# @cheat: <name> | <description>"         → ENTRY (free-form name + description)
#   "# @cheat: <description>" then "name() {"  → ENTRY (function name + directive description)
# Aliases without a trailing description comment are skipped — the cheatsheet is curated.
_aliases_parse() {
    local file="$1"
    awk '
        # Section header: "# @section: <Name>"
        /^# @section: / {
            name = substr($0, 13)
            sub(/^[[:space:]]+/, "", name)
            sub(/[[:space:]]+$/, "", name)
            print "SECTION\t" toupper(name)
            pending_cheat = ""
            next
        }

        # Free-form cheat row: "# @cheat: <name> | <description>"
        # Splits on the FIRST "|" only (descriptions may contain "|").
        /^# @cheat:.*\|/ {
            line = substr($0, 10)
            sub(/^[[:space:]]+/, "", line)
            if (match(line, /[[:space:]]*\|[[:space:]]*/)) {
                name = substr(line, 1, RSTART - 1)
                desc = substr(line, RSTART + RLENGTH)
                sub(/[[:space:]]+$/, "", name)
                sub(/[[:space:]]+$/, "", desc)
                print "ENTRY\t" name "\t" desc
            }
            pending_cheat = ""
            next
        }

        # Function-attached cheat directive: "# @cheat: <description>"
        /^# @cheat: / {
            pending_cheat = substr($0, 10)
            sub(/^[[:space:]]+/, "", pending_cheat)
            next
        }

        # Function definition (with or without "function" keyword).
        # Pairs with the preceding pending_cheat.
        /^(function )?[a-zA-Z_][a-zA-Z0-9_-]*\(\)[[:space:]]*\{/ {
            if (pending_cheat != "") {
                fname = $0
                sub(/^function /, "", fname)
                sub(/\(\).*/, "", fname)
                print "ENTRY\t" fname "\t" pending_cheat
            }
            pending_cheat = ""
            next
        }

        # Alias definition with trailing description comment.
        # Match a closing quote followed by whitespace then "# <desc>".
        # Leading whitespace allowed (handles aliases inside if/else blocks).
        /^[[:space:]]*alias [a-zA-Z_][a-zA-Z0-9_-]*=/ {
            name = $0
            sub(/^[[:space:]]*alias /, "", name)
            sub(/=.*/, "", name)

            desc = $0
            if (match(desc, /"[[:space:]]+#[[:space:]]*/)) {
                desc = substr(desc, RSTART + RLENGTH)
            } else if (match(desc, /'\''[[:space:]]+#[[:space:]]*/)) {
                desc = substr(desc, RSTART + RLENGTH)
            } else {
                pending_cheat = ""
                next
            }
            sub(/[[:space:]]+$/, "", desc)
            print "ENTRY\t" name "\t" desc
            pending_cheat = ""
            next
        }

        # Any other non-comment, non-blank line clears pending_cheat so the
        # directive only attaches to the immediately following function.
        /^[^#[:space:]]/ { pending_cheat = "" }
    ' "$file"
}

# Two-column emit: buffers one pair, flushes when paired.
_ALIASES_PENDING_NAME=""
_ALIASES_PENDING_DESC=""

_aliases_emit() {
    local name="$1" desc="$2"
    if [[ -z "$_ALIASES_PENDING_NAME" ]]; then
        _ALIASES_PENDING_NAME="$name"
        _ALIASES_PENDING_DESC="$desc"
        return
    fi
    printf "  ${YELLOW}%-12s${NC} ${GREY}%-22s${NC}  ${GREY}│${NC}  ${YELLOW}%-12s${NC} ${GREY}%s${NC}\n" \
        "$_ALIASES_PENDING_NAME" "$_ALIASES_PENDING_DESC" "$name" "$desc"
    _ALIASES_PENDING_NAME=""
    _ALIASES_PENDING_DESC=""
}

_aliases_flush_pending() {
    if [[ -n "$_ALIASES_PENDING_NAME" ]]; then
        printf "  ${YELLOW}%-12s${NC} ${GREY}%s${NC}\n" \
            "$_ALIASES_PENDING_NAME" "$_ALIASES_PENDING_DESC"
        _ALIASES_PENDING_NAME=""
        _ALIASES_PENDING_DESC=""
    fi
}

# Render dynamic sections (project dirs + user aliases from ~/.zshrc).
_aliases_render_zshrc() {
    local zshrc="$HOME/.zshrc"
    [[ -f "$zshrc" ]] || return 0

    local dev_root projects_root
    dev_root=$(grep -E '^\s*export\s+DEV_ROOT=' "$zshrc" 2>/dev/null \
        | head -1 | sed 's/.*=//; s/^"//; s/"$//' || true)
    projects_root=$(grep -E '^\s*export\s+PROJECTS_ROOT=' "$zshrc" 2>/dev/null \
        | head -1 | sed 's/.*=//; s/^"//; s/"$//' || true)
    if [[ -n "$dev_root" || -n "$projects_root" ]]; then
        printf "\n${CYAN}DOTFILES DIRECTORIES${NC}  ${GREY}(set via dotfiles set)${NC}\n"
        [[ -n "$dev_root" ]]      && printf "  ${YELLOW}%-14s${NC} ${GREY}%s${NC}\n" "DEV_ROOT" "$dev_root"
        [[ -n "$projects_root" ]] && printf "  ${YELLOW}%-14s${NC} ${GREY}%s${NC}\n" "PROJECTS_ROOT" "$projects_root"
    fi

    local user_aliases
    user_aliases=$(grep -E '^\s*alias\s+' "$zshrc" 2>/dev/null \
        | sed 's/^[[:space:]]*alias[[:space:]]*//' || true)
    if [[ -n "$user_aliases" ]]; then
        printf "\n${CYAN}USER ALIASES${NC}  ${GREY}(~/.zshrc)${NC}\n"
        while IFS= read -r line; do
            local name="${line%%=*}"
            local value="${line#*=}"
            value="${value%%[[:space:]]# *}"
            local trailing="${value##*[^[:space:]]}"
            value="${value%"$trailing"}"
            value="${value#[\"\']}"
            value="${value%[\"\']}"
            printf "  ${YELLOW}%-14s${NC} ${GREY}%s${NC}\n" "$name" "$value"
        done <<< "$user_aliases"
    fi
}

cmd_cd() {
    while [[ $# -gt 0 ]]; do
        case "$1" in
            -h|--help) _help_cd; return 0 ;;
            --)        shift; break ;;
            -*)        unknown_flag cd "$1"; return $? ;;
            *)         unknown_flag cd "$1"; return $? ;;
        esac
        shift
    done
    echo "$DOTFILES_DIR"
}

cmd_diff() {
    while [[ $# -gt 0 ]]; do
        case "$1" in
            -h|--help) _help_diff; return 0 ;;
            --)        shift; break ;;
            -*)        unknown_flag diff "$1"; return $? ;;
            *)         unknown_flag diff "$1"; return $? ;;
        esac
        shift
    done

    local found=0
    _copy_pairs

    for pair in "${COPY_PAIRS[@]}"; do
        local repo="${pair%%|*}" installed="${pair#*|}"
        [[ ! -f "$installed" ]] && continue
        local repo_path="$DOTFILES_DIR/$repo"
        [[ ! -f "$repo_path" ]] && continue
        if ! diff -q "$repo_path" "$installed" &>/dev/null; then
            found=1
            echo ""
            printf "${CYAN}%s${NC} vs ${YELLOW}%s${NC}\n" "$repo" "$installed"
            diff --color=auto -u "$repo_path" "$installed" || true
        fi
    done

    if [[ $found -eq 0 ]]; then
        success "All copy-on-install files match repo versions"
    fi
}

cmd_edit() {
    while [[ $# -gt 0 ]]; do
        case "$1" in
            -h|--help) _help_edit; return 0 ;;
            --)        shift; break ;;
            -*)        unknown_flag edit "$1"; return $? ;;
            *)         unknown_flag edit "$1"; return $? ;;
        esac
        shift
    done
    cd "$DOTFILES_DIR"
    ${EDITOR:-vim} .
}

cmd_health() {
    while [[ $# -gt 0 ]]; do
        case "$1" in
            -h|--help) _help_health; return 0 ;;
            --)        shift; break ;;
            -*)        unknown_flag health "$1"; return $? ;;
            *)         unknown_flag health "$1"; return $? ;;
        esac
        shift
    done
    "$DOTFILES_DIR/scripts/install/health-check.sh"
}

cmd_help() {
    local topic="${1:-}"
    if [[ -z "$topic" ]]; then
        _help_main
        return 0
    fi
    # Resolve aliases / short flags to canonical names
    case "$topic" in
        -u) topic="update" ;;
        -s) topic="status" ;;
        -t) topic="theme" ;;
        -l) topic="links" ;;
        -d) topic="diff" ;;
        -a) topic="aliases" ;;
        -n) topic="notes" ;;
        -v) topic="version" ;;
        -e) topic="edit" ;;
    esac
    local fn="_help_${topic//-/_}"
    if declare -F "$fn" >/dev/null; then
        "$fn"
    else
        error "No help available for: $topic"
        echo ""
        _help_main
        return 1
    fi
}

cmd_links() {
    while [[ $# -gt 0 ]]; do
        case "$1" in
            -h|--help) _help_links; return 0 ;;
            --)        shift; break ;;
            -*)        unknown_flag links "$1"; return $? ;;
            *)         unknown_flag links "$1"; return $? ;;
        esac
        shift
    done

    local preset
    preset=$(get_preset)

    local ok=0 broken=0 absent=0 file_exists=0

    print_logo
    print_header "Managed Symlinks"
    printf "${CYAN}Preset:${NC} %s\n\n" "$preset"

    # Zsh (minimal)
    printf "${CYAN}Zsh${NC}\n"
    _check_link "$HOME/.zprofile"
    _check_link "$HOME/.p10k.zsh"

    # Tmux (minimal)
    printf "\n${CYAN}Tmux${NC}\n"
    _check_link "$HOME/.tmux"
    _check_link "$HOME/.tmux.conf"

    # CLI (minimal)
    printf "\n${CYAN}CLI${NC}\n"
    _check_link "$HOME/.local/bin/dotfiles"

    # Formatters
    printf "\n${CYAN}Formatters${NC}\n"
    _check_link "$HOME/.prettierrc"
    _check_link "$HOME/.editorconfig"

    # Neovim (core)
    if should_install "core"; then
        printf "\n${CYAN}Neovim${NC}\n"
        _check_link "$HOME/.config/nvim"
    fi

    # gh-dash (core) — config is generated, not symlinked
    if should_install "core"; then
        printf "\n${CYAN}gh-dash${NC}\n"
        _check_link "$HOME/.local/bin/dash-repo-sync"
    fi

    # Launchers (core)
    if should_install "core"; then
        printf "\n${CYAN}Launchers${NC}\n"
        _check_link "$HOME/.local/launchers/dev"
    fi

    # LazyGit (core)
    if should_install "core"; then
        printf "\n${CYAN}LazyGit${NC}\n"
        _check_link "$HOME/.config/lazygit/config.yml"
    fi

    # Hammerspoon (full)
    if should_install "full"; then
        printf "\n${CYAN}Hammerspoon${NC}\n"
        _check_link "$HOME/.hammerspoon/init.lua"
    fi

    # Summary
    local total=$(( ok + broken + absent + file_exists ))
    echo ""
    printf "${GREEN}%d OK${NC}  ${RED}%d broken${NC}  ${YELLOW}%d absent${NC}  ${YELLOW}%d file${NC}  (%d total)\n" \
        "$ok" "$broken" "$absent" "$file_exists" "$total"
    echo ""
}

cmd_notes() {
    while [[ $# -gt 0 ]]; do
        case "$1" in
            -h|--help) _help_notes; return 0 ;;
            --)        shift; break ;;
            -*)        unknown_flag notes "$1"; return $? ;;
            *)         unknown_flag notes "$1"; return $? ;;
        esac
        shift
    done

    local changelog="$DOTFILES_DIR/CHANGELOG.md"
    if [[ ! -f "$changelog" ]]; then
        error "CHANGELOG.md not found"
        return 1
    fi

    local current_version
    current_version=$(_changelog_local_version) || true

    # Try to show the remote changelog so users can see unreceived changes
    local content=""
    git -C "$DOTFILES_DIR" fetch origin --quiet 2>/dev/null || true
    local remote_branch
    remote_branch=$(get_remote_branch)
    content=$(git -C "$DOTFILES_DIR" show "$remote_branch:CHANGELOG.md" 2>/dev/null) || content=""

    # Fall back to local changelog if remote is unavailable
    if [[ -z "$content" ]]; then
        content=$(<"$changelog")
    fi

    # Pre-process: mark the current version line with ★
    if [[ -n "$current_version" ]]; then
        local escaped="${current_version//./\\.}"
        content=$(printf '%s\n' "$content" | sed "s/^## \[${escaped}\]/& ★ current/")
    fi

    printf '%s\n' "$content" | _changelog_colorise | less -R
}

cmd_set() {
    while [[ $# -gt 0 ]]; do
        case "$1" in
            -h|--help) _help_set; return 0 ;;
            --)        shift; break ;;
            -*)        unknown_flag set "$1"; return $? ;;
            *)         break ;;
        esac
    done

    local target="${1:-}"
    local dir="${2:-}"

    if [[ -z "$target" ]]; then
        error "Missing argument: dev|projects"
        printf "  Run: ${CYAN}dotfiles help set${NC}\n" >&2
        return 2
    fi

    local var_name
    case "$target" in
        dev)      var_name="DEV_ROOT" ;;
        projects) var_name="PROJECTS_ROOT" ;;
        *)
            error "Unknown target: $target (use 'dev' or 'projects')"
            printf "  Run: ${CYAN}dotfiles help set${NC}\n" >&2
            return 2
            ;;
    esac

    if [[ -z "$dir" ]]; then
        error "Directory argument required"
        printf "  Run: ${CYAN}dotfiles help set${NC}\n" >&2
        return 2
    fi

    # Expand ~ and resolve to absolute path
    dir="${dir/#\~/$HOME}"
    if [[ -d "$dir" ]]; then
        dir=$(cd "$dir" && pwd)
    elif [[ -d "$(dirname "$dir")" ]]; then
        dir=$(cd "$(dirname "$dir")" && pwd)/$(basename "$dir")
    fi

    # Store with $HOME for portability
    local stored_value="\$HOME${dir#"$HOME"}"

    update_zshrc_export "$var_name" "$stored_value"

    success "$var_name set to $dir"
    printf "  ${GREY}Updated ~/.zshrc${NC}\n"
    echo ""
    info "Run 'source ~/.zshrc' or open a new shell to apply."
}

cmd_status() {
    while [[ $# -gt 0 ]]; do
        case "$1" in
            -h|--help) _help_status; return 0 ;;
            --)        shift; break ;;
            -*)        unknown_flag status "$1"; return $? ;;
            *)         unknown_flag status "$1"; return $? ;;
        esac
        shift
    done

    local preset remote_branch behind ahead version

    preset=$(get_preset)
    remote_branch=$(get_remote_branch)
    version=$(_changelog_local_version) || true

    print_logo
    print_header "Dotfiles Status"

    [[ -n "$version" ]] && printf "${CYAN}Version:${NC}   %s\n" "$(_format_version "$version")"
    printf "${CYAN}Preset:${NC}    %s\n" "$preset"
    local theme_file="${XDG_CONFIG_HOME:-$HOME/.config}/dotfiles/current-theme"
    [[ -f "$theme_file" ]] && printf "${CYAN}Theme:${NC}     %s\n" "$(<"$theme_file")"
    printf "${CYAN}Branch:${NC}    %s\n" "$(git -C "$DOTFILES_DIR" rev-parse --abbrev-ref HEAD)"
    printf "${CYAN}Path:${NC}      %s\n" "$DOTFILES_DIR"
    echo ""

    git -C "$DOTFILES_DIR" fetch origin --quiet 2>/dev/null || true

    behind=$(git -C "$DOTFILES_DIR" rev-list HEAD.."$remote_branch" --count 2>/dev/null) || behind=0
    ahead=$(git -C "$DOTFILES_DIR" rev-list "$remote_branch"..HEAD --count 2>/dev/null) || ahead=0

    if [[ $behind -eq 0 && $ahead -eq 0 ]]; then
        printf "  ${GREEN}✓${NC} Up-to-date with %s\n" "$remote_branch"
    else
        if [[ $behind -gt 0 ]]; then
            printf "  ${YELLOW}↓${NC} %d commit(s) behind %s\n" "$behind" "$remote_branch"
        fi
        if [[ $ahead -gt 0 ]]; then
            printf "  ${YELLOW}↑${NC} %d commit(s) ahead of %s\n" "$ahead" "$remote_branch"
        fi

        if [[ $behind -gt 0 ]]; then
            local incoming
            incoming=$(_changelog_incoming "$remote_branch") || true
            if [[ -n "$incoming" ]]; then
                echo ""
                printf "  ${CYAN}Incoming changes:${NC}\n"
                printf '%s\n' "$incoming" | _changelog_colorise | sed 's/^/  /'
                echo ""
                printf "  ${GREY}Run 'dotfiles update' to apply.${NC}\n"
            fi
        fi
    fi

    if [[ -n $(git -C "$DOTFILES_DIR" status --porcelain 2>/dev/null) ]]; then
        echo ""
        printf "  ${YELLOW}!${NC} Uncommitted local changes:\n"
        git -C "$DOTFILES_DIR" status --short | sed 's/^/    /'
    fi

    echo ""
}

cmd_sync() {
    local force=0
    while [[ $# -gt 0 ]]; do
        case "$1" in
            -h|--help)    _help_sync; return 0 ;;
            -f|--force)   force=1 ;;
            --)           shift; break ;;
            -*)           unknown_flag sync "$1"; return $? ;;
            *)            unknown_flag sync "$1"; return $? ;;
        esac
        shift
    done

    _copy_pairs
    local synced=0 skipped=0 missing=0

    for pair in "${COPY_PAIRS[@]}"; do
        local repo="${pair%%|*}" installed="${pair#*|}"
        local repo_path="$DOTFILES_DIR/$repo"

        [[ ! -f "$repo_path" ]] && continue

        if [[ ! -f "$installed" ]]; then
            mkdir -p "$(dirname "$installed")"
            /bin/cp "$repo_path" "$installed"
            success "Created $installed"
            synced=$((synced + 1))
            continue
        fi

        if diff -q "$repo_path" "$installed" &>/dev/null; then
            skipped=$((skipped + 1))
            continue
        fi

        if [[ $force -eq 1 ]]; then
            /bin/cp "$repo_path" "$installed"
            success "Updated $installed"
            synced=$((synced + 1))
        else
            printf "  ${YELLOW}differs${NC}  %s\n" "$repo"
            missing=$((missing + 1))
        fi
    done

    echo ""
    if [[ $synced -gt 0 ]]; then
        success "$synced file(s) synced"
    fi
    if [[ $skipped -gt 0 ]]; then
        printf "  ${GREY}%d file(s) already up to date${NC}\n" "$skipped"
    fi
    if [[ $missing -gt 0 ]]; then
        echo ""
        info "$missing file(s) differ — run 'dotfiles sync --force' to overwrite"
        info "Use 'dotfiles diff' to inspect changes"
    fi
    if [[ $synced -eq 0 ]] && [[ $missing -eq 0 ]]; then
        success "All copy-on-install files are in sync"
    fi
}

cmd_theme() {
    # Top-level --help is handled here. Subcommands (list, current, generate,
    # delete, <theme>) are delegated to scripts/theme-* — pass DOTFILES_INVOKED_AS
    # so child scripts render the user-facing parent name in their help text.
    if [[ "${1:-}" == "-h" || "${1:-}" == "--help" ]]; then
        _help_theme
        return 0
    fi

    local theme_cmd="${1:-list}"
    shift || true

    case "$theme_cmd" in
        list)
            "$DOTFILES_DIR/scripts/theme-switch" list
            ;;
        current)
            "$DOTFILES_DIR/scripts/theme-switch" current
            ;;
        generate)
            DOTFILES_INVOKED_AS="dotfiles theme generate" \
                "$DOTFILES_DIR/scripts/generate-theme" "$@"
            ;;
        delete)
            DOTFILES_INVOKED_AS="dotfiles theme delete" \
                "$DOTFILES_DIR/scripts/theme-delete" "$@"
            ;;
        *)
            "$DOTFILES_DIR/scripts/theme-switch" "$theme_cmd"
            ;;
    esac
}

cmd_update() {
    local force=0 dry_run=0
    while [[ $# -gt 0 ]]; do
        case "$1" in
            -h|--help)    _help_update; return 0 ;;
            -f|--force)   force=1 ;;
            -p|--preview) dry_run=1 ;;
            --)           shift; break ;;
            -*)           unknown_flag update "$1"; return $? ;;
            *)            unknown_flag update "$1"; return $? ;;
        esac
        shift
    done

    local preset remote_branch local_branch

    cd "$DOTFILES_DIR"

    preset=$(get_preset)
    remote_branch=$(get_remote_branch)
    local_branch=$(git rev-parse --abbrev-ref HEAD)

    print_logo
    print_header "Dotfiles Update"

    printf "${CYAN}Preset:${NC}  %s\n" "$preset"
    printf "${CYAN}Branch:${NC}  %s (tracking %s)\n" "$local_branch" "$remote_branch"
    echo ""

    printf "  ${CYAN}→${NC} Fetching from origin...\n"
    git fetch origin --quiet

    local behind ahead
    behind=$(git rev-list HEAD.."$remote_branch" --count 2>/dev/null) || behind=0
    ahead=$(git rev-list "$remote_branch"..HEAD --count 2>/dev/null) || ahead=0

    if [[ $behind -eq 0 && $ahead -eq 0 ]]; then
        printf "  ${GREEN}✓${NC} Already up-to-date!\n"
        echo ""
        return 0
    fi

    if [[ $ahead -gt 0 ]]; then
        printf "  ${YELLOW}!${NC} You have %d unpushed commit(s)\n" "$ahead"
    fi

    if [[ $behind -eq 0 ]]; then
        echo ""
        return 0
    fi

    printf "  ${CYAN}→${NC} %d new commit(s) available\n" "$behind"

    local incoming
    incoming=$(_changelog_incoming "$remote_branch") || true
    if [[ -n "$incoming" ]]; then
        echo ""
        printf "  ${CYAN}What's new:${NC}\n"
        printf '%s\n' "$incoming" | _changelog_colorise | sed 's/^/  /'
    fi

    # ── Dry-run mode: show preview and exit ──
    if [[ $dry_run -eq 1 ]]; then
        echo ""
        printf "  ${CYAN}Changed files:${NC}\n"
        _preview_changed_files HEAD "$remote_branch"

        echo ""
        local would_skip=""
        if [[ $force -eq 0 ]]; then
            would_skip=$(_compute_skip_steps HEAD "$remote_branch")
        fi
        printf "  ${CYAN}Update steps:${NC}\n"
        _show_step_plan "$would_skip"

        _show_pending_migrations HEAD "$remote_branch"

        echo ""
        printf "  ${GREY}Run 'dotfiles update' to apply these changes.${NC}\n"
        echo ""
        return 0
    fi

    # ── Confirm before applying ──
    echo ""
    local response
    read -r -p "  Apply update? [Y/n] " response
    if [[ "$response" =~ ^[Nn]$ ]]; then
        printf "  ${GREY}Update cancelled.${NC}\n"
        return 0
    fi

    # ── Pull changes ──
    echo ""
    local old_head
    old_head=$(git rev-parse HEAD)

    printf "  ${CYAN}→${NC} Pulling changes...\n"
    git pull --ff-only --quiet origin "$local_branch" || {
        error "Pull failed. You may have local changes that conflict."
        echo "Try: cd $DOTFILES_DIR && git status"
        return 1
    }

    local new_head
    new_head=$(git rev-parse HEAD)

    # ── Run migrations ──
    _run_pending_migrations "$old_head" "$new_head"

    # ── Compute skip steps (unless --force) ──
    local skip_steps=""
    if [[ $force -eq 0 ]]; then
        skip_steps=$(_compute_skip_steps "$old_head" "$new_head")
    fi

    if [[ -n "$skip_steps" ]]; then
        printf "  ${GREY}Skipping unchanged: %s${NC}\n" "$skip_steps"
    fi

    echo ""

    local install_args=("--$preset" --skip-backup --update --yes)
    [[ -n "$skip_steps" ]] && install_args+=(--skip-steps "$skip_steps")

    if ! "$DOTFILES_DIR/install.sh" "${install_args[@]}"; then
        error "Update failed — check output above"
        return 1
    fi
}

cmd_version() {
    while [[ $# -gt 0 ]]; do
        case "$1" in
            -h|--help) _help_version; return 0 ;;
            --)        shift; break ;;
            -*)        unknown_flag version "$1"; return $? ;;
            *)         unknown_flag version "$1"; return $? ;;
        esac
        shift
    done

    local version
    version=$(_changelog_local_version) || true

    if [[ -z "$version" ]]; then
        error "Could not determine version from CHANGELOG.md"
        return 1
    fi

    print_logo

    printf "${CYAN}Version:${NC}  %s\n" "$(_format_version "$version")"
    printf "${CYAN}Preset:${NC}   %s\n" "$(get_preset)"

    local theme_file="${XDG_CONFIG_HOME:-$HOME/.config}/dotfiles/current-theme"
    if [[ -f "$theme_file" ]]; then
        printf "${CYAN}Theme:${NC}    %s\n" "$(<"$theme_file")"
    fi

    printf "${CYAN}Branch:${NC}   %s\n" "$(git -C "$DOTFILES_DIR" rev-parse --abbrev-ref HEAD 2>/dev/null || echo "unknown")"
    printf "${CYAN}Path:${NC}     %s\n" "$DOTFILES_DIR"
    echo ""
}

# ─── Per-command help (_help_*) ───────────────────────────────────────

_help_aliases() {
    cat << 'EOF'
dotfiles aliases — show all shell aliases, functions, and shortcuts

USAGE
  dotfiles aliases [OPTIONS]
  dot a            (shorthand)

OPTIONS
  -h, --help     Show this help

EXAMPLES
  dotfiles aliases
  dotfiles -a
EOF
}

_help_cd() {
    cat << 'EOF'
dotfiles cd — print the dotfiles installation path

USAGE
  dotfiles cd [OPTIONS]

OPTIONS
  -h, --help     Show this help

EXAMPLES
  cd "$(dotfiles cd)"   # Navigate to the dotfiles directory
EOF
}

_help_diff() {
    cat << 'EOF'
dotfiles diff — show changes in copy-on-install files vs repo

USAGE
  dotfiles diff [OPTIONS]
  dotfiles -d

OPTIONS
  -h, --help     Show this help

EXAMPLES
  dotfiles diff
EOF
}

