#!/usr/bin/env bash
# Dotfiles CLI - manage your dotfiles installation
# Usage: dotfiles <command> [options]
#
# Commands:
#   update  -u    Pull latest changes and re-run installer
#   status  -s    Show version, sync status, and local changes
#   health        Run full health check
#   set           Configure project directories (DEV_ROOT, PROJECTS_ROOT)
#   theme   -t    Manage colour themes
#   links   -l    Show all managed symlinks and their status
#   aliases -a    Show all shell aliases, functions, and utilities
#   notes   -n    Browse the full changelog in a pager
#   version -v    Show current dotfiles version, preset, and theme
#   edit    -e    Open dotfiles directory in $EDITOR
#   cd            Print dotfiles path (use: cd "$(dotfiles cd)")
#   help          Show this help message

set -euo pipefail

# Detect script location to find DOTFILES_DIR
SCRIPT_PATH="${BASH_SOURCE[0]}"
# Resolve symlinks to find the real script location
while [[ -L "$SCRIPT_PATH" ]]; do
    SCRIPT_DIR="$(cd -P "$(dirname "$SCRIPT_PATH")" && pwd)"
    SCRIPT_PATH="$(readlink "$SCRIPT_PATH")"
    [[ "$SCRIPT_PATH" != /* ]] && SCRIPT_PATH="$SCRIPT_DIR/$SCRIPT_PATH"
done
SCRIPT_DIR="$(cd -P "$(dirname "$SCRIPT_PATH")" && pwd)"

# DOTFILES_DIR is parent of scripts/
DOTFILES_DIR="${DOTFILES_DIR:-$(dirname "$SCRIPT_DIR")}"
CONFIG_DIR="${XDG_CONFIG_HOME:-$HOME/.config}/dotfiles"
PRESET_FILE="$CONFIG_DIR/preset"

# Source common utilities
# shellcheck disable=SC1091
source "$DOTFILES_DIR/scripts/_lib/common.sh"

# Get the saved preset or default to full
get_preset() {
    if [[ -f "$PRESET_FILE" ]]; then
        cat "$PRESET_FILE"
    else
        echo "full"
    fi
}

# ─────────────────────────────────────────
# Changelog helpers
# ─────────────────────────────────────────

# Get the latest non-Unreleased version from the local changelog
_changelog_local_version() {
    sed -n 's/^## \[\([0-9][^]]*\)\].*/\1/p' "$DOTFILES_DIR/CHANGELOG.md" | head -1
}

# Show changelog entries from the remote that are newer than the local version
# Outputs nothing if no new entries exist
_changelog_incoming() {
    local remote_branch="$1"
    local local_version

    local_version=$(_changelog_local_version) || return 1
    [[ -z "$local_version" ]] && return 1

    local remote_changelog
    remote_changelog=$(git show "$remote_branch:CHANGELOG.md" 2>/dev/null) || return 1

    # Extract entries newer than local version (skip [Unreleased], stop at local version)
    printf '%s\n' "$remote_changelog" | awk -v ver="$local_version" '
        /^## \[Unreleased\]/ { next }
        /^## \[/ {
            if (index($0, "[" ver "]")) exit
            found = 1
        }
        found { print }
    '
}

# Colorise changelog markdown for terminal display
_changelog_colorise() {
    local cyan=$'\033[0;36m' green=$'\033[0;32m' magenta=$'\033[0;35m' bold_magenta=$'\033[1;35m'
    local yellow=$'\033[0;33m' red=$'\033[0;31m' grey=$'\033[0;90m' nc=$'\033[0m'
    sed \
        -e "s|^\(## \[.*\]\) ★ current\(.*\)|${magenta}\1 ${bold_magenta}★ current${magenta}\2${nc}|" \
        -e "s|^## \[.*|${cyan}&${nc}|" \
        -e "s|^### Added.*|${green}&${nc}|" \
        -e "s|^### Changed.*|${yellow}&${nc}|" \
        -e "s|^### Fixed.*|${yellow}&${nc}|" \
        -e "s|^### Removed.*|${red}&${nc}|" \
        -e "s|^- |  ${grey}•${nc} |"
}

# Get the default remote branch
get_remote_branch() {
    cd "$DOTFILES_DIR"
    local ref
    ref=$(git symbolic-ref refs/remotes/origin/HEAD 2>/dev/null) || {
        # Fallback: try common names
        if git rev-parse --verify origin/main &>/dev/null; then
            echo "origin/main"
        elif git rev-parse --verify origin/master &>/dev/null; then
            echo "origin/master"
        else
            echo "origin/main"  # Default guess
        fi
        return
    }
    echo "${ref#refs/remotes/}"
}

cmd_update() {
    local preset remote_branch

    cd "$DOTFILES_DIR"

    preset=$(get_preset)
    remote_branch=$(get_remote_branch)
    local_branch=$(git rev-parse --abbrev-ref HEAD)

    print_logo
    print_header "Dotfiles Update"

    printf "${CYAN}Preset:${NC}  %s\n" "$preset"
    printf "${CYAN}Branch:${NC}  %s (tracking %s)\n" "$local_branch" "$remote_branch"
    echo ""

    # Fetch and check status
    printf "  ${CYAN}→${NC} Fetching from origin...\n"
    git fetch origin --quiet

    local behind ahead
    behind=$(git rev-list HEAD.."$remote_branch" --count 2>/dev/null) || behind=0
    ahead=$(git rev-list "$remote_branch"..HEAD --count 2>/dev/null) || ahead=0

    if [[ $behind -eq 0 && $ahead -eq 0 ]]; then
        printf "  ${GREEN}✓${NC} Already up-to-date!\n"
        echo ""
        return 0
    fi

    if [[ $ahead -gt 0 ]]; then
        printf "  ${YELLOW}!${NC} You have %d unpushed commit(s)\n" "$ahead"
    fi

    if [[ $behind -gt 0 ]]; then
        printf "  ${CYAN}→${NC} Pulling %d new commit(s)...\n" "$behind"

        # Show incoming changelog entries
        local incoming
        incoming=$(_changelog_incoming "$remote_branch") || true
        if [[ -n "$incoming" ]]; then
            echo ""
            printf "  ${CYAN}What's new:${NC}\n"
            printf '%s\n' "$incoming" | _changelog_colorise | sed 's/^/  /'
        fi

        echo ""
        git pull --ff-only --quiet origin "$local_branch" || {
            error "Pull failed. You may have local changes that conflict."
            echo "Try: cd $DOTFILES_DIR && git status"
            return 1
        }
        echo ""

        # Re-run installer with saved preset
        printf "  ${CYAN}→${NC} Re-running installer with --%s preset...\n" "$preset"
        echo ""
        "$DOTFILES_DIR/install.sh" "--$preset" --skip-backup --no-logo
    fi
}

cmd_status() {
    cd "$DOTFILES_DIR"

    local preset remote_branch behind ahead version

    preset=$(get_preset)
    remote_branch=$(get_remote_branch)
    version=$(_changelog_local_version) || true

    print_logo
    print_header "Dotfiles Status"

    # Summary line: version, preset, theme, branch
    [[ -n "$version" ]] && printf "${CYAN}Version:${NC}   %s\n" "$version"
    printf "${CYAN}Preset:${NC}    %s\n" "$preset"
    local theme_file="${XDG_CONFIG_HOME:-$HOME/.config}/dotfiles/current-theme"
    [[ -f "$theme_file" ]] && printf "${CYAN}Theme:${NC}     %s\n" "$(<"$theme_file")"
    printf "${CYAN}Branch:${NC}    %s\n" "$(git rev-parse --abbrev-ref HEAD)"
    printf "${CYAN}Path:${NC}      %s\n" "$DOTFILES_DIR"
    echo ""

    # Fetch quietly
    git fetch origin --quiet 2>/dev/null || true

    behind=$(git rev-list HEAD.."$remote_branch" --count 2>/dev/null) || behind=0
    ahead=$(git rev-list "$remote_branch"..HEAD --count 2>/dev/null) || ahead=0

    if [[ $behind -eq 0 && $ahead -eq 0 ]]; then
        printf "  ${GREEN}✓${NC} Up-to-date with %s\n" "$remote_branch"
    else
        if [[ $behind -gt 0 ]]; then
            printf "  ${YELLOW}↓${NC} %d commit(s) behind %s\n" "$behind" "$remote_branch"
        fi
        if [[ $ahead -gt 0 ]]; then
            printf "  ${YELLOW}↑${NC} %d commit(s) ahead of %s\n" "$ahead" "$remote_branch"
        fi

        # Show incoming changelog entries
        if [[ $behind -gt 0 ]]; then
            local incoming
            incoming=$(_changelog_incoming "$remote_branch") || true
            if [[ -n "$incoming" ]]; then
                echo ""
                printf "  ${CYAN}Incoming changes:${NC}\n"
                printf '%s\n' "$incoming" | _changelog_colorise | sed 's/^/  /'
                echo ""
                printf "  ${GREY}Run 'dotfiles update' to apply.${NC}\n"
            fi
        fi
    fi

    # Local changes
    if [[ -n $(git status --porcelain 2>/dev/null) ]]; then
        echo ""
        printf "  ${YELLOW}!${NC} Uncommitted local changes:\n"
        git status --short | sed 's/^/    /'
    fi

    echo ""
}

cmd_health() {
    "$DOTFILES_DIR/scripts/install/health-check.sh"
}

cmd_edit() {
    cd "$DOTFILES_DIR"
    ${EDITOR:-vim} .
}

cmd_cd() {
    echo "$DOTFILES_DIR"
}

# ─────────────────────────────────────────
# Release notes
# ─────────────────────────────────────────
cmd_notes() {
    local changelog="$DOTFILES_DIR/CHANGELOG.md"

    if [[ ! -f "$changelog" ]]; then
        error "CHANGELOG.md not found"
        return 1
    fi

    local current_version
    current_version=$(_changelog_local_version) || true

    # Try to show the remote changelog so users can see unreceived changes
    local content=""
    cd "$DOTFILES_DIR"
    git fetch origin --quiet 2>/dev/null || true
    local remote_branch
    remote_branch=$(get_remote_branch)
    content=$(git show "$remote_branch:CHANGELOG.md" 2>/dev/null) || content=""

    # Fall back to local changelog if remote is unavailable
    if [[ -z "$content" ]]; then
        content=$(<"$changelog")
    fi

    # Pre-process: mark the current version line with ★
    if [[ -n "$current_version" ]]; then
        local escaped="${current_version//./\\.}"
        content=$(printf '%s\n' "$content" | sed "s/^## \[${escaped}\]/& ★ current/")
    fi

    # Always use custom coloriser so the ★ current marker gets accent colour
    printf '%s\n' "$content" | _changelog_colorise | less -R
}

cmd_version() {
    local version
    version=$(_changelog_local_version) || true

    if [[ -z "$version" ]]; then
        error "Could not determine version from CHANGELOG.md"
        return 1
    fi

    print_logo

    printf "${CYAN}Version:${NC}  %s\n" "$version"
    printf "${CYAN}Preset:${NC}   %s\n" "$(get_preset)"

    local theme_file="${XDG_CONFIG_HOME:-$HOME/.config}/dotfiles/current-theme"
    if [[ -f "$theme_file" ]]; then
        printf "${CYAN}Theme:${NC}    %s\n" "$(<"$theme_file")"
    fi

    cd "$DOTFILES_DIR"
    printf "${CYAN}Branch:${NC}   %s\n" "$(git rev-parse --abbrev-ref HEAD 2>/dev/null || echo "unknown")"
    printf "${CYAN}Path:${NC}     %s\n" "$DOTFILES_DIR"
    echo ""
}

# ─────────────────────────────────────────
# Theme management
# ─────────────────────────────────────────
cmd_theme() {
    local theme_cmd="${1:-list}"
    shift || true

    case "$theme_cmd" in
        list)
            "$DOTFILES_DIR/scripts/theme-switch" list
            ;;
        current)
            "$DOTFILES_DIR/scripts/theme-switch" current
            ;;
        generate)
            "$DOTFILES_DIR/scripts/generate-theme" "$@"
            ;;
        delete)
            "$DOTFILES_DIR/scripts/theme-delete" "$@"
            ;;
        *)
            "$DOTFILES_DIR/scripts/theme-switch" "$theme_cmd"
            ;;
    esac
}

# ─────────────────────────────────────────
# Set configuration
# ─────────────────────────────────────────
cmd_set() {
    local target="${1:-}"
    local dir="${2:-}"

    if [[ -z "$target" ]]; then
        error "Usage: dotfiles set <dev|projects> <directory>"
        echo ""
        echo "Examples:"
        echo "  dotfiles set dev ~/src"
        echo "  dotfiles set projects ~/playground"
        return 1
    fi

    local var_name
    case "$target" in
        dev)
            var_name="DEV_ROOT"
            ;;
        projects)
            var_name="PROJECTS_ROOT"
            ;;
        *)
            error "Unknown target: $target (use 'dev' or 'projects')"
            return 1
            ;;
    esac

    if [[ -z "$dir" ]]; then
        error "Directory argument required"
        echo "Usage: dotfiles set $target <directory>"
        return 1
    fi

    # Expand ~ and resolve to absolute path
    dir="${dir/#\~/$HOME}"
    if [[ -d "$dir" ]]; then
        dir=$(cd "$dir" && pwd)
    elif [[ -d "$(dirname "$dir")" ]]; then
        dir=$(cd "$(dirname "$dir")" && pwd)/$(basename "$dir")
    fi

    # Store with $HOME for portability
    local stored_value="\$HOME${dir#"$HOME"}"

    update_zshrc_export "$var_name" "$stored_value"

    success "$var_name set to $dir"
    printf "  ${GREY}Updated ~/.zshrc${NC}\n"
    echo ""
    info "Run 'source ~/.zshrc' or open a new shell to apply."
}

cmd_help() {
    print_logo
    cat << 'EOF'
Dotfiles CLI - manage your dotfiles installation

Usage: dotfiles <command> [options]    (shorthand: dot <command>)

Commands:
  update  -u    Pull latest changes and re-run installer with saved preset
  status  -s    Show version, sync status, and local changes
  health        Run full health check (symlinks, plugins, secrets)
  set           Configure project directories
                dotfiles set dev <dir>       - Set DEV_ROOT in ~/.zshrc
                dotfiles set projects <dir>  - Set PROJECTS_ROOT in ~/.zshrc
  theme   -t    Manage colour themes
                dotfiles theme list          - List available themes
                dotfiles theme current       - Show current theme
                dotfiles theme <name>        - Switch to theme
                dotfiles theme generate <n>  - Generate from Ghostty theme
                dotfiles theme generate list - List Ghostty themes
                dotfiles theme delete <n>    - Delete a generated theme
  links   -l    Show all managed symlinks and their status
  aliases -a    Show all shell aliases, functions, and utilities
  notes   -n    Browse the full changelog in a pager
  version -v    Show current dotfiles version, preset, and theme
  edit    -e    Open dotfiles directory in $EDITOR
  cd            Print dotfiles path (use: cd "$(dotfiles cd)")
  help          Show this help message

Examples:
  dotfiles status                    # Check if updates are available
  dotfiles update                    # Pull and re-install
  dotfiles notes                     # Browse full changelog
  dotfiles aliases                   # Browse available aliases and shortcuts
  dotfiles set dev ~/src             # Set DEV_ROOT for launcher picker
  dotfiles theme list                # Show available themes
  dotfiles theme dracula             # Switch to Dracula theme
  dotfiles theme generate zenburn    # Generate from Ghostty theme
  dotfiles theme delete zenburn      # Remove generated theme
  cd "$(dotfiles cd)"                # Navigate to dotfiles directory

Configuration:
  Preset is saved to ~/.config/dotfiles/preset during installation.
  The 'update' command re-uses your saved preset (minimal/core/full).
EOF
}

cmd_aliases() {
    local BOLD='\033[1m'

    # Print entries in two columns (pairs of name/description)
    # Names in yellow, descriptions in grey, columns separated by dim │
    _2col() {
        local -a items=("$@")
        local i=0 count=${#items[@]}
        while (( i < count )); do
            if (( i + 3 < count )); then
                printf "  ${YELLOW}%-12s${NC} ${GREY}%-22s${NC}  ${GREY}│${NC}  ${YELLOW}%-12s${NC} ${GREY}%s${NC}\n" \
                    "${items[$i]}" "${items[$((i+1))]}" \
                    "${items[$((i+2))]}" "${items[$((i+3))]}"
                (( i += 4 ))
            else
                printf "  ${YELLOW}%-12s${NC} ${GREY}%s${NC}\n" "${items[$i]}" "${items[$((i+1))]}"
                (( i += 2 ))
            fi
        done
    }

    printf "${BOLD}SHELL REFERENCE${NC}\n"
    printf '%0.s─' {1..80}; printf '\n'

    printf "\n${CYAN}NAVIGATION${NC}\n"
    _2col \
        "c"           "clear" \
        "cl"          "clear + scrollback" \
        ".."          "cd .." \
        "..."         "cd ../.." \
        "mkcd <dir>"  "mkdir + cd" \
        "cdb"         "cd back (browser)" \
        "cdf"         "cd forward (after cdb)" \
        "cdl"         "cd from history (fzf)"

    printf "\n${CYAN}FILES${NC}\n"
    _2col \
        "ls"  "ls (colour-aware)" \
        "ll"  "ls -alF" \
        "la"  "ls -A" \
        "l"   "ls -CF" \
        "cp"  "cp -i (safe overwrite)" \
        "mv"  "mv -i (safe overwrite)"

    printf "\n${CYAN}SEARCH & PROCESS${NC}\n"
    _2col \
        "grep"        "grep --color=auto" \
        "rg"          "ripgrep (fast search)" \
        "psg <name>"  "ps aux | grep" \
        "ports"       "lsof ports (local)"

    printf "\n${CYAN}GIT${NC}\n"
    _2col \
        "gs"   "git status -sb" \
        "gd"   "git diff" \
        "gdn"  "git diff (diffnav)" \
        "gds"  "git diff --staged" \
        "gl"   "git log (last 20)" \
        "glf"  "git log (full)" \
        "gco"  "git checkout" \
        "gsw"  "git switch" \
        "gb"   "git branch -vv" \
        "gp"   "git push" \
        "gpl"  "git pull" \
        "gst"  "git stash" \
        "gfp"  "git fetch --prune" \
        "gpr"  "prune local branches"

    printf "\n${CYAN}TMUX${NC}\n"
    _2col \
        "tls"          "list session backups" \
        "ta/tattach"   "attach/restore session" \
        "trestore"     "restore from backup" \
        "tkill"        "delete session backup" \
        "tcleanup"     "clean test resources" \
        "alerts-clear" "clear all tmux alerts"

    printf "\n${CYAN}SYSTEM & NETWORK${NC}\n"
    _2col \
        "df"      "df -h" \
        "du"      "du -sh" \
        "myip"    "curl ifconfig.me" \
        "h"       "cd ~" \
        "j"       "jobs" \
        "v"       "nvim" \
        "o"       "open file/dir" \
        "finder"  "open in Finder (macOS)"

    printf "\n${CYAN}DEVELOPMENT${NC}\n"
    _2col \
        "oc"         "opencode" \
        "drs"        "sync repo paths to gh-dash" \
        "gols"       "list Go binaries" \
        "nvim-clear" "clear nvim cache" \
        "nvim-sync"  "sync Lazy.nvim plugins" \
        "brewup"     "brew update + upgrade"

    printf "\n${CYAN}PROFILING${NC}\n"
    printf "  ${YELLOW}%-12s${NC} ${GREY}%-22s${NC}  ${GREY}│${NC}  ${YELLOW}%s${NC} ${GREY}%s${NC}\n" \
        "zsh-profile" "benchmark startup (5x)" \
        "zsh-profile-detailed" "detailed (ZPROF)"

    printf "\n${CYAN}DOTFILES CLI${NC}\n"
    _2col \
        "update  -u"  "pull + re-install" \
        "status  -s"  "version + sync + changes" \
        "health"      "full health check" \
        "links   -l"  "managed symlinks" \
        "theme   -t"  "colour themes" \
        "set dev <d>" "set DEV_ROOT" \
        "notes   -n"  "browse changelog" \
        "version -v"  "version, preset, theme" \
        "edit    -e"  "open in \$EDITOR" \
        "aliases -a"  "show this reference" \
        "dot"         "shorthand for dotfiles" \
        "help"        "show help message"

    # Dotfiles-managed directories from ~/.zshrc
    local zshrc="$HOME/.zshrc"
    if [[ -f "$zshrc" ]]; then
        local dev_root projects_root
        dev_root=$(grep -E '^\s*export\s+DEV_ROOT=' "$zshrc" 2>/dev/null | head -1 | sed 's/.*=//; s/^"//; s/"$//' || true)
        projects_root=$(grep -E '^\s*export\s+PROJECTS_ROOT=' "$zshrc" 2>/dev/null | head -1 | sed 's/.*=//; s/^"//; s/"$//' || true)
        if [[ -n "$dev_root" || -n "$projects_root" ]]; then
            printf "\n${CYAN}DOTFILES DIRECTORIES${NC}  ${GREY}(set via dotfiles set)${NC}\n"
            [[ -n "$dev_root" ]] && printf "  ${YELLOW}%-14s${NC} ${GREY}%s${NC}\n" "DEV_ROOT" "$dev_root"
            [[ -n "$projects_root" ]] && printf "  ${YELLOW}%-14s${NC} ${GREY}%s${NC}\n" "PROJECTS_ROOT" "$projects_root"
        fi
    fi

    # User-defined aliases from ~/.zshrc
    if [[ -f "$zshrc" ]]; then
        local user_aliases
        user_aliases=$(grep -E '^\s*alias\s+' "$zshrc" 2>/dev/null | sed 's/^[[:space:]]*alias[[:space:]]*//' || true)
        if [[ -n "$user_aliases" ]]; then
            printf "\n${CYAN}USER ALIASES${NC}  ${GREY}(~/.zshrc)${NC}\n"
            while IFS= read -r line; do
                local name="${line%%=*}"
                local value="${line#*=}"
                # Strip inline comment (everything from whitespace+# onwards)
                value="${value%%[[:space:]]# *}"
                # Strip surrounding quotes
                value="${value#[\"\']}"
                value="${value%[\"\']}"
                printf "  ${YELLOW}%-14s${NC} ${GREY}%s${NC}\n" "$name" "$value"
            done <<< "$user_aliases"
        fi
    fi

    printf '\n'; printf '%0.s─' {1..80}; printf '\n'
    printf "${GREEN}Tip:${NC} run ${YELLOW}dotfiles help${NC} for CLI usage, ${YELLOW}dotfiles health${NC} to verify your install.\n\n"
}

# ─────────────────────────────────────────
# Managed symlinks
# ─────────────────────────────────────────
cmd_links() {
    local preset
    preset=$(get_preset)

    local ok=0 broken=0 absent=0 file_exists=0

    _check_link() {
        local dest="$1"
        # Display path with ~ for $HOME prefix
        local label="${dest/#"$HOME"/\~}"

        if [[ -L "$dest" ]]; then
            if [[ -e "$dest" ]]; then
                printf "  ${GREEN}OK${NC}      %s  ${GREY}→ %s${NC}\n" "$label" "$(readlink "$dest")"
                ok=$(( ok + 1 ))
            else
                printf "  ${RED}BROKEN${NC}  %s  ${GREY}→ %s${NC}\n" "$label" "$(readlink "$dest")"
                broken=$(( broken + 1 ))
            fi
        elif [[ -e "$dest" ]]; then
            printf "  ${YELLOW}FILE${NC}    %s  ${GREY}(exists but not a symlink)${NC}\n" "$label"
            file_exists=$(( file_exists + 1 ))
        else
            printf "  ${YELLOW}ABSENT${NC}  %s\n" "$label"
            absent=$(( absent + 1 ))
        fi
    }

    print_logo
    print_header "Managed Symlinks"
    printf "${CYAN}Preset:${NC} %s\n\n" "$preset"

    # Zsh (minimal)
    printf "${CYAN}Zsh${NC}\n"
    _check_link "$HOME/.zprofile"
    _check_link "$HOME/.p10k.zsh"

    # Tmux (minimal)
    printf "\n${CYAN}Tmux${NC}\n"
    _check_link "$HOME/.tmux"
    _check_link "$HOME/.tmux.conf"

    # CLI (minimal)
    printf "\n${CYAN}CLI${NC}\n"
    _check_link "$HOME/.local/bin/dotfiles"

    # Prettier (minimal)
    printf "\n${CYAN}Prettier${NC}\n"
    _check_link "$HOME/.prettierrc"

    # Neovim (core)
    if should_install "core"; then
        printf "\n${CYAN}Neovim${NC}\n"
        _check_link "$HOME/.config/nvim"
    fi

    # Ghostty (core) — config is generated, not symlinked

    # gh-dash (core) — config is generated, not symlinked
    if should_install "core"; then
        printf "\n${CYAN}gh-dash${NC}\n"
        _check_link "$HOME/.local/bin/dash-repo-sync"
    fi

    # Launchers (core)
    if should_install "core"; then
        printf "\n${CYAN}Launchers${NC}\n"
        _check_link "$HOME/.local/launchers/dev"
    fi

    # LazyGit (core)
    if should_install "core"; then
        printf "\n${CYAN}LazyGit${NC}\n"
        _check_link "$HOME/.config/lazygit/config.yml"
    fi



    # Hammerspoon (full)
    if should_install "full"; then
        printf "\n${CYAN}Hammerspoon${NC}\n"
        _check_link "$HOME/.hammerspoon/init.lua"
    fi

    # Summary
    local total=$(( ok + broken + absent + file_exists ))
    echo ""
    printf "${GREEN}%d OK${NC}  ${RED}%d broken${NC}  ${YELLOW}%d absent${NC}  ${YELLOW}%d file${NC}  (%d total)\n" \
        "$ok" "$broken" "$absent" "$file_exists" "$total"
    echo ""
}

# Main dispatch
main() {
    local cmd="${1:-help}"

    case "$cmd" in
        update|-u)
            cmd_update
            ;;
        status|-s)
            cmd_status
            ;;
        health)
            cmd_health
            ;;
        set)
            shift
            cmd_set "$@"
            ;;
        theme|-t)
            shift
            cmd_theme "$@"
            ;;
        links|-l)
            cmd_links
            ;;
        aliases|alias|cheat|-a)
            cmd_aliases
            ;;
        edit|-e)
            cmd_edit
            ;;
        cd)
            cmd_cd
            ;;
        notes|-n)
            cmd_notes
            ;;
        version|-v|--version)
            cmd_version
            ;;
        help|--help|-h)
            cmd_help
            ;;
        *)
            error "Unknown command: $cmd"
            echo ""
            cmd_help
            exit 1
            ;;
    esac
}

main "$@"
