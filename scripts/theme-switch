#!/usr/bin/env bash
set -euo pipefail

# ══════════════════════════════════════════════════════════════
# Theme Switcher for Tmux, Ghostty & gh-dash
# ══════════════════════════════════════════════════════════════
# Usage:
#   theme-switch <theme-name>
#   theme-switch list
#   theme-switch current
#
# Examples:
#   theme-switch dracula
#   theme-switch catppuccin-mocha
#   theme-switch tokyo-night
#   theme-switch nord

SCRIPT_DIR="$(cd "$(dirname "$(readlink -f "${BASH_SOURCE[0]}" 2>/dev/null || realpath "${BASH_SOURCE[0]}")")" && pwd)"
DOTFILES_ROOT="$(cd "$SCRIPT_DIR/.." && pwd)"

# shellcheck source=scripts/_lib/common.sh
source "$DOTFILES_ROOT/scripts/_lib/common.sh"
# shellcheck source=scripts/_lib/ghdash.sh
source "$DOTFILES_ROOT/scripts/_lib/ghdash.sh"

# Build sed -e arguments from an associative array of placeholder→value mappings.
# Usage: _build_sed_args vars_assoc_array_name
# Populates the caller's `sed_args` array with -e flags.
_build_sed_args() {
    local -n _vars=$1
    sed_args=()
    for key in "${!_vars[@]}"; do
        sed_args+=(-e "s|{{${key}}}|${_vars[$key]}|g")
    done
}

# Directories
THEMES_DIR="$DOTFILES_ROOT/themes"
CONFIG_DIR="${XDG_CONFIG_HOME:-$HOME/.config}/dotfiles"
CURRENT_THEME_FILE="$CONFIG_DIR/current-theme"

# Templates and output files
TMUX_TEMPLATE="$DOTFILES_ROOT/tmux/tmux.conf.template"
TMUX_OUTPUT="${XDG_CONFIG_HOME:-$HOME/.config}/tmux/tmux.conf"
GHOSTTY_TEMPLATE="$DOTFILES_ROOT/ghostty/config.template"

# Ghostty config location (XDG only - macOS symlinks to this)
GHOSTTY_OUTPUT="${XDG_CONFIG_HOME:-$HOME/.config}/ghostty/config"
GH_DASH_TEMPLATE="$DOTFILES_ROOT/gh-dash/config.yml.template"
GH_DASH_OUTPUT="$GHDASH_BASE"

# ══════════════════════════════════════════════════════════════
# Theme Output Functions (different style from common.sh)
# ══════════════════════════════════════════════════════════════

theme_error()   { printf "${RED}✗${NC} %s\n" "$1" >&2; }
theme_success() { printf "${GREEN}✓${NC} %s\n" "$1"; }
theme_info()    { printf "${CYAN}•${NC} %s\n" "$1"; }
theme_warn()    { printf "${YELLOW}!${NC} %s\n" "$1"; }

# List installed themes (hand-crafted + generated on disk)
list_themes() {
    local current_theme=""
    if [[ -f "$CURRENT_THEME_FILE" ]]; then
        current_theme=$(cat "$CURRENT_THEME_FILE")
    fi

    printf "\n${CYAN}Custom themes:${NC}\n\n"

    for theme_file in "$THEMES_DIR"/*.theme; do
        if [[ -f "$theme_file" ]]; then
            local theme_name
            theme_name=$(basename "$theme_file" .theme)
            # shellcheck disable=SC1090
            source "$theme_file"

            local tags=""
            if [[ "$current_theme" == "$theme_name" ]]; then
                tags=" ${GREEN}#current${NC}"
            fi

            printf "  ${CYAN}•${NC} %s - %s${YELLOW} #custom${NC}%b\n" "$theme_name" "$THEME_NAME" "$tags"
        fi
    done

    # Show generated themes
    local has_generated=false
    for theme_file in "$THEMES_DIR/generated/"*.theme; do
        if [[ -f "$theme_file" ]]; then
            if [[ "$has_generated" == "false" ]]; then
                printf "\n${CYAN}Generated themes:${NC}\n\n"
                has_generated=true
            fi

            local theme_name
            theme_name=$(basename "$theme_file" .theme)
            # shellcheck disable=SC1090
            source "$theme_file"

            local tags=""
            if [[ "$current_theme" == "$theme_name" ]]; then
                tags=" ${GREEN}#current${NC}"
            fi

            printf "  ${CYAN}•${NC} %s - %s%b\n" "$theme_name" "$THEME_NAME" "$tags"
        fi
    done

    # Hint about Ghostty themes
    if [[ -x "$SCRIPT_DIR/generate-theme" ]]; then
        local available_count
        available_count=$("$SCRIPT_DIR/generate-theme" list 2>/dev/null | wc -l | tr -d ' ' || true)
        if [[ "$available_count" -gt 0 ]]; then
            printf "\n  ${CYAN}%s Ghostty themes available.${NC} Use 'dotfiles theme <name>' to auto-generate.\n" "$available_count"
            printf "  Run 'dotfiles theme generate list' for the full list.\n"
        fi
    fi

    printf "\n"
}

# Get current theme
get_current_theme() {
    if [[ -f "$CURRENT_THEME_FILE" ]]; then
        cat "$CURRENT_THEME_FILE"
    else
        echo "dracula"  # Default
    fi
}

# Apply theme by replacing template variables
apply_theme() {
    local theme_name="$1"
    local no_reload="${2:-false}"
    local quiet="${3:-false}"
    local theme_file="$THEMES_DIR/$theme_name.theme"

    # Tier 1: Hand-crafted theme
    if [[ -f "$theme_file" ]]; then
        : # Use hand-crafted theme
    # Tier 2: Previously generated theme
    elif [[ -f "$THEMES_DIR/generated/$theme_name.theme" ]]; then
        theme_file="$THEMES_DIR/generated/$theme_name.theme"
    # Tier 3: Auto-generate from Ghostty
    else
        if [[ "$quiet" != "true" ]]; then
            theme_info "Theme '$theme_name' not found locally, checking Ghostty themes..."
        fi
        local generated_name
        if generated_name=$("$SCRIPT_DIR/generate-theme" "$theme_name" ${quiet:+--quiet}); then
            theme_file="$THEMES_DIR/generated/$generated_name.theme"
        else
            [[ "$quiet" != "true" ]] && theme_error "Theme '$theme_name' not found"
            [[ "$quiet" != "true" ]] && theme_info "Run 'dotfiles theme list' to see available themes"
            return 1
        fi
    fi

    # Source theme variables
    # shellcheck disable=SC1090
    source "$theme_file"

    # Apply theme defaults (derives status bar, pane borders, FZF from base colours)
    # shellcheck disable=SC1091
    source "$THEMES_DIR/theme-defaults.sh"
    apply_theme_defaults

    # Validate required theme variables are defined
    local required_vars=(
        THEME_NAME TMUX_BG_PRIMARY TMUX_FG_PRIMARY TMUX_STATUS_BG TMUX_STATUS_FG
        GHOSTTY_BACKGROUND GHOSTTY_FOREGROUND
    )
    for var in "${required_vars[@]}"; do
        if [[ -z "${!var:-}" ]]; then
            theme_error "Theme '$theme_name' is missing required variable: $var"
            return 1
        fi
    done

    [[ "$quiet" != "true" ]] && theme_info "Applying theme: $THEME_NAME"

    # Process tmux template using sed (much faster than bash string replacement)
    if [[ -f "$TMUX_TEMPLATE" ]]; then
        # Ensure XDG config directory exists
        mkdir -p "$(dirname "$TMUX_OUTPUT")"
        local tmux_tmp="${TMUX_OUTPUT}.tmp.$$"

        # Determine platform clipboard command
        local clipboard_cmd="pbcopy"
        if is_linux; then
            if command_exists wl-copy; then
                clipboard_cmd="wl-copy"
            elif command_exists xclip; then
                clipboard_cmd="xclip -selection clipboard"
            elif command_exists xsel; then
                clipboard_cmd="xsel --clipboard --input"
            fi
        fi

        # Build sed arguments from theme variables (adding new vars only requires a new entry)
        declare -A tmux_vars=(
            [THEME_NAME]="$THEME_NAME"
            [TMUX_BG_PRIMARY]="$TMUX_BG_PRIMARY"
            [TMUX_FG_PRIMARY]="$TMUX_FG_PRIMARY"
            [TMUX_STATUS_BG]="$TMUX_STATUS_BG"
            [TMUX_STATUS_FG]="$TMUX_STATUS_FG"
            [TMUX_STATUS_ACTIVE_BG]="$TMUX_STATUS_ACTIVE_BG"
            [TMUX_STATUS_ACTIVE_FG]="$TMUX_STATUS_ACTIVE_FG"
            [TMUX_STATUS_INACTIVE_FG]="$TMUX_STATUS_INACTIVE_FG"
            [TMUX_STATUS_BELL_FG]="$TMUX_STATUS_BELL_FG"
            [TMUX_EXIT_PASS_COLOUR]="$TMUX_EXIT_PASS_COLOUR"
            [TMUX_EXIT_FAIL_COLOUR]="$TMUX_EXIT_FAIL_COLOUR"
            [TMUX_ACCENT_CYAN]="$TMUX_ACCENT_CYAN"
            [TMUX_ACCENT_PINK]="$TMUX_ACCENT_PINK"
            [TMUX_ACCENT_PURPLE]="$TMUX_ACCENT_PURPLE"
            [TMUX_ACCENT_YELLOW]="$TMUX_ACCENT_YELLOW"
            [TMUX_ACCENT_GREEN]="$TMUX_ACCENT_GREEN"
            [TMUX_BG_SECONDARY]="$TMUX_BG_SECONDARY"
            [TMUX_FG_SECONDARY]="$TMUX_FG_SECONDARY"
            [TMUX_PANE_BORDER_INACTIVE]="$TMUX_PANE_BORDER_INACTIVE"
            [TMUX_PANE_BORDER_ACTIVE]="$TMUX_PANE_BORDER_ACTIVE"
            [TMUX_MESSAGE_BG]="$TMUX_MESSAGE_BG"
            [TMUX_MESSAGE_FG]="$TMUX_MESSAGE_FG"
            [TMUX_MESSAGE_COMMAND_BG]="$TMUX_MESSAGE_COMMAND_BG"
            [TMUX_MESSAGE_COMMAND_FG]="$TMUX_MESSAGE_COMMAND_FG"
            [TMUX_CPU_LOW_BG]="$TMUX_CPU_LOW_BG"
            [TMUX_CPU_MEDIUM_BG]="$TMUX_CPU_MEDIUM_BG"
            [TMUX_CPU_HIGH_BG]="$TMUX_CPU_HIGH_BG"
            [TMUX_RAM_LOW_BG]="$TMUX_RAM_LOW_BG"
            [TMUX_RAM_MEDIUM_BG]="$TMUX_RAM_MEDIUM_BG"
            [TMUX_RAM_HIGH_BG]="$TMUX_RAM_HIGH_BG"
            [TMUX_BATTERY_NORMAL_BG]="$TMUX_BATTERY_NORMAL_BG"
            [TMUX_BATTERY_LOW_BG]="$TMUX_BATTERY_LOW_BG"
            [CLIPBOARD_CMD]="$clipboard_cmd"
            [DOTFILES_ROOT]="$DOTFILES_ROOT"
        )
        local -a sed_args
        _build_sed_args tmux_vars
        sed "${sed_args[@]}" "$TMUX_TEMPLATE" > "$tmux_tmp" || { rm -f "$tmux_tmp"; return 1; }
        mv "$tmux_tmp" "$TMUX_OUTPUT"
        [[ "$quiet" != "true" ]] && theme_success "Generated tmux configuration"
    else
        [[ "$quiet" != "true" ]] && theme_warn "Tmux template not found, skipping"
    fi

    # Process ghostty template using sed
    if [[ -f "$GHOSTTY_TEMPLATE" ]]; then
        # Ensure ghostty config directory exists
        mkdir -p "$(dirname "$GHOSTTY_OUTPUT")"
        local ghostty_tmp platform_tmp
        ghostty_tmp=$(mktemp)
        platform_tmp=$(mktemp)

        # Build platform-specific config (macOS uses opt+, Linux uses alt+)
        if is_macos; then
            local mod="opt"
            cat > "$platform_tmp" <<PLATFORM
# macOS
macos-icon = glass
macos-icon-frame = chrome
macos-option-as-alt = left

PLATFORM
        else
            local mod="alt"
            printf "# Linux\n" > "$platform_tmp"
        fi

        cat >> "$platform_tmp" <<PLATFORM
keybind = shift+enter=text:\x1b\r
keybind = ctrl+enter=text:\x1b[13;5u
keybind = ctrl+shift+enter=text:\x1b[13;6u
keybind = ${mod}+c=text:\x1bc
keybind = ${mod}+shift+[=text:\x1b{
keybind = ${mod}+shift+]=text:\x1b}
keybind = ${mod}+shift+h=text:\x1bH
keybind = ${mod}+shift+j=text:\x1bJ
keybind = ${mod}+shift+k=text:\x1bK
keybind = ${mod}+shift+l=text:\x1bL
keybind = ${mod}+shift+d=text:\x1bD
keybind = ${mod}+shift+0=text:\x1b)
keybind = ${mod}+up=text:\x1b[1;3A
keybind = ${mod}+down=text:\x1b[1;3B
keybind = ${mod}+3=text:#
keybind = super+left=text:\x1b[H
keybind = super+right=text:\x1b[F
keybind = super+up=text:\x1b[1;5H
keybind = super+down=text:\x1b[1;5F
keybind = shift+backspace=text:\x7f
keybind = shift+space=text:\x20
PLATFORM

        declare -A ghostty_vars=(
            [THEME_NAME]="$THEME_NAME"
            [GHOSTTY_BACKGROUND]="$GHOSTTY_BACKGROUND"
            [GHOSTTY_FOREGROUND]="$GHOSTTY_FOREGROUND"
            [GHOSTTY_CURSOR_COLOR]="$GHOSTTY_CURSOR_COLOR"
            [GHOSTTY_CURSOR_TEXT]="$GHOSTTY_CURSOR_TEXT"
            [GHOSTTY_SELECTION_BG]="$GHOSTTY_SELECTION_BG"
            [GHOSTTY_SELECTION_FG]="$GHOSTTY_SELECTION_FG"
            [GHOSTTY_PALETTE_0]="$GHOSTTY_PALETTE_0"
            [GHOSTTY_PALETTE_1]="$GHOSTTY_PALETTE_1"
            [GHOSTTY_PALETTE_2]="$GHOSTTY_PALETTE_2"
            [GHOSTTY_PALETTE_3]="$GHOSTTY_PALETTE_3"
            [GHOSTTY_PALETTE_4]="$GHOSTTY_PALETTE_4"
            [GHOSTTY_PALETTE_5]="$GHOSTTY_PALETTE_5"
            [GHOSTTY_PALETTE_6]="$GHOSTTY_PALETTE_6"
            [GHOSTTY_PALETTE_7]="$GHOSTTY_PALETTE_7"
            [GHOSTTY_PALETTE_8]="$GHOSTTY_PALETTE_8"
            [GHOSTTY_PALETTE_9]="$GHOSTTY_PALETTE_9"
            [GHOSTTY_PALETTE_10]="$GHOSTTY_PALETTE_10"
            [GHOSTTY_PALETTE_11]="$GHOSTTY_PALETTE_11"
            [GHOSTTY_PALETTE_12]="$GHOSTTY_PALETTE_12"
            [GHOSTTY_PALETTE_13]="$GHOSTTY_PALETTE_13"
            [GHOSTTY_PALETTE_14]="$GHOSTTY_PALETTE_14"
            [GHOSTTY_PALETTE_15]="$GHOSTTY_PALETTE_15"
        )
        local -a sed_args
        _build_sed_args ghostty_vars
        # Platform config uses sed's r/d commands (can't go through _build_sed_args)
        sed_args+=(-e "/{{PLATFORM_CONFIG}}/{
                r $platform_tmp
                d
            }")
        sed "${sed_args[@]}" "$GHOSTTY_TEMPLATE" > "$ghostty_tmp" || { rm -f "$ghostty_tmp" "$platform_tmp"; return 1; }
        rm -f "$platform_tmp"
        mv "$ghostty_tmp" "$GHOSTTY_OUTPUT"
        [[ "$quiet" != "true" ]] && theme_success "Generated ghostty configuration"

        # Ensure local override file exists (Ghostty errors on missing config-file includes)
        local ghostty_local="${XDG_CONFIG_HOME:-$HOME/.config}/ghostty/local"
        if [[ ! -f "$ghostty_local" ]]; then
            touch "$ghostty_local"
        fi
    else
        [[ "$quiet" != "true" ]] && theme_warn "Ghostty template not found, skipping"
    fi

    # Process gh-dash template using sed
    if [[ -f "$GH_DASH_TEMPLATE" ]]; then
        mkdir -p "$(dirname "$GH_DASH_OUTPUT")"
        local ghdash_tmp="${GH_DASH_OUTPUT}.tmp.$$"
        sed -e "s|{{TMUX_FG_PRIMARY}}|$TMUX_FG_PRIMARY|g" \
            -e "s|{{TMUX_FG_SECONDARY}}|$TMUX_FG_SECONDARY|g" \
            -e "s|{{TMUX_BG_PRIMARY}}|$TMUX_BG_PRIMARY|g" \
            -e "s|{{TMUX_BG_SECONDARY}}|$TMUX_BG_SECONDARY|g" \
            -e "s|{{TMUX_ACCENT_YELLOW}}|$TMUX_ACCENT_YELLOW|g" \
            -e "s|{{TMUX_ACCENT_GREEN}}|$TMUX_ACCENT_GREEN|g" \
            -e "s|{{TMUX_ACCENT_RED}}|$TMUX_ACCENT_RED|g" \
            -e "s|{{TMUX_ACCENT_CYAN}}|$TMUX_ACCENT_CYAN|g" \
            -e "s|{{TMUX_ACCENT_PURPLE}}|$TMUX_ACCENT_PURPLE|g" \
            -e "s|{{TMUX_ACCENT_PINK}}|$TMUX_ACCENT_PINK|g" \
            "$GH_DASH_TEMPLATE" > "$ghdash_tmp" || { rm -f "$ghdash_tmp"; return 1; }
        mv "$ghdash_tmp" "$GH_DASH_OUTPUT"

        # Merge user local overrides on top (survives theme-switch)
        if [[ "$quiet" == "true" ]]; then
            ghdash_merge_local --quiet
        else
            ghdash_merge_local
        fi

        [[ "$quiet" != "true" ]] && theme_success "Generated gh-dash configuration"
    fi

    # Save current theme preference
    mkdir -p "$CONFIG_DIR"
    echo "$theme_name" > "$CURRENT_THEME_FILE"

    # Append to theme history for MRU sorting in picker
    local theme_history="${XDG_DATA_HOME:-$HOME/.local/share}/dotfiles/theme-history"
    mkdir -p "$(dirname "$theme_history")"
    printf '%s\n' "$theme_name" >> "$theme_history"
    # Trim history to last 100 entries
    if [[ $(wc -l < "$theme_history") -gt 100 ]]; then
        tail -100 "$theme_history" > "$theme_history.tmp" && mv "$theme_history.tmp" "$theme_history"
    fi

    # Reload tmux if running (unless --no-reload was specified)
    if [[ "$no_reload" != "true" ]]; then
        # shellcheck disable=SC2033
        if command -v tmux >/dev/null 2>&1 && tmux info &>/dev/null; then
            # Try XDG location first, fallback to ~/.tmux.conf
            if tmux source-file "$TMUX_OUTPUT" 2>/dev/null; then
                [[ "$quiet" != "true" ]] && theme_success "Reloaded tmux configuration"
            elif [[ -f "$HOME/.tmux.conf" ]] && tmux source-file "$HOME/.tmux.conf" 2>/dev/null; then
                [[ "$quiet" != "true" ]] && theme_success "Reloaded tmux configuration (legacy path)"
            else
                [[ "$quiet" != "true" ]] && theme_warn "Failed to reload tmux"
            fi
        else
            # Not in tmux - inform user that files are ready
            [[ "$quiet" != "true" ]] && theme_success "Theme files generated (start tmux to see changes)"
        fi

        # Reload Ghostty config (script handles detection internally)
        if [[ -f "$DOTFILES_ROOT/tmux/scripts/themes/reload-ghostty.sh" ]]; then
            "$DOTFILES_ROOT/tmux/scripts/themes/reload-ghostty.sh"
            [[ "$quiet" != "true" ]] && theme_success "Reloaded ghostty configuration"
        fi

        # Reload FZF theme colours
        if [[ -f "$DOTFILES_ROOT/tmux/scripts/themes/reload-fzf.sh" ]]; then
            "$DOTFILES_ROOT/tmux/scripts/themes/reload-fzf.sh"
            [[ "$quiet" != "true" ]] && theme_success "Reloaded FZF theme colours"
        fi
    fi

    if [[ "$quiet" != "true" ]]; then
        printf "\n"
        theme_success "Theme applied: $THEME_NAME"
        if [[ "$no_reload" == "true" ]]; then
            theme_info "Run 'tmux source ~/.config/tmux/tmux.conf' to apply tmux changes"
            theme_info "Restart ghostty to see changes"
        fi
    fi
}

# ══════════════════════════════════════════════════════════════
# Main
# ══════════════════════════════════════════════════════════════

main() {
    local command="${1:-}"
    local no_reload=false
    local quiet=false

    # Check for flags
    for arg in "$@"; do
        case "$arg" in
            --no-reload) no_reload=true ;;
            --quiet|-q) quiet=true ;;
        esac
    done

    # Collect non-flag arguments
    args=()
    for arg in "$@"; do
        case "$arg" in
            --no-reload|--quiet|-q) continue ;;
            *) args+=("$arg") ;;
        esac
    done
    set -- "${args[@]+"${args[@]}"}"
    command="${1:-}"

    case "$command" in
        list)
            list_themes
            ;;
        current)
            current=$(get_current_theme)
            # shellcheck disable=SC1090
            if [[ -f "$THEMES_DIR/$current.theme" ]]; then
                source "$THEMES_DIR/$current.theme"
            elif [[ -f "$THEMES_DIR/generated/$current.theme" ]]; then
                source "$THEMES_DIR/generated/$current.theme"
            else
                THEME_NAME="Unknown"
            fi
            printf "\n${CYAN}Current theme:${NC} %s (%s)\n\n" "$THEME_NAME" "$current"
            ;;
        "")
            theme_error "No theme specified"
            theme_info "Usage: dotfiles theme <theme-name|list|current> [--no-reload]"
            exit 1
            ;;
        *)
            apply_theme "$command" "$no_reload" "$quiet"
            ;;
    esac
}

main "$@"
