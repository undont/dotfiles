# Secrets - NEVER commit (user files now in ~/.config/zsh/)
# These patterns kept for safety in case files are accidentally created here
zsh/secrets.zsh
zsh/local-aliases.zsh

# Tmux runtime data (managed by plugins)
tmux/plugins/
tmux/resurrect/

# Generated ghostty config (template is tracked, generated config is not)
ghostty/config

# System files
.DS_Store
*.swp
*.swo
*~
*.backup

# Installation state (runtime data)
.install-state/

# Neovim generated/cache
nvim/.luarc.json
.luarc.json

# Neovim backup files
nvim/init.lua.backup

# AI Code Assistants
.claude/*
!.claude/commands/
.opencode
