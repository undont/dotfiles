# Secrets - NEVER commit (user files now in ~/.config/zsh/)
# These patterns kept for safety in case files are accidentally created here
zsh/secrets.zsh
zsh/local-aliases.zsh

# Tmux runtime data (managed by plugins)
tmux/plugins/
tmux/resurrect/

# Generated ghostty config (template is tracked, generated config is not)
ghostty/config

# Generated yazi theme (template is tracked; output lives in ~/.config/yazi).
# Defensive: only relevant if a pre-migration whole-dir symlink wrote it here.
yazi/theme.toml

# System files
.DS_Store
*.swp
*.swo
*~
*.backup

# Installation state (runtime data)
.install-state/

# Neovim generated/cache
nvim/.luarc.json
.luarc.json

# Neovim backup files
nvim/init.lua.backup

# Neovim local override (user-owned, not tracked)
nvim/local.lua

# Generated themes (auto-generated from Ghostty, local cache)
themes/generated/
!themes/generated/.gitkeep
nvim/colors/generated/
!nvim/colors/generated/.gitkeep

# AI Code Assistants
.claude/*
.claude/skills/
!.claude/rules/
.agents/*
.agents/skills/
.opencode

# Local markdown files
scratch/*
/zsh/p10k.zsh
/Dockerfile.timemachine
.plans/*
nvim.log
/.playwright-mcp
